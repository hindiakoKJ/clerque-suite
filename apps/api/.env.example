# ── Database ───────────────────────────────────────────────────────────────────
# Pooled connection URL (used by Prisma at runtime — e.g. via PgBouncer)
# Railway:  Settings → Variables → DATABASE_URL  (auto-provided if you add a Postgres service)
# Neon:     Connection string → Pooled connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/clerque?schema=public"

# Direct (non-pooled) connection — used only by Prisma Migrate
# Railway: use the same DATABASE_URL value (Railway PG has no separate direct URL)
# Neon:    Connection string → Direct connection
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/clerque?schema=public"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-64-char-random-hex"
JWT_REFRESH_SECRET="replace-with-a-different-64-char-random-hex"

# Token lifetimes (optional — these are the defaults)
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Mail (Resend) ──────────────────────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create API key
# Domain: add your Cloudflare-managed domain in Resend → Domains, then copy
#   the SPF / DKIM TXT records into Cloudflare DNS.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# The "From" address — must use a domain verified in Resend
# e.g. "Clerque <noreply@clerque.app>"
MAIL_FROM="Clerque <noreply@yourdomain.com>"

# Public URL of the frontend app (used to build password-reset links)
# No trailing slash.
APP_URL="https://clerque.cc"

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="production"

# Comma-separated list of allowed CORS origins (no trailing slash)
# Production canonical list — main.ts also hardcodes the clerque.cc family.
ALLOWED_ORIGINS="https://clerque.cc,https://console.clerque.cc,https://www.clerque.cc"

# ── File Storage (Sprint 19) ───────────────────────────────────────────────────
# When set, all uploads (product images, documents, daily backups) are
# written to Cloudflare R2 / AWS S3 instead of local disk. This is REQUIRED
# in production on Railway because Railway's filesystem is ephemeral —
# every redeploy wipes ./uploads/.
#
# CLOUDFLARE R2 SETUP (recommended — cheaper, S3-compatible):
#   1. Cloudflare dashboard → R2 → Create bucket "clerque-prod"
#   2. R2 → Manage R2 API tokens → Create token (Edit access on the bucket)
#   3. Copy the Access Key ID + Secret Access Key + endpoint URL
#   4. (Optional) R2 → bucket → Settings → Public access → enable for the
#      product-images path; copy the public r2.dev URL into S3_PUBLIC_URL
#
# AWS S3 SETUP:
#   1. S3 → Create bucket "clerque-prod" (any region; pick closest to your
#      Railway region — usually us-east-1 / ap-southeast-1)
#   2. IAM → Create user with programmatic access; attach a policy
#      granting s3:PutObject + s3:GetObject + s3:DeleteObject on the bucket
#   3. Leave S3_ENDPOINT blank (SDK uses AWS default endpoint per region)
#
# Leave all blank for local-disk fallback (dev only).
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# R2: "https://<account-id>.r2.cloudflarestorage.com"
# AWS S3: leave blank
S3_ENDPOINT=""
# R2: "auto"
# AWS S3: e.g. "ap-southeast-1"
S3_REGION="auto"
# Public CDN URL for product images. R2 example:
#   "https://pub-<bucket-id>.r2.dev"   (when public access enabled)
# Leave blank to fall back to /uploads/... served by the API (works for
# local-disk driver only; on S3 without a public URL, images can't be
# rendered by browsers without a signed-URL flow).
S3_PUBLIC_URL=""

# ── Backups (Sprint 19) ────────────────────────────────────────────────────────
# When S3_BUCKET above is set, the daily backup cron writes to:
#   <bucket>/backups/<YYYY-MM-DD>/<tenant-slug>.json
# That's the recommended path — pair it with R2 Object Lock + a 30-day
# lifecycle rule for ransomware-proof, immutable, automatically-aged backups.
#
# Legacy webhook fallback — set this to POST a copy to a Cloudflare Worker
# / Vercel function / your own ingest endpoint. Both can be set; both run.
BACKUP_WEBHOOK_URL=""
BACKUP_WEBHOOK_TOKEN=""

# ── AI (optional — Anthropic) ──────────────────────────────────────────────────
# When set, AI-powered features (copilot, summarisation) become available.
# Without it, AI features are disabled (UI affordances hidden).
ANTHROPIC_API_KEY=""

# Tenant-level monthly budget cap (USD). When a tenant exceeds this, AI
# features return 402 Payment Required. Default 50 USD.
AI_MONTHLY_BUDGET_USD="50"

# ── Error tracking (optional — Sentry) ─────────────────────────────────────────
# When set, all unhandled exceptions are reported to Sentry.
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
