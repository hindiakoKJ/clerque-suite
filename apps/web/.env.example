# ── API ────────────────────────────────────────────────────────────────────────
# Base URL of the NestJS API — no trailing slash
# Local dev:  http://localhost:3001
# Production: your Railway service URL  (e.g. https://clerque-api.up.railway.app)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── App URL (optional — used only for og:url / canonical) ───────────────────
# Should match the APP_URL set on the API side
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
