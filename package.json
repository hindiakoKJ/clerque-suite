{
  "name": "app-suite",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
