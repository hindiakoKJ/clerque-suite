{
  "name": "clerque-suite",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:seed": "npm run seed --workspace=packages/db",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=packages/db",
    "db:generate": "npx prisma generate --schema=packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.0"
  }
}
