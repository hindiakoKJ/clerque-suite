generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  // ── Administrative ──────────────────────────────────────────────────────────
  SUPER_ADMIN
  BUSINESS_OWNER // Full access; the only role that can assign MDM / PAYROLL_MASTER

  // ── Operations ──────────────────────────────────────────────────────────────
  BRANCH_MANAGER // Branch-level operations; subset of BUSINESS_OWNER rights

  // ── Sales & Revenue ─────────────────────────────────────────────────────────
  SALES_LEAD // Sales + void/discount authority; supervises cashiers
  CASHIER // Sales only; voids require SALES_LEAD / BUSINESS_OWNER co-auth
  AR_ACCOUNTANT // Accounts Receivable / Collections (Phase 4 — AR module)

  // ── Expenditure & Inventory ──────────────────────────────────────────────────
  AP_ACCOUNTANT // Accounts Payable / Supplier Bills (Phase 4 — AP module)
  MDM // Master Data Manager — products/prices/suppliers; assigned by OWNER only
  WAREHOUSE_STAFF // Stock movement / inventory adjustments; no financial access

  // ── Finance & Compliance ─────────────────────────────────────────────────────
  FINANCE_LEAD // Bank reconciliation / cash-flow reports; no payroll
  BOOKKEEPER // Journal entries / GL; no payroll; no price edits
  PAYROLL_MASTER // Salaries / payroll runs; exclusive salary column access
  ACCOUNTANT // Legacy — full ledger read; no payroll
  GENERAL_EMPLOYEE // Clock-in/out only
  EXTERNAL_AUDITOR // Read-only compliance view; no writes anywhere

  // ── Service / Display Accounts ───────────────────────────────────────────────
  // Not a real employee — a credential for kiosk hardware (KDS tablet,
  // customer-facing display, secondary station view). Read/bump-only access
  // to KDS + customer-display pages. NO Payroll app, NO Ledger app, NO Terminal.
  // Does NOT count against the tenant's staff cap.
  KIOSK_DISPLAY
}

/// Which application the access entry refers to
enum AppCode {
  POS
  LEDGER
  PAYROLL
}

/// Ordered by privilege: NONE < CLOCK_ONLY < READ_ONLY < OPERATOR < FULL
enum AccessLevel {
  NONE
  CLOCK_ONLY
  READ_ONLY
  OPERATOR
  FULL
}

/// Used to pre-seed chart of accounts labels on tenant onboarding.
/// F&B group (any of these enables recipe/ingredient inventory):
///   COFFEE_SHOP, RESTAURANT, BAKERY, FOOD_STALL, BAR_LOUNGE, CATERING
/// Non-F&B group: RETAIL, SERVICE, MANUFACTURING
enum BusinessType {
  // ── Food & Beverage ──────────────────────────────────────────────────────
  COFFEE_SHOP // Café, milk tea, coffee kiosk (legacy value — kept for backward compat)
  RESTAURANT // Dine-in or takeout restaurant
  BAKERY // Bakery, pastry shop, cake shop
  FOOD_STALL // Carinderia, turo-turo, market stall
  BAR_LOUNGE // Bar, lounge, nightspot with food/drinks
  CATERING // Catering / events food service
  // ── Non-F&B ──────────────────────────────────────────────────────────────
  RETAIL // Convenience store, boutique, product-based shop
  SERVICE // Salon, clinic, repair, any generic service-based
  LAUNDRY // Laundromat / wash-dry-fold / dry-clean — first-class vertical
  MANUFACTURING // Fabrication, construction, BOM / bill-of-materials workflows
  // ── Sprint 12 — six-engine vertical structure ─────────────────────────────
  PHARMACY // Drugstores / botikas — Compliance-Engine (Rx, lots, DDB register, expiry)
  TRUCKING // Trucking / hauling / courier — Logistics-Engine (trip tickets, liquidation)
  CONSTRUCTION // Construction / civil works / fit-out — Project-Engine (WIP, progress billing)
  // ── Sprint Bakery+1 — DME + Fuel verticals ───────────────────────────────
  MEDICAL_EQUIPMENT // DME / medical supply with serial tracking + rentals + repairs
  GAS_STATION // MSME independent gas station with manual-meter fuel POS
}

/// Sprint 19 — Philippine drug-classification taxonomy.
/// Drives the till workflow at sale (zero friction for OTC, PIN-attest for
/// Rx-only, PIN-attest + Yellow Rx for DDB Schedule II). The two derived
/// booleans on Product (isRxRequired, isControlledDrug) are auto-projected
/// from this enum by ProductsService — drugClass is the single source of truth.
enum DrugClass {
  // Tier 1 — non-prescription
  /// Over the counter (paracetamol, antacids, ORS) — tap and charge
  OTC
  /// Behind the counter — pharmacist counsel required, no Rx
  /// (Plan B emergency contraceptives, some pseudoephedrine cold meds)
  OTC_BTC

  // Tier 2 — Rx-only, non-controlled
  /// White prescription — most antibiotics, antihypertensives, antidiabetics
  RX_ONLY

  // Tier 3 — DDB controlled (RA 9165 — Comprehensive Dangerous Drugs Act)
  /// Schedule II — Yellow Rx + S2-licensed pharmacist
  /// (morphine, oxycodone, fentanyl, methadone, methylphenidate, ketamine)
  DDB_S2
  /// Schedule III — Regular Rx + DDB Register entry (codeine combinations, some barbiturates)
  DDB_S3
  /// Schedule IV — Regular Rx + DDB Register entry
  /// (diazepam/Valium, alprazolam/Xanax, lorazepam, zolpidem)
  DDB_S4
  /// Schedule V — Regular Rx + DDB Register entry
  /// (low-dose codeine cough syrups < 200mg/100mL)
  DDB_S5

  // Tier 4 — special handling, non-Rx
  /// Vaccines / biologicals — cold-chain + lot/expiry mandatory at sale
  /// (Hep B, Pneumococcal, COVID, insulin)
  VACCINE

  // Tier 5 — non-drugs sold in drugstores
  /// Glucometer, BP monitor, thermometer, pulse oximeter
  DEVICE
  /// Vitamins, probiotics, herbal products
  SUPPLEMENT
  /// Sunscreen, soaps, personal care
  COSMETIC
  /// First-aid, gauze, alcohol, miscellaneous
  OTHER
}

enum TenantStatus {
  ACTIVE
  GRACE
  SUSPENDED
}

enum SubscriptionTier {
  TIER_1
  TIER_2
  TIER_3
  TIER_4
  TIER_5
  TIER_6
}

/// Where a tenant originated from. Drives onboarding flow + future
/// freemium/Play-Store differentiation. Default WEB is the existing path.
enum SignupSource {
  WEB
  PLAYSTORE
  IMPORTED
}

/// AI add-on packages. Sold monthly to TIER_4+ (T1-T3 cannot buy — no JE write).
/// TIER_5 includes 200 prompts/mo without buying; addon stacks on top.
/// TIER_6 includes 500 prompts/mo without buying; addon stacks on top.
enum AiAddonType {
  STARTER_50 // 50 prompts/mo for ₱250
  STANDARD_200 // 200 prompts/mo for ₱600
  PRO_500 // 500 prompts/mo for ₱1,400
}

enum EmploymentType {
  REGULAR
  PROBATIONARY
  CONTRACTUAL
  PART_TIME
}

enum SalaryType {
  MONTHLY
  SEMI_MONTHLY
  DAILY
  HOURLY
}

/// Sprint 19 — Reason category for an employee separation. Drives HR
/// analytics (voluntary attrition rate) and downstream BIR forms (e.g.
/// Form 2316 must be issued within 30 days of any separation regardless
/// of cause).
enum SeparationType {
  RESIGNED // Voluntary — employee gave notice
  TERMINATED // Involuntary — for cause
  RETIRED // Reached retirement age / opted in
  END_OF_CONTRACT // Contractual / project-based ended
  ABANDONED // No-show / AWOL beyond company policy
  OTHER
}

enum InventoryMode {
  UNIT_BASED
  RECIPE_BASED
}

enum ValuationMethod {
  WAC
  FIFO
}

/// Cash-basis: recognize revenue/expense when cash moves.
/// Accrual: recognize when earned/incurred (standard for VAT-registered MSMEs).
enum AccountingMethod {
  CASH
  ACCRUAL
}

/// BSP-compliant payment rails. QR_PH (InstaPay national QR) and CARD
/// (Visa/MC/JCB via EDC terminal) are intentionally separate — they
/// settle through different rails, have different MDR, and reconcile
/// against different statements. Lumping them confuses MSME bookkeeping.
enum PaymentMethod {
  CASH
  GCASH_PERSONAL
  GCASH_BUSINESS
  MAYA_PERSONAL
  MAYA_BUSINESS
  QR_PH
  /// Visa / Mastercard / JCB / BancNet via EDC terminal (tap, dip, swipe).
  /// Distinct from QR_PH which settles through InstaPay.
  CARD
}

enum OrderStatus {
  OPEN
  /// Sprint 7 — payment received, items still in production at bar/kitchen.
  /// Transitions to COMPLETED automatically when KDS marks the last prep
  /// item as READY. Lead time KPI = readyAt - paidAt.
  PAID
  COMPLETED
  VOIDED
  RETURNED
}

/// BIR-required tax classification per line item.
/// Drives VAT computation and BIR form categorization.
///   VAT_12     → Standard rated; 12% VAT collected and remitted to BIR (Form 2550Q).
///   VAT_EXEMPT → Exempt by law (e.g., basic food staples, medicines); no VAT collected.
///   ZERO_RATED → Subject to VAT but at 0% (e.g., exports, PEZA locators); input VAT reclaimable.
enum TaxType {
  VAT_12
  VAT_EXEMPT
  ZERO_RATED
}

/// Controls how the invoice is settled at point-of-sale.
///   CASH_SALE → Payment received immediately (cash, e-wallet, QR Ph).
///   CHARGE    → On-account/credit; receivable pending (B2B, corporate accounts).
///               Phase 4: links to AR sub-ledger when built.
enum InvoiceType {
  CASH_SALE
  CHARGE
}

enum SettlementStatus {
  PENDING // transactions collected, not yet settled to bank
  SETTLED // bank receipt confirmed
  RECONCILED // matched to bank statement line
  DISPUTED // amount mismatch — under investigation
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

enum AccountingEventType {
  SALE
  COGS
  VOID
  RETURN
  EOD_SUMMARY
  INVENTORY_ADJUSTMENT
  SETTLEMENT
  // Sprint 10: project material issuance — Dr Project-WIP / Cr Inventory
  MATERIAL_ISSUANCE
  // Sprint 11: shift cash flow events
  /// Mid-shift cash drop / paid-out (cashier pays for supplies, petty expense
  /// from the till). DR Expense / CR Cash on Hand.
  PAID_OUT
  /// Cash variance recorded at shift close (declared cash != expected cash).
  /// Over: DR Cash / CR Cash Variance Income. Short: DR Cash Variance Expense / CR Cash.
  CASH_VARIANCE
  // ── Sprint 13 — Vertical-engine events ───────────────────────────────────
  /// Trucking: cash advance issued to driver at trip dispatch.
  /// DR 1034 Advances to Employees / CR 1010 Cash on Hand.
  TRIP_CASH_ADVANCE
  /// Trucking: trip liquidated — driver returns receipts; expense the
  /// receipts by category, settle the advance, carry overspend on 1034
  /// (left non-zero so the bookkeeper investigates).
  TRIP_LIQUIDATION
  /// Construction: progress billing issued — revenue fully recognized,
  /// retention split out as a long-term receivable (1037) so it doesn't
  /// pollute current-AR aging. DR 1030 AR (net) + DR 1037 Retention
  /// Receivable / CR 4010 Revenue / CR 2020 Output VAT.
  PROGRESS_BILLING
  /// Construction: retention released — moved into current AR for normal
  /// collection (default) or paid directly as cash. DR 1030 or 1010 / CR 1037.
  RETENTION_RELEASE
}

enum InventoryLogType {
  INITIAL
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  SALE_DEDUCTION
  VOID_REVERSAL
}

enum AccountingEventStatus {
  PENDING
  SYNCED
  FAILED
}

enum DiscountType {
  PROMO
  CASHIER_APPLIED
  MANAGER_OVERRIDE
  PWD
  SENIOR_CITIZEN
}

/// BIR registration / VAT status of the business.
/// Drives receipt title, TIN display, VAT math, and PWD discount engine.
/// VAT          = BIR-registered + VAT-registered → collects 12% VAT, issues VAT OR
/// NON_VAT      = BIR-registered but not VAT       → no VAT collected, issues Official Receipt
/// UNREGISTERED = no BIR registration              → issues Acknowledgement Receipt only
enum TaxStatus {
  VAT
  NON_VAT
  UNREGISTERED
}

/// Categorises audit log events for tax / price settings.
enum AuditAction {
  TAX_STATUS_CHANGED
  TIN_UPDATED
  PRICE_ADJUSTED
  DISCOUNT_APPLIED
  VOID_PROCESSED
  SETTING_CHANGED
  /// RBAC: owner overrode an SOD warning when assigning permissions.
  /// Stored with the rule id and the owner's reason in the `details` JSON.
  SOD_OVERRIDE_GRANTED
  /// RBAC: a staff member's role / persona / permissions were changed.
  PERMISSIONS_UPDATED
  /// Audit-D3-07 — sensitive accounting / payroll / export mutations.
  JOURNAL_POSTED
  JOURNAL_REVERSED
  YEAR_END_CLOSED
  PERIOD_REOPENED
  AP_BILL_POSTED
  AP_BILL_VOIDED
  AR_INVOICE_POSTED
  AR_INVOICE_VOIDED
  PAYSLIP_PUBLISHED
  SALARY_CHANGED
  USER_DEPROVISIONED
  DATA_EXPORTED
  /// Audit-D10-D — set by the bulk-export scheduler when a user exports >5
  /// reports inside a one-hour window (potential exfiltration signal).
  BULK_EXPORT_FLAGGED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalEntryStatus {
  DRAFT
  PENDING_APPROVAL // entry exceeds tenant.jeApprovalThreshold; awaiting sign-off
  POSTED
  VOIDED
}

/// Controls who is allowed to post to this account.
/// OPEN = manual JEs allowed; others = sub-ledger or system only.
enum PostingControl {
  OPEN // Accountant / Business Owner can post via manual JE
  AP_ONLY // Only AP module service may post (Phase 4)
  AR_ONLY // Only AR module service may post (Phase 5)
  SYSTEM_ONLY // Only the @Cron event processor may post (Sales, COGS, VAT)
}

/// Tracks which subsystem originated a journal entry.
enum JournalSource {
  MANUAL // posted by a human via the JE screen
  SYSTEM // posted by the accounting event queue (@Cron)
  AP // posted by the AP module (Phase 4)
  AR // posted by the AR module (Phase 5)
  PAYROLL // posted by the Payroll engine on PayRun lock (Sprint 19)
}

// ─── Super Admin ──────────────────────────────────────────────────────────────

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions SuperAdminSession[]

  @@map("super_admins")
}

model SuperAdminSession {
  id           String        @id @default(cuid())
  superAdminId String
  tokenHash    String        @unique
  deviceInfo   String?
  ipAddress    String?
  status       SessionStatus @default(ACTIVE)
  expiresAt    DateTime
  createdAt    DateTime      @default(now())

  superAdmin SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@map("super_admin_sessions")
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  businessType      BusinessType     @default(RETAIL)
  tin               String? // Legacy field; use tinNumber going forward
  /// BIR Tax Identification Number — format: 000-000-000-00000 (15 chars with dashes)
  tinNumber         String?
  /// Business name exactly as it appears on the BIR Certificate of Registration
  businessName      String?
  address           String?
  contactEmail      String?
  contactPhone      String?
  status            TenantStatus     @default(ACTIVE)
  tier              SubscriptionTier @default(TIER_1)
  expiresAt         DateTime?
  branchQuota       Int              @default(1)
  cashierSeatQuota  Int              @default(2)
  hasTimeMonitoring Boolean          @default(false)
  hasBirForms       Boolean          @default(false)
  // ── Plan & module entitlement (modular pricing, 2026-05-08) ────────────
  /// Authoritative plan code: STD_SOLO / STD_DUO / STD_TEAM / STD_BIZ /
  /// PAIR_T1 / PAIR_T2 / PAIR_T3 / SUITE_T1 / SUITE_T2 / SUITE_T3 / ENTERPRISE.
  /// Drives staffSeatQuota ceilings + module flags. `tier` (SubscriptionTier)
  /// is retained for backward compatibility but is advisory only.
  planCode          String           @default("SUITE_T2")
  /// Per-module entitlement. Defaults to true for backward compat — existing
  /// tenants get all 3 modules. New plan-aware signups set these per planCode.
  modulePos         Boolean          @default(true)
  moduleLedger      Boolean          @default(true)
  modulePayroll     Boolean          @default(true)
  /// Base staff seats included in planCode. PLAN_CAPS in shared-types is the
  /// single source of truth; this column mirrors it for fast quota checks.
  staffSeatQuota    Int              @default(15)
  /// Additional purchased seats above quota. Total cap = staffSeatQuota +
  /// staffSeatAddons must remain <= PLAN_CAPS[planCode].maxTotal.
  staffSeatAddons   Int              @default(0)
  /// Marks the public shared demo tenant. Receipts watermarked, settings
  /// locked, nightly cron resets data. Exactly one record should have this true.
  isDemoTenant      Boolean          @default(false)

  /// Sprint 19 — Customizable receipt template. All optional. When null,
  /// the existing baked-in copy is used. Owner edits these from
  /// Settings → Receipt template.
  /// Header note printed BELOW the business name (e.g. tagline / branch
  /// supplemental line). 2 lines max recommended.
  receiptHeaderNote String?
  /// Footer note printed at the bottom (Wi-Fi password, social media,
  /// "thank you" message). 3 lines max recommended.
  receiptFooterNote String?
  /// Optional logo URL printed at the top of the receipt. Should be a
  /// 1-bit PNG ideally; thermal printers don't render full color anyway.
  receiptLogoUrl    String?

  /// Sprint 19 — Self-service clock-in policy. When false (default), staff
  /// cannot clock in/out from their own Sync account; only the shared
  /// kiosk tablet works. Owner flips this on in Settings → Kiosk Terminals
  /// when they trust employees to track their own hours from a phone or
  /// personal device. The /payroll/clock/in and /clock/out endpoints
  /// reject with code SELF_CLOCK_DISABLED while this is false; kiosk
  /// punches always work either way.
  allowSelfClockIn Boolean @default(false)

  /// Sprint 19 — Returns / refunds policy. When true, only BUSINESS_OWNER
  /// (and SUPER_ADMIN) can void an order or refund a line; cashiers,
  /// sales leads, and branch managers are blocked even with supervisor
  /// PIN. Pharmacy tenants get this on by default (regulatory + audit
  /// pressure); other verticals default off. Owner toggles in Settings.
  returnsOwnerOnly Boolean @default(false)

  /// Sprint 19 — Ransomware kill switch. When true, ALL data-mutating
  /// endpoints for this tenant return 423 Locked. Use case: detect
  /// compromise (e.g. unusual destructive activity), flip flag, freeze
  /// further damage while you investigate. SUPER_ADMIN can flip on/off
  /// from Console; tenant operators see a banner and read-only UI.
  readOnlyMode             Boolean          @default(false)
  readOnlyReason           String?
  readOnlySetAt            DateTime?
  readOnlySetById          String?
  /// Where this tenant originated from. WEB = sales-led signup, PLAYSTORE =
  /// future freemium standalone POS app, IMPORTED = backfill / migration.
  signupSource             SignupSource     @default(WEB)
  /// One-time setup fee paid date. Metadata only — billing is out-of-band.
  /// Null = setup fee not yet paid (e.g. trial / launch member).
  setupFeePaidAt           DateTime?
  /// Active AI add-on package — null = no addon (uses tier-included quota only).
  /// SUPER_ADMIN assigns via PATCH /tenant/ai-addon. Renews monthly via the
  /// external billing flow; aiAddonExpiresAt drives the active/inactive check.
  aiAddonType              AiAddonType?
  /// When the active addon expires. After this date, addon contributes 0 to
  /// the monthly quota. Renewal pushes the date forward.
  aiAddonExpiresAt         DateTime?
  /// Monthly prompt quota override. Null = inherit (tier-included + addon).
  /// 0 = kill switch (force AI off entirely, regardless of addon).
  /// >0 = SUPER_ADMIN custom quota (sales perk, beta access, etc.).
  aiQuotaOverride          Int?
  /// Primary tax classification per BIR registration.
  /// Drives receipt type, VAT math, PWD discount engine, and journal entries.
  taxStatus                TaxStatus        @default(UNREGISTERED)
  /// Derived convenience flag — true when taxStatus = VAT.
  /// Kept for backward compatibility with existing JWT consumers.
  isBirRegistered          Boolean          @default(false)
  /// Derived convenience flag — true when taxStatus IN (VAT, NON_VAT).
  /// Kept for backward compatibility with existing JWT consumers.
  isVatRegistered          Boolean          @default(false)
  /// Accounting method: ACCRUAL (default, for registered MSMEs) or CASH (backyard)
  accountingMethod         AccountingMethod @default(ACCRUAL)
  /// BIR Permit to Use (PTU) — issued for CAS-accredited POS systems
  isPtuHolder              Boolean          @default(false)
  /// PTU number as printed on the BIR PTU certificate (e.g. "PTU-123456-2024")
  ptuNumber                String?
  /// Machine Identification Number (MIN) — BIR CAS accreditation identifier
  minNumber                String?
  /// FDA License to Operate number — required for MEDICAL_EQUIPMENT tenants
  /// selling Class A/B/C/D medical devices in the Philippines. Printed on
  /// every receipt header so the customer (and FDA auditors) can verify.
  fdaLicenseNumber         String?
  /// Registered address exactly as it appears on BIR Certificate of Registration
  registeredAddress        String?
  managerAccountingEnabled Boolean          @default(false)
  inventoryMode            InventoryMode    @default(UNIT_BASED)
  valuationMethod          ValuationMethod  @default(WAC)
  firstTransactionAt       DateTime?
  notes                    String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  branches                   Branch[]
  users                      User[]
  products                   Product[]
  categories                 Category[]
  orders                     Order[]
  shifts                     Shift[]
  accountingEvents           AccountingEvent[]
  accounts                   Account[]
  journalEntries             JournalEntry[]
  subscriptionLogs           SubscriptionLog[]
  discountTypes              DiscountTypeConfig[]
  promotions                 Promotion[]
  paymentConfigs             PaymentChannelConfig[]
  modifierGroups             ModifierGroup[]
  unitsOfMeasure             UnitOfMeasure[]
  settlementBatches          SettlementBatch[]
  accountingPeriods          AccountingPeriod[]
  auditLogs                  AuditLog[]
  zReadLogs                  ZReadLog[]
  xReadLogs                  XReadLog[]
  vendors                    Vendor[]
  expenses                   ExpenseEntry[]
  customers                  Customer[]
  preOrders                  PreOrder[]
  priceLists                 PriceList[]
  serializedUnits            SerializedUnit[]
  rentalAgreements           RentalAgreement[]
  repairTickets              RepairTicket[]
  fuelPumps                  FuelPump[]
  tankDips                   TankDip[]
  rawMaterials               RawMaterial[]
  payRuns                    PayRun[]
  payslips                   Payslip[]
  documents                  Document[]
  orSequence                 OrSequence?
  expenseClaims              ExpenseClaim[]
  expenseClaimSeq            ExpenseClaimSequence?
  arInvoices                 ARInvoice[]
  arPayments                 ARPayment[]
  quotes                     Quote[]
  apBills                    APBill[]
  apPayments                 APPayment[]
  // Sprint 22 — AR/AP standalone-accounting parity
  creditMemos                CreditMemo[]
  vendorCreditNotes          VendorCreditNote[]
  customerAdvances           CustomerAdvance[]
  vendorAdvances             VendorAdvance[]
