generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  BUSINESS_OWNER
  ACCOUNTANT
  BRANCH_MANAGER
  CASHIER
  GENERAL_EMPLOYEE
  EXTERNAL_AUDITOR
}

/// Which application the access entry refers to
enum AppCode {
  POS
  LEDGER
  PAYROLL
}

/// Ordered by privilege: NONE < CLOCK_ONLY < READ_ONLY < OPERATOR < FULL
enum AccessLevel {
  NONE
  CLOCK_ONLY
  READ_ONLY
  OPERATOR
  FULL
}

/// Used to pre-seed chart of accounts labels on tenant onboarding
enum BusinessType {
  COFFEE_SHOP
  RETAIL
  SERVICE
  MANUFACTURING
}

enum TenantStatus {
  ACTIVE
  GRACE
  SUSPENDED
}

enum SubscriptionTier {
  TIER_1
  TIER_2
  TIER_3
  TIER_4
  TIER_5
}

enum EmploymentType {
  REGULAR
  PROBATIONARY
  CONTRACTUAL
  PART_TIME
}

enum SalaryType {
  MONTHLY
  SEMI_MONTHLY
  DAILY
  HOURLY
}

enum InventoryMode {
  UNIT_BASED
  RECIPE_BASED
}

enum ValuationMethod {
  WAC
  FIFO
}

enum PaymentMethod {
  CASH
  GCASH_PERSONAL
  GCASH_BUSINESS
  MAYA_PERSONAL
  MAYA_BUSINESS
  QR_PH
}

enum OrderStatus {
  OPEN
  COMPLETED
  VOIDED
  RETURNED
}

enum AccountingEventType {
  SALE
  COGS
  VOID
  RETURN
  EOD_SUMMARY
  INVENTORY_ADJUSTMENT
  SETTLEMENT
}

enum InventoryLogType {
  INITIAL
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  SALE_DEDUCTION
  VOID_REVERSAL
}

enum AccountingEventStatus {
  PENDING
  SYNCED
  FAILED
}

enum DiscountType {
  PROMO
  CASHIER_APPLIED
  MANAGER_OVERRIDE
  PWD
  SENIOR_CITIZEN
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

// ─── Super Admin ──────────────────────────────────────────────────────────────

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     SuperAdminSession[]

  @@map("super_admins")
}

model SuperAdminSession {
  id           String   @id @default(cuid())
  superAdminId String
  tokenHash    String   @unique
  deviceInfo   String?
  ipAddress    String?
  status       SessionStatus @default(ACTIVE)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@map("super_admin_sessions")
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id                       String           @id @default(cuid())
  name                     String
  slug                     String           @unique
  businessType             BusinessType     @default(RETAIL)
  tin                      String?
  address                  String?
  contactEmail             String?
  contactPhone             String?
  status                   TenantStatus     @default(ACTIVE)
  tier                     SubscriptionTier @default(TIER_1)
  expiresAt                DateTime?
  branchQuota              Int              @default(1)
  cashierSeatQuota         Int              @default(2)
  hasTimeMonitoring        Boolean          @default(false)
  hasBirForms              Boolean          @default(false)
  managerAccountingEnabled Boolean          @default(false)
  inventoryMode            InventoryMode    @default(UNIT_BASED)
  valuationMethod          ValuationMethod  @default(WAC)
  firstTransactionAt       DateTime?
  notes                    String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  branches            Branch[]
  users               User[]
  products            Product[]
  categories          Category[]
  orders              Order[]
  accountingEvents    AccountingEvent[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  subscriptionLogs    SubscriptionLog[]
  discountTypes       DiscountTypeConfig[]
  promotions          Promotion[]
  paymentConfigs      PaymentChannelConfig[]

  @@map("tenants")
}

model SubscriptionLog {
  id          String   @id @default(cuid())
  tenantId    String
  action      String
  tierFrom    SubscriptionTier?
  tierTo      SubscriptionTier?
  expiresAt   DateTime?
  notes       String?
  performedBy String
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscription_logs")
}

// ─── Branch ───────────────────────────────────────────────────────────────────

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  inventory   InventoryItem[]
  orders      Order[]
  shifts      Shift[]

  @@map("branches")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                   String         @id @default(cuid())
  tenantId             String
  branchId             String?
  email                String
  passwordHash         String
  name                 String
  role                 UserRole
  employmentType       EmploymentType @default(REGULAR)
  salaryType           SalaryType?
  salaryRate           Decimal?       @db.Decimal(12, 2)
  shiftStart           String?
  shiftEnd             String?
  sssNumber            String?
  philhealthNumber     String?
  pagibigNumber        String?
  tin                  String?
  photo                String?
  kioskPin             String?
  isActive             Boolean        @default(true)
  hiredAt              DateTime?
  separatedAt          DateTime?
  enable2fa            Boolean        @default(false)
  twoFactorSecret      String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch?        @relation(fields: [branchId], references: [id])
  sessions             UserSession[]
  trustedDevices       TrustedDevice[]
  loginLogs            LoginLog[]
  appAccess            UserAppAccess[]
  ordersAsCreator      Order[]        @relation("CreatedByUser")
  ordersAsVoidedBy     Order[]        @relation("VoidedByUser")
  discountsAuthorized  OrderDiscount[] @relation("AuthorizedByUser")

  @@unique([tenantId, email])
  @@map("users")
}

/// Per-user, per-app access level.
/// Auto-seeded from DEFAULT_APP_ACCESS on user create; can be overridden by BUSINESS_OWNER.
model UserAppAccess {
  id      String      @id @default(cuid())
  userId  String
  appCode AppCode
  level   AccessLevel @default(NONE)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appCode])
  @@map("user_app_access")
}

model UserSession {
  id                String        @id @default(cuid())
  userId            String
  refreshTokenHash  String        @unique
  deviceInfo        String?
  deviceFingerprint String?
  ipAddress         String?
  status            SessionStatus @default(ACTIVE)
  expiresAt         DateTime
  createdAt         DateTime      @default(now())
  lastUsedAt        DateTime      @default(now())

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model TrustedDevice {
  id                String   @id @default(cuid())
  userId            String
  deviceFingerprint String
  deviceInfo        String?
  trustedAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@map("trusted_devices")
}

model LoginLog {
  id           String   @id @default(cuid())
  userId       String?
  tenantId     String?
  email        String
  success      Boolean
  reason       String?
  ipAddress    String?
  deviceInfo   String?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("login_logs")
}

// ─── Product Catalog ──────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("categories")
}

model Product {
  id             String        @id @default(cuid())
  tenantId       String
  categoryId     String?
  name           String
  description    String?
  sku            String?
  imageUrl       String?
  price          Decimal       @db.Decimal(12, 2)
  costPrice      Decimal?      @db.Decimal(12, 2)
  inventoryMode  InventoryMode @default(UNIT_BASED)
  isVatable      Boolean       @default(true)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       Category?     @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  inventory      InventoryItem[]
  inventoryLogs  InventoryLog[]
  bomItems       BomItem[]
  orderItems     OrderItem[]
  promotionItems PromotionProduct[]

  @@map("products")
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  name        String
  sku         String?
  price       Decimal?  @db.Decimal(12, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("product_variants")
}

// ─── Raw Materials & BOM ──────────────────────────────────────────────────────

model RawMaterial {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  unit        String
  costPrice   Decimal? @db.Decimal(12, 4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bomItems    BomItem[]
  inventory   RawMaterialInventory[]

  @@map("raw_materials")
}

model BomItem {
  id            String      @id @default(cuid())
  productId     String
  rawMaterialId String
  quantity      Decimal     @db.Decimal(12, 4)

  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)

  @@unique([productId, rawMaterialId])
  @@map("bom_items")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryItem {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String
  productId     String
  quantity      Decimal  @db.Decimal(12, 4)
  lowStockAlert Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
  @@map("inventory_items")
}

model RawMaterialInventory {
  id            String      @id @default(cuid())
  tenantId      String
  branchId      String
  rawMaterialId String
  quantity      Decimal     @db.Decimal(12, 4)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@unique([branchId, rawMaterialId])
  @@map("raw_material_inventory")
}

model InventoryLog {
  id             String           @id @default(cuid())
  tenantId       String
  branchId       String
  productId      String
  type           InventoryLogType
  quantity       Decimal          @db.Decimal(12, 4)
  quantityBefore Decimal          @db.Decimal(12, 4)
  quantityAfter  Decimal          @db.Decimal(12, 4)
  reason         String?
  note           String?
  referenceId    String?
  createdById    String?
  createdAt      DateTime         @default(now())

  product        Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId])
  @@index([productId])
  @@map("inventory_logs")
}

// ─── Promotions & Discount Types ──────────────────────────────────────────────

model Promotion {
  id               String    @id @default(cuid())
  tenantId         String
  name             String
  discountPercent  Decimal?  @db.Decimal(5, 2)
  fixedPrice       Decimal?  @db.Decimal(12, 2)
  appliesToAll     Boolean   @default(false)
  isStackable      Boolean   @default(false)
  startDate        DateTime?
  endDate          DateTime?
  activeDays       Int[]
  activeHoursStart String?
  activeHoursEnd   String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products         PromotionProduct[]

  @@map("promotions")
}

model PromotionProduct {
  promotionId String
  productId   String

  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@map("promotion_products")
}

model DiscountTypeConfig {
  id                   String   @id @default(cuid())
  tenantId             String
  name                 String
  defaultPercent       Decimal? @db.Decimal(5, 2)
  defaultFixed         Decimal? @db.Decimal(12, 2)
  requiresManagerAuth  Boolean  @default(false)
  appliesAtItemLevel   Boolean  @default(true)
  appliesAtOrderLevel  Boolean  @default(true)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("discount_type_configs")
}

// ─── Payment Channel Config ───────────────────────────────────────────────────

model PaymentChannelConfig {
  id          String        @id @default(cuid())
  tenantId    String
  method      PaymentMethod
  isEnabled   Boolean       @default(true)
  isBusiness  Boolean       @default(false)
  mdrRate     Decimal?      @db.Decimal(5, 4)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, method])
  @@map("payment_channel_configs")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id               String        @id @default(cuid())
  tenantId         String
  branchId         String
  shiftId          String?
  orderNumber      String
  status           OrderStatus   @default(OPEN)
  subtotal         Decimal       @db.Decimal(12, 2)
  discountAmount   Decimal       @db.Decimal(12, 2) @default(0)
  vatAmount        Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount      Decimal       @db.Decimal(12, 2)
  isPwdScDiscount  Boolean       @default(false)
  pwdScIdRef       String?
  pwdScIdOwnerName String?
  notes            String?
  clientUuid       String?       @unique
  createdById      String?
  voidedById       String?
  voidedAt         DateTime?
  voidReason       String?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch        @relation(fields: [branchId], references: [id])
  shift            Shift?        @relation(fields: [shiftId], references: [id])
  createdBy        User?         @relation("CreatedByUser", fields: [createdById], references: [id])
  voidedBy         User?         @relation("VoidedByUser", fields: [voidedById], references: [id])
  items            OrderItem[]
  payments         OrderPayment[]
  discounts        OrderDiscount[]
  accountingEvents AccountingEvent[]

  @@unique([tenantId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  productId      String
  variantId      String?
  productName    String
  unitPrice      Decimal         @db.Decimal(12, 2)
  quantity       Decimal         @db.Decimal(12, 4)
  discountAmount Decimal         @db.Decimal(12, 2) @default(0)
  vatAmount      Decimal         @db.Decimal(12, 2) @default(0)
  lineTotal      Decimal         @db.Decimal(12, 2)
  costPrice      Decimal?        @db.Decimal(12, 2)
  isVatable      Boolean         @default(true)
  notes          String?

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model OrderPayment {
  id        String        @id @default(cuid())
  orderId   String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  createdAt DateTime      @default(now())

  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_payments")
}

model OrderDiscount {
  id               String       @id @default(cuid())
  orderId          String
  discountType     DiscountType
  discountConfigId String?
  appliedBy        String?
  authorizedById   String?
  discountPercent  Decimal?     @db.Decimal(5, 2)
  discountFixed    Decimal?     @db.Decimal(12, 2)
  discountAmount   Decimal      @db.Decimal(12, 2)
  reason           String?
  createdAt        DateTime     @default(now())

  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorizedBy     User?        @relation("AuthorizedByUser", fields: [authorizedById], references: [id])

  @@map("order_discounts")
}

// ─── Shift / Cash Management ──────────────────────────────────────────────────

model Shift {
  id                  String    @id @default(cuid())
  tenantId            String
  branchId            String
  cashierId           String
  openingCash         Decimal   @db.Decimal(12, 2)
  closingCashDeclared Decimal?  @db.Decimal(12, 2)
  closingCashExpected Decimal?  @db.Decimal(12, 2)
  variance            Decimal?  @db.Decimal(12, 2)
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  notes               String?

  branch              Branch    @relation(fields: [branchId], references: [id])
  orders              Order[]

  @@map("shifts")
}

// ─── Accounting Events ────────────────────────────────────────────────────────

model AccountingEvent {
  id         String                @id @default(cuid())
  tenantId   String
  orderId    String?
  type       AccountingEventType
  status     AccountingEventStatus @default(PENDING)
  payload    Json
  retryCount Int                   @default(0)
  lastError  String?
  syncedAt   DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order        Order?              @relation(fields: [orderId], references: [id])
  journalEntry JournalEntry?

  @@index([tenantId, status])
  @@map("accounting_events")
}

// ─── Chart of Accounts ────────────────────────────────────────────────────────

model Account {
  id            String        @id @default(cuid())
  tenantId      String
  code          String
  name          String
  type          AccountType
  normalBalance NormalBalance
  isSystem      Boolean       @default(false)
  isActive      Boolean       @default(true)
  parentId      String?
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent        Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]     @relation("AccountHierarchy")
  journalLines  JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@map("accounts")
}

// ─── Journal Entries ──────────────────────────────────────────────────────────

model JournalEntry {
  id                String             @id @default(cuid())
  tenantId          String
  accountingEventId String?            @unique
  entryNumber       String
  date              DateTime
  description       String
  status            JournalEntryStatus @default(POSTED)
  createdBy         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountingEvent   AccountingEvent?   @relation(fields: [accountingEventId], references: [id])
  lines             JournalLine[]

  @@index([tenantId, date])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal      @default(0) @db.Decimal(14, 2)
  credit         Decimal      @default(0) @db.Decimal(14, 2)
  createdAt      DateTime     @default(now())

  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}
