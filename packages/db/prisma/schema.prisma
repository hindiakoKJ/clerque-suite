// ═══ Compliance-Engine (Pharmacy) ════════════════════════════════════════════

/// Prescription record (RA 6675, RA 9165, FDA). One row per Rx; multiple
/// dispenses against the same Rx tracked via `refillsRemaining` countdown.
/// Pharmacy POS rejects sale of `Product.isRxRequired` items without a
/// valid (refillsRemaining > 0) Prescription attached.
model Prescription {
  id                String   @id @default(cuid())
  tenantId          String
  customerId        String?
  /// Pharmacy-issued Rx number, scanned or typed at intake.
  rxNumber          String
  /// Patient's name as written on the Rx — required even when customerId is null.
  patientName       String
  patientIdType     String?
  patientIdNumber   String?
  /// Prescribing physician's name + PRC license + S2 license (for controlled drugs).
  prescribingDoctor String
  doctorPrcLicense  String
  doctorS2License   String?
  doctorClinic      String?
  issuedAt          DateTime
  refillsRemaining  Int      @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer                Customer?                @relation(fields: [customerId], references: [id])
  orderItems              OrderItem[]
  controlledSubstanceLogs ControlledSubstanceLog[]

  @@unique([tenantId, rxNumber])
  @@index([tenantId, customerId])
  @@map("prescriptions")
}

/// FDA-required lot + expiry tracking for pharmacy products.
model ProductLot {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  branchId    String
  lotNumber   String
  expiresAt   DateTime
  quantity    Decimal  @db.Decimal(12, 3)
  costPrice   Decimal  @db.Decimal(12, 2)
  receivedAt  DateTime @default(now())
  supplierRef String?
  isActive    Boolean  @default(true)

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product              Product               @relation(fields: [productId], references: [id])
  branch               Branch                @relation(fields: [branchId], references: [id])
  orderItems           OrderItem[]
  deliveryReceiptItems DeliveryReceiptItem[]

  @@unique([tenantId, productId, lotNumber])
  @@index([tenantId, productId, branchId, expiresAt])
  @@map("product_lots")
}

/// DDB controlled-substance dispensing register (RA 9165).
model ControlledSubstanceLog {
  id                String   @id @default(cuid())
  tenantId          String
  orderItemId       String   @unique
  prescriptionId    String?
  patientName       String
  patientIdType     String
  patientIdNumber   String
