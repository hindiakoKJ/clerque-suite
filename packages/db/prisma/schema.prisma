generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  // ── Administrative ──────────────────────────────────────────────────────────
  SUPER_ADMIN
  BUSINESS_OWNER       // Full access; the only role that can assign MDM / PAYROLL_MASTER

  // ── Operations ──────────────────────────────────────────────────────────────
  BRANCH_MANAGER       // Branch-level operations; subset of BUSINESS_OWNER rights

  // ── Sales & Revenue ─────────────────────────────────────────────────────────
  SALES_LEAD           // Sales + void/discount authority; supervises cashiers
  CASHIER              // Sales only; voids require SALES_LEAD / BUSINESS_OWNER co-auth
  AR_ACCOUNTANT        // Accounts Receivable / Collections (Phase 4 — AR module)

  // ── Expenditure & Inventory ──────────────────────────────────────────────────
  AP_ACCOUNTANT        // Accounts Payable / Supplier Bills (Phase 4 — AP module)
  MDM                  // Master Data Manager — products/prices/suppliers; assigned by OWNER only
  WAREHOUSE_STAFF      // Stock movement / inventory adjustments; no financial access

  // ── Finance & Compliance ─────────────────────────────────────────────────────
  FINANCE_LEAD         // Bank reconciliation / cash-flow reports; no payroll
  BOOKKEEPER           // Journal entries / GL; no payroll; no price edits
  PAYROLL_MASTER       // Salaries / payroll runs; exclusive salary column access
  ACCOUNTANT           // Legacy — full ledger read; no payroll
  GENERAL_EMPLOYEE     // Clock-in/out only
  EXTERNAL_AUDITOR     // Read-only compliance view; no writes anywhere
}

/// Which application the access entry refers to
enum AppCode {
  POS
  LEDGER
  PAYROLL
}

/// Ordered by privilege: NONE < CLOCK_ONLY < READ_ONLY < OPERATOR < FULL
enum AccessLevel {
  NONE
  CLOCK_ONLY
  READ_ONLY
  OPERATOR
  FULL
}

/// Used to pre-seed chart of accounts labels on tenant onboarding.
/// F&B group (any of these enables recipe/ingredient inventory):
///   COFFEE_SHOP, RESTAURANT, BAKERY, FOOD_STALL, BAR_LOUNGE, CATERING
/// Non-F&B group: RETAIL, SERVICE, MANUFACTURING
enum BusinessType {
  // ── Food & Beverage ──────────────────────────────────────────────────────
  COFFEE_SHOP    // Café, milk tea, coffee kiosk (legacy value — kept for backward compat)
  RESTAURANT     // Dine-in or takeout restaurant
  BAKERY         // Bakery, pastry shop, cake shop
  FOOD_STALL     // Carinderia, turo-turo, market stall
  BAR_LOUNGE     // Bar, lounge, nightspot with food/drinks
  CATERING       // Catering / events food service
  // ── Non-F&B ──────────────────────────────────────────────────────────────
  RETAIL         // Convenience store, boutique, product-based shop
  SERVICE        // Salon, clinic, laundry, repair, any service-based
  MANUFACTURING  // Fabrication, construction, BOM / bill-of-materials workflows
}

enum TenantStatus {
  ACTIVE
  GRACE
  SUSPENDED
}

enum SubscriptionTier {
  TIER_1
  TIER_2
  TIER_3
  TIER_4
  TIER_5
  TIER_6
}

/// Where a tenant originated from. Drives onboarding flow + future
/// freemium/Play-Store differentiation. Default WEB is the existing path.
enum SignupSource {
  WEB
  PLAYSTORE
  IMPORTED
}

/// AI add-on packages. Sold monthly to TIER_4+ (T1-T3 cannot buy — no JE write).
/// TIER_5 includes 200 prompts/mo without buying; addon stacks on top.
/// TIER_6 includes 500 prompts/mo without buying; addon stacks on top.
enum AiAddonType {
  STARTER_50    // 50 prompts/mo for ₱250
  STANDARD_200  // 200 prompts/mo for ₱600
  PRO_500       // 500 prompts/mo for ₱1,400
}

enum EmploymentType {
  REGULAR
  PROBATIONARY
  CONTRACTUAL
  PART_TIME
}

enum SalaryType {
  MONTHLY
  SEMI_MONTHLY
  DAILY
  HOURLY
}

enum InventoryMode {
  UNIT_BASED
  RECIPE_BASED
}

enum ValuationMethod {
  WAC
  FIFO
}

/// Cash-basis: recognize revenue/expense when cash moves.
/// Accrual: recognize when earned/incurred (standard for VAT-registered MSMEs).
enum AccountingMethod {
  CASH
  ACCRUAL
}

enum PaymentMethod {
  CASH
  GCASH_PERSONAL
  GCASH_BUSINESS
  MAYA_PERSONAL
  MAYA_BUSINESS
  QR_PH
}

enum OrderStatus {
  OPEN
  COMPLETED
  VOIDED
  RETURNED
}

/// BIR-required tax classification per line item.
/// Drives VAT computation and BIR form categorization.
///   VAT_12     → Standard rated; 12% VAT collected and remitted to BIR (Form 2550Q).
///   VAT_EXEMPT → Exempt by law (e.g., basic food staples, medicines); no VAT collected.
///   ZERO_RATED → Subject to VAT but at 0% (e.g., exports, PEZA locators); input VAT reclaimable.
enum TaxType {
  VAT_12
  VAT_EXEMPT
  ZERO_RATED
}

/// Controls how the invoice is settled at point-of-sale.
///   CASH_SALE → Payment received immediately (cash, e-wallet, QR Ph).
///   CHARGE    → On-account/credit; receivable pending (B2B, corporate accounts).
///               Phase 4: links to AR sub-ledger when built.
enum InvoiceType {
  CASH_SALE
  CHARGE
}

enum SettlementStatus {
  PENDING     // transactions collected, not yet settled to bank
  SETTLED     // bank receipt confirmed
  RECONCILED  // matched to bank statement line
  DISPUTED    // amount mismatch — under investigation
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

enum AccountingEventType {
  SALE
  COGS
  VOID
  RETURN
  EOD_SUMMARY
  INVENTORY_ADJUSTMENT
  SETTLEMENT
}

enum InventoryLogType {
  INITIAL
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  SALE_DEDUCTION
  VOID_REVERSAL
}

enum AccountingEventStatus {
  PENDING
  SYNCED
  FAILED
}

enum DiscountType {
  PROMO
  CASHIER_APPLIED
  MANAGER_OVERRIDE
  PWD
  SENIOR_CITIZEN
}

/// BIR registration / VAT status of the business.
/// Drives receipt title, TIN display, VAT math, and PWD discount engine.
/// VAT          = BIR-registered + VAT-registered → collects 12% VAT, issues VAT OR
/// NON_VAT      = BIR-registered but not VAT       → no VAT collected, issues Official Receipt
/// UNREGISTERED = no BIR registration              → issues Acknowledgement Receipt only
enum TaxStatus {
  VAT
  NON_VAT
  UNREGISTERED
}

/// Categorises audit log events for tax / price settings.
enum AuditAction {
  TAX_STATUS_CHANGED
  TIN_UPDATED
  PRICE_ADJUSTED
  DISCOUNT_APPLIED
  VOID_PROCESSED
  SETTING_CHANGED
  /// RBAC: owner overrode an SOD warning when assigning permissions.
  /// Stored with the rule id and the owner's reason in the `details` JSON.
  SOD_OVERRIDE_GRANTED
  /// RBAC: a staff member's role / persona / permissions were changed.
  PERMISSIONS_UPDATED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

/// Controls who is allowed to post to this account.
/// OPEN = manual JEs allowed; others = sub-ledger or system only.
enum PostingControl {
  OPEN        // Accountant / Business Owner can post via manual JE
  AP_ONLY     // Only AP module service may post (Phase 4)
  AR_ONLY     // Only AR module service may post (Phase 5)
  SYSTEM_ONLY // Only the @Cron event processor may post (Sales, COGS, VAT)
}

/// Tracks which subsystem originated a journal entry.
enum JournalSource {
  MANUAL  // posted by a human via the JE screen
  SYSTEM  // posted by the accounting event queue (@Cron)
  AP      // posted by the AP module (Phase 4)
  AR      // posted by the AR module (Phase 5)
}

// ─── Super Admin ──────────────────────────────────────────────────────────────

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     SuperAdminSession[]

  @@map("super_admins")
}

model SuperAdminSession {
  id           String   @id @default(cuid())
  superAdminId String
  tokenHash    String   @unique
  deviceInfo   String?
  ipAddress    String?
  status       SessionStatus @default(ACTIVE)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@map("super_admin_sessions")
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id                       String           @id @default(cuid())
  name                     String
  slug                     String           @unique
  businessType             BusinessType     @default(RETAIL)
  tin                      String?          // Legacy field; use tinNumber going forward
  /// BIR Tax Identification Number — format: 000-000-000-00000 (15 chars with dashes)
  tinNumber                String?
  /// Business name exactly as it appears on the BIR Certificate of Registration
  businessName             String?
  address                  String?
  contactEmail             String?
  contactPhone             String?
  status                   TenantStatus     @default(ACTIVE)
  tier                     SubscriptionTier @default(TIER_1)
  expiresAt                DateTime?
  branchQuota              Int              @default(1)
  cashierSeatQuota         Int              @default(2)
  hasTimeMonitoring        Boolean          @default(false)
  hasBirForms              Boolean          @default(false)
  /// Marks the public shared demo tenant. Receipts watermarked, settings
  /// locked, nightly cron resets data. Exactly one record should have this true.
  isDemoTenant             Boolean          @default(false)
  /// Where this tenant originated from. WEB = sales-led signup, PLAYSTORE =
  /// future freemium standalone POS app, IMPORTED = backfill / migration.
  signupSource             SignupSource     @default(WEB)
  /// One-time setup fee paid date. Metadata only — billing is out-of-band.
  /// Null = setup fee not yet paid (e.g. trial / launch member).
  setupFeePaidAt           DateTime?
  /// Active AI add-on package — null = no addon (uses tier-included quota only).
  /// SUPER_ADMIN assigns via PATCH /tenant/ai-addon. Renews monthly via the
  /// external billing flow; aiAddonExpiresAt drives the active/inactive check.
  aiAddonType              AiAddonType?
  /// When the active addon expires. After this date, addon contributes 0 to
  /// the monthly quota. Renewal pushes the date forward.
  aiAddonExpiresAt         DateTime?
  /// Monthly prompt quota override. Null = inherit (tier-included + addon).
  /// 0 = kill switch (force AI off entirely, regardless of addon).
  /// >0 = SUPER_ADMIN custom quota (sales perk, beta access, etc.).
  aiQuotaOverride          Int?
  /// Primary tax classification per BIR registration.
  /// Drives receipt type, VAT math, PWD discount engine, and journal entries.
  taxStatus                TaxStatus        @default(UNREGISTERED)
  /// Derived convenience flag — true when taxStatus = VAT.
  /// Kept for backward compatibility with existing JWT consumers.
  isBirRegistered          Boolean          @default(false)
  /// Derived convenience flag — true when taxStatus IN (VAT, NON_VAT).
  /// Kept for backward compatibility with existing JWT consumers.
  isVatRegistered          Boolean          @default(false)
  /// Accounting method: ACCRUAL (default, for registered MSMEs) or CASH (backyard)
  accountingMethod         AccountingMethod @default(ACCRUAL)
  /// BIR Permit to Use (PTU) — issued for CAS-accredited POS systems
  isPtuHolder              Boolean          @default(false)
  /// PTU number as printed on the BIR PTU certificate (e.g. "PTU-123456-2024")
  ptuNumber                String?
  /// Machine Identification Number (MIN) — BIR CAS accreditation identifier
  minNumber                String?
  /// Registered address exactly as it appears on BIR Certificate of Registration
  registeredAddress        String?
  managerAccountingEnabled Boolean          @default(false)
  inventoryMode            InventoryMode    @default(UNIT_BASED)
  valuationMethod          ValuationMethod  @default(WAC)
  firstTransactionAt       DateTime?
  notes                    String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  branches            Branch[]
  users               User[]
  products            Product[]
  categories          Category[]
  orders              Order[]
  shifts              Shift[]
  accountingEvents    AccountingEvent[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  subscriptionLogs    SubscriptionLog[]
  discountTypes       DiscountTypeConfig[]
  promotions          Promotion[]
  paymentConfigs      PaymentChannelConfig[]
  modifierGroups      ModifierGroup[]
  unitsOfMeasure      UnitOfMeasure[]
  settlementBatches   SettlementBatch[]
  accountingPeriods   AccountingPeriod[]
  auditLogs           AuditLog[]
  zReadLogs           ZReadLog[]
  xReadLogs           XReadLog[]
  vendors             Vendor[]
  expenses            ExpenseEntry[]
  customers           Customer[]
  rawMaterials        RawMaterial[]
  payRuns             PayRun[]
  payslips            Payslip[]
  documents           Document[]
  orSequence          OrSequence?
  expenseClaims       ExpenseClaim[]
  expenseClaimSeq     ExpenseClaimSequence?
  arInvoices          ARInvoice[]
  arPayments          ARPayment[]
  apBills             APBill[]
  apPayments          APPayment[]
  documentSequences   DocumentNumberSequence[]
  notifications       Notification[]
  bankReconciliations BankReconciliation[]

  @@map("tenants")
}

model SubscriptionLog {
  id          String   @id @default(cuid())
  tenantId    String
  action      String
  tierFrom    SubscriptionTier?
  tierTo      SubscriptionTier?
  expiresAt   DateTime?
  notes       String?
  performedBy String
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscription_logs")
}

/// Immutable audit trail for any change to tax settings or price adjustments.
/// Records are INSERT-only; never updated or deleted — required for BIR compliance.
model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String
  action      AuditAction
  /// The table / domain entity that was changed (e.g. "Tenant", "Order", "Product")
  entityType  String
  /// Primary key of the changed entity
  entityId    String
  /// Previous state as JSON snapshot
  before      Json?
  /// New state as JSON snapshot
  after       Json?
  /// Human-readable description of the change
  description String?
  /// User who triggered the change (null = system action)
  performedBy String?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, action])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ─── Branch ───────────────────────────────────────────────────────────────────

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  inventory   InventoryItem[]
  orders      Order[]
  shifts      Shift[]
  arInvoices  ARInvoice[]
  arPayments  ARPayment[]
  apBills     APBill[]
  apPayments  APPayment[]

  @@map("branches")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                   String         @id @default(cuid())
  tenantId             String
  branchId             String?
  email                String
  passwordHash         String
  name                 String
  role                 UserRole
  employmentType       EmploymentType @default(REGULAR)
  salaryType           SalaryType?
  salaryRate           Decimal?       @db.Decimal(12, 2)
  shiftStart           String?
  shiftEnd             String?
  sssNumber            String?
  philhealthNumber     String?
  pagibigNumber        String?
  tin                  String?
  photo                String?
  kioskPin             String?
  /// Mobile / contact number for HR records
  phone                String?
  /// Job title / position (e.g. "Barista", "Shift Supervisor")
  position             String?
  isActive             Boolean        @default(true)
  hiredAt              DateTime?
  separatedAt          DateTime?
  enable2fa                Boolean        @default(false)
  twoFactorSecret          String?
  /// Time-limited token for self-service password reset (expires in 1 hour)
  passwordResetToken       String?        @unique
  passwordResetTokenExpiry DateTime?
  /// Bcrypt-hashed 4-6 digit PIN for supervisor void overrides at the till.
  /// Only meaningful for users with VOID_DIRECT_ROLES (SALES_LEAD,
  /// BRANCH_MANAGER, BUSINESS_OWNER). Cashiers can have one set but it
  /// won't be accepted by /auth/verify-supervisor-pin.
  supervisorPinHash        String?
  /// RBAC: persona template the user was created from (e.g. "CASHIER_COOK").
  /// Reference into packages/shared-types/src/personas.ts; null for legacy users.
  personaKey               String?
  /// RBAC: extra permissions granted on top of the role + persona defaults.
  /// Members are PermissionKey strings (see permissions.ts). JWT-issue time
  /// merges these into the user's effective permission set.
  customPermissions        String[]       @default([])
  /// RBAC: SOD warning overrides. JSON shape:
  ///   { ruleId: string; reason: string; overriddenAt: ISO; overriddenById: cuid }[]
  /// Recorded when the owner explicitly accepts a yellow SOD warning.
  sodOverrides             Json?
  createdAt                DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch?        @relation(fields: [branchId], references: [id])
  sessions             UserSession[]
  trustedDevices       TrustedDevice[]
  loginLogs            LoginLog[]
  appAccess            UserAppAccess[]
  ordersAsCreator      Order[]        @relation("CreatedByUser")
  ordersAsUpdatedBy    Order[]        @relation("UpdatedByUser")
  ordersAsVoidedBy     Order[]        @relation("VoidedByUser")
  discountsAuthorized  OrderDiscount[] @relation("AuthorizedByUser")
  timeEntries          TimeEntry[]
  payslips             Payslip[]
  notifications        Notification[]
  bankReconciliations  BankReconciliation[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

/// Per-user, per-app access level.
/// Auto-seeded from DEFAULT_APP_ACCESS on user create; can be overridden by BUSINESS_OWNER.
model UserAppAccess {
  id      String      @id @default(cuid())
  userId  String
  appCode AppCode
  level   AccessLevel @default(NONE)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appCode])
  @@map("user_app_access")
}

model UserSession {
  id                String        @id @default(cuid())
  userId            String
  refreshTokenHash  String        @unique
  deviceInfo        String?
  deviceFingerprint String?
  ipAddress         String?
  status            SessionStatus @default(ACTIVE)
  expiresAt         DateTime
  createdAt         DateTime      @default(now())
  lastUsedAt        DateTime      @default(now())

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model TrustedDevice {
  id                String   @id @default(cuid())
  userId            String
  deviceFingerprint String
  deviceInfo        String?
  trustedAt         DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@map("trusted_devices")
}

model LoginLog {
  id           String   @id @default(cuid())
  userId       String?
  tenantId     String?
  email        String
  success      Boolean
  reason       String?
  ipAddress    String?
  deviceInfo   String?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@map("login_logs")
}

// ─── Product Catalog ──────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@index([tenantId, sortOrder])
  @@map("categories")
}

model Product {
  id             String        @id @default(cuid())
  tenantId       String
  categoryId     String?
  name           String
  description    String?
  /// Internal Stock-Keeping Unit — unique per tenant when set
  sku            String?
  /// Barcode (EAN-13, UPC-A, QR, etc.) — for scanner integration and BIR inventory audit
  barcode        String?
  imageUrl       String?
  price          Decimal       @db.Decimal(12, 2)
  costPrice      Decimal?      @db.Decimal(12, 2)
  inventoryMode  InventoryMode @default(UNIT_BASED)
  /// Whether this item carries 12% VAT. Drives taxType on OrderItem at checkout.
  isVatable      Boolean       @default(true)
  isActive       Boolean       @default(true)
  /// Unit of Measure for this product (PC, KG, BOX, LITER, etc.)
  unitOfMeasureId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       Category?     @relation(fields: [categoryId], references: [id])
  unitOfMeasure  UnitOfMeasure? @relation(fields: [unitOfMeasureId], references: [id])
  variants       ProductVariant[]
  inventory      InventoryItem[]
  inventoryLogs  InventoryLog[]
  bomItems       BomItem[]
  orderItems     OrderItem[]
  promotionItems PromotionProduct[]
  modifierGroups ProductModifierGroup[]

  @@index([tenantId, sku])
  @@index([tenantId, barcode])
  @@map("products")
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  name        String
  sku         String?
  price       Decimal?  @db.Decimal(12, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  variantBomItems VariantBomItem[]

  @@map("product_variants")
}

// ─── Raw Materials & BOM ──────────────────────────────────────────────────────

model RawMaterial {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  /// Unit of measure for this ingredient (g, ml, pc, kg, etc.)
  unit        String   @default("g")
  costPrice   Decimal? @db.Decimal(12, 4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bomItems         BomItem[]
  variantBomItems  VariantBomItem[]
  inventory        RawMaterialInventory[]

  @@index([tenantId, isActive])
  @@map("raw_materials")
}

/// Variant-level BOM — maps a specific product size/variant to ingredient quantities.
/// Example: ProductVariant "Large Iced Americano" → espresso beans 25g, water 180ml.
/// Overrides or supplements the product-level BomItem for that variant.
model VariantBomItem {
  id            String         @id @default(cuid())
  variantId     String
  rawMaterialId String
  /// How much of the raw material is consumed per unit of this variant
  quantity      Decimal        @db.Decimal(12, 4)

  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial    @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)

  @@unique([variantId, rawMaterialId])
  @@map("variant_bom_items")
}

model BomItem {
  id            String      @id @default(cuid())
  productId     String
  rawMaterialId String
  quantity      Decimal     @db.Decimal(12, 4)

  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)

  @@unique([productId, rawMaterialId])
  @@map("bom_items")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryItem {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String
  productId     String
  quantity      Decimal  @db.Decimal(12, 4)
  /// Moving-Average Cost (WAC). Recomputed on every positive-qty receipt
  /// when a unitCost is supplied. Drives COGS posting at sale time, replacing
  /// the older "snapshot of Product.costPrice" model. Null until the first
  /// costed receipt — sales fall back to product.costPrice in that case.
  avgCost       Decimal? @db.Decimal(12, 4)
  lowStockAlert Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
  @@map("inventory_items")
}

model RawMaterialInventory {
  id            String      @id @default(cuid())
  tenantId      String
  branchId      String
  rawMaterialId String
  quantity      Decimal     @db.Decimal(12, 4)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@unique([branchId, rawMaterialId])
  @@map("raw_material_inventory")
}

model InventoryLog {
  id             String           @id @default(cuid())
  tenantId       String
  branchId       String
  productId      String
  type           InventoryLogType
  quantity       Decimal          @db.Decimal(12, 4)
  quantityBefore Decimal          @db.Decimal(12, 4)
  quantityAfter  Decimal          @db.Decimal(12, 4)
  reason         String?
  note           String?
  referenceId    String?
  createdById    String?
  createdAt      DateTime         @default(now())

  product        Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId])
  @@index([productId])
  @@map("inventory_logs")
}

// ─── Promotions & Discount Types ──────────────────────────────────────────────

model Promotion {
  id               String    @id @default(cuid())
  tenantId         String
  name             String
  discountPercent  Decimal?  @db.Decimal(5, 2)
  fixedPrice       Decimal?  @db.Decimal(12, 2)
  appliesToAll     Boolean   @default(false)
  isStackable      Boolean   @default(false)
  startDate        DateTime?
  endDate          DateTime?
  activeDays       Int[]
  activeHoursStart String?
  activeHoursEnd   String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products         PromotionProduct[]

  @@index([tenantId, isActive])
  @@index([tenantId, isActive, startDate, endDate])   // promo rules engine: active + date-range filter
  @@map("promotions")
}

model PromotionProduct {
  promotionId String
  productId   String

  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@map("promotion_products")
}

model DiscountTypeConfig {
  id                   String   @id @default(cuid())
  tenantId             String
  name                 String
  defaultPercent       Decimal? @db.Decimal(5, 2)
  defaultFixed         Decimal? @db.Decimal(12, 2)
  requiresManagerAuth  Boolean  @default(false)
  appliesAtItemLevel   Boolean  @default(true)
  appliesAtOrderLevel  Boolean  @default(true)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("discount_type_configs")
}

// ─── Payment Channel Config ───────────────────────────────────────────────────

model PaymentChannelConfig {
  id          String        @id @default(cuid())
  tenantId    String
  method      PaymentMethod
  isEnabled   Boolean       @default(true)
  isBusiness  Boolean       @default(false)
  mdrRate     Decimal?      @db.Decimal(5, 4)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, method])
  @@map("payment_channel_configs")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id               String        @id @default(cuid())
  tenantId         String
  branchId         String
  shiftId          String?
  orderNumber      String
  status           OrderStatus   @default(OPEN)
  subtotal         Decimal       @db.Decimal(12, 2)
  discountAmount   Decimal       @db.Decimal(12, 2) @default(0)
  vatAmount        Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount      Decimal       @db.Decimal(12, 2)
  isPwdScDiscount  Boolean       @default(false)
  pwdScIdRef       String?
  pwdScIdOwnerName String?
  notes            String?
  clientUuid       String?       @unique

  // ── BIR CAS Audit: Invoice Classification ─────────────────────────────────
  /// How payment is settled at POS.
  /// CASH_SALE = paid immediately; CHARGE = on-account (B2B / corporate).
  invoiceType      InvoiceType   @default(CASH_SALE)
  /// Dominant tax classification for the order.
  /// Individual line items may override this with their own taxType.
  taxType          TaxType       @default(VAT_12)

  // ── BIR CAS Audit: B2B Customer Fields (AR) ───────────────────────────────
  // Required per RR No. 1-2026 for invoices issued to registered businesses.
  // Walk-in / anonymous retail sales leave all three null.
  /// FK to the Customer master (AR sub-ledger). Null for walk-in / anonymous sales.
  customerId       String?
  /// Business name of the corporate buyer (for B2B invoices)
  customerName     String?
  /// BIR TIN of the corporate buyer — required for valid input VAT claim (format: 000-000-000)
  customerTin      String?
  /// Registered address of the corporate buyer — required for invoices > ₱1,000
  customerAddress  String?
  /// Due date for credit (CHARGE) sales — set to createdAt + Customer.creditTermDays.
  /// Null for CASH_SALE. Drives AR aging buckets.
  dueDate          DateTime?

  // ── Audit Trail ────────────────────────────────────────────────────────────
  createdById      String?
  /// Last user to modify this record (role change, void, correction)
  updatedById      String?
  voidedById       String?    // The supervisor who authorized the void (SALES_LEAD / OWNER)
  voidInitiatedById String?   // The cashier who requested the void (null if supervisor voided directly)
  voidedAt         DateTime?
  voidReason       String?
  completedAt      DateTime?
  /// Soft-delete timestamp — set on void/correction; NULL means active.
  /// BIR requirement: invoice numbers must never have gaps; hard delete is forbidden.
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch        @relation(fields: [branchId], references: [id])
  shift            Shift?        @relation(fields: [shiftId], references: [id])
  customer         Customer?     @relation(fields: [customerId], references: [id])
  createdBy        User?         @relation("CreatedByUser", fields: [createdById], references: [id])
  updatedBy        User?         @relation("UpdatedByUser", fields: [updatedById], references: [id])
  voidedBy         User?         @relation("VoidedByUser", fields: [voidedById], references: [id])
  items            OrderItem[]
  payments         OrderPayment[]
  discounts        OrderDiscount[]
  accountingEvents AccountingEvent[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, createdAt])
  @@index([branchId, status])
  @@index([tenantId, deletedAt])   // soft-delete filter: WHERE deleted_at IS NULL
  @@index([branchId, deletedAt])   // branch-scoped active-order queries
  @@index([tenantId, customerId])  // AR: customer ledger queries
  @@index([tenantId, dueDate])     // AR aging: due-date range scans
  @@map("orders")
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  productId      String
  variantId      String?
  productName    String
  unitPrice      Decimal         @db.Decimal(12, 2)
  quantity       Decimal         @db.Decimal(12, 4)
  discountAmount Decimal         @db.Decimal(12, 2) @default(0)
  vatAmount      Decimal         @db.Decimal(12, 2) @default(0)
  lineTotal      Decimal         @db.Decimal(12, 2)
  costPrice      Decimal?        @db.Decimal(12, 2)
  isVatable      Boolean         @default(true)
  /// BIR per-line tax classification. Overrides the order-level taxType for this line.
  /// VAT_12 = standard 12%; VAT_EXEMPT = exempt by law; ZERO_RATED = 0% (exports/PEZA).
  taxType        TaxType         @default(VAT_12)
  notes          String?

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  modifiers      OrderItemModifier[]

  @@index([orderId])
  @@map("order_items")
}

model OrderPayment {
  id               String            @id @default(cuid())
  orderId          String
  method           PaymentMethod
  amount           Decimal           @db.Decimal(12, 2)
  reference        String?
  createdAt        DateTime          @default(now())

  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  settlementItem   SettlementItem?

  @@index([orderId])   // settlement unmatched-payment lookup
  @@map("order_payments")
}

model OrderDiscount {
  id               String       @id @default(cuid())
  orderId          String
  discountType     DiscountType
  discountConfigId String?
  appliedBy        String?
  authorizedById   String?
  discountPercent  Decimal?     @db.Decimal(5, 2)
  discountFixed    Decimal?     @db.Decimal(12, 2)
  discountAmount   Decimal      @db.Decimal(12, 2)
  reason           String?
  createdAt        DateTime     @default(now())

  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorizedBy     User?        @relation("AuthorizedByUser", fields: [authorizedById], references: [id])

  @@index([orderId])   // order detail fetch includes discounts
  @@map("order_discounts")
}

// ─── Shift / Cash Management ──────────────────────────────────────────────────

model Shift {
  id                  String    @id @default(cuid())
  tenantId            String
  branchId            String
  cashierId           String
  openingCash         Decimal   @db.Decimal(12, 2)
  closingCashDeclared Decimal?  @db.Decimal(12, 2)
  closingCashExpected Decimal?  @db.Decimal(12, 2)
  variance            Decimal?  @db.Decimal(12, 2)
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  notes               String?

  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch    @relation(fields: [branchId], references: [id])
  orders              Order[]
  cashOuts            ShiftCashOut[]

  @@index([tenantId, branchId])
  @@index([branchId, closedAt])   // getActive(): WHERE branchId = X AND closedAt IS NULL
  @@map("shifts")
}

/// AI usage telemetry — one row per LLM call. Drives per-tenant cost
/// tracking, monthly budget caps, and an audit trail of AI-assisted
/// actions (receipt OCR, JE drafter, time-anomaly resolver, etc.).
///
/// Cost is recorded at write-time based on the provider's published pricing;
/// we do NOT recompute or normalise across providers. If pricing changes,
/// historical rows keep their original cost.
model AiUsage {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?
  /// Stable action key, e.g. 'receipt_ocr' | 'je_drafter' | 'time_anomaly'.
  /// New actions can be added without a migration.
  action        String
  provider      String   @default("anthropic")
  model         String
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  costUsd       Decimal  @default(0) @db.Decimal(12, 6)
  success       Boolean  @default(true)
  errorMessage  String?
  durationMs    Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action, createdAt])
  @@map("ai_usage")
}

/// Cash leaving the till during a shift.
/// PAID_OUT  = real expense paid from cash drawer (parking tip, ice run,
///             COD delivery payment). Reduces expected cash AND posts a
///             journal entry (DR Expense / CR Cash on Hand).
/// CASH_DROP = mid-shift safekeeping — cashier hands cash to manager who
///             puts it in the safe. Reduces expected cash; offset to
///             "Cash on Safe" — no expense.
///
/// Both subtract from the close-shift expected-cash math, so variance
/// reconciles cleanly when legitimate cash leaves the till mid-shift.
enum CashOutType {
  PAID_OUT
  CASH_DROP
}

model ShiftCashOut {
  id              String       @id @default(cuid())
  tenantId        String
  branchId        String
  shiftId         String
  type            CashOutType
  amount          Decimal      @db.Decimal(12, 2)
  reason          String       // free-text, ≥10 chars validated at DTO
  category        String?      // 'supplies' | 'delivery' | 'fuel' | 'change_fund' | 'other' | etc.
  receiptPhotoUrl String?      // optional snap of the receipt; OCR-fillable
  /// User who recorded the cash-out (typically the cashier on shift)
  createdById     String
  /// Optional manager who approved an above-threshold paid-out (PIN co-auth)
  approvedById    String?
  /// AI-assisted flag — set when receipt OCR pre-filled the form
  aiAssisted      Boolean      @default(false)
  createdAt       DateTime     @default(now())

  shift           Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([tenantId, shiftId])
  @@index([branchId, createdAt])
  @@map("shift_cash_outs")
}

// ─── Accounting Events ────────────────────────────────────────────────────────

model AccountingEvent {
  id         String                @id @default(cuid())
  tenantId   String
  orderId    String?
  type       AccountingEventType
  status     AccountingEventStatus @default(PENDING)
  payload    Json
  retryCount Int                   @default(0)
  lastError  String?
  syncedAt   DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order        Order?              @relation(fields: [orderId], references: [id])
  journalEntry JournalEntry?

  @@index([tenantId, status])
  @@index([tenantId, status, createdAt])   // CRON processor: PENDING events ordered by age
  @@map("accounting_events")
}

// ─── Chart of Accounts ────────────────────────────────────────────────────────

model Account {
  id             String         @id @default(cuid())
  tenantId       String
  code           String
  name           String
  type           AccountType
  normalBalance  NormalBalance
  postingControl PostingControl @default(OPEN)
  isSystem       Boolean        @default(false)
  isActive       Boolean        @default(true)
  parentId       String?
  description    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent         Account?        @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]       @relation("AccountHierarchy")
  journalLines   JournalLine[]
  arInvoiceLines ARInvoiceLine[]
  apBillLines    APBillLine[]
  bankReconciliations BankReconciliation[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@map("accounts")
}

// ─── Journal Entries ──────────────────────────────────────────────────────────

model JournalEntry {
  id                String             @id @default(cuid())
  tenantId          String
  accountingEventId String?            @unique
  entryNumber       String
  /// Document Date — date the economic event occurred (source doc date)
  date              DateTime
  /// Posting Date — determines which accounting period the entry lands in.
  /// User-editable; must fall within an open period before posting.
  /// Defaults to the document date when not explicitly set.
  postingDate       DateTime?
  description       String
  /// Optional external reference: invoice #, OR #, voucher #, etc.
  reference         String?
  status            JournalEntryStatus @default(POSTED)
  source            JournalSource      @default(MANUAL)
  createdBy         String?
  postedBy          String?            // userId who approved DRAFT → POSTED
  postedAt          DateTime?
  /// Points to the JE this entry is reversing (set on the reversal JE)
  reversalOfId      String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountingEvent   AccountingEvent?   @relation(fields: [accountingEventId], references: [id])
  lines             JournalLine[]
  /// The original entry that this JE reverses
  reversalOf        JournalEntry?      @relation("JEReversals", fields: [reversalOfId], references: [id])
  /// The reversal entry created for this JE (if any)
  reversedBy        JournalEntry?      @relation("JEReversals")
  /// AR/AP back-references — at most one is non-null per JE (a JE is created
  /// by exactly one document type: invoice post, bill post, or payment).
  arInvoice         ARInvoice?         @relation("ARInvoiceJE")
  arPayment         ARPayment?         @relation("ARPaymentJE")
  apBill            APBill?            @relation("APBillJE")
  apPayment         APPayment?         @relation("APPaymentJE")

  @@index([tenantId, postingDate])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal      @default(0) @db.Decimal(14, 2)
  credit         Decimal      @default(0) @db.Decimal(14, 2)
  /// Transaction currency (future FX support). Always "PHP" until multi-currency is enabled.
  currency       String       @default("PHP")
  /// Exchange rate to PHP functional currency. Always 1 until FX engine is built.
  exchangeRate   Decimal      @default(1) @db.Decimal(12, 6)
  createdAt      DateTime     @default(now())

  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

// ─── Modifier Groups (F&B add-ons) ───────────────────────────────────────────

/// A named group of choices attached to a product (e.g. "Size", "Add-ons")
model ModifierGroup {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  required    Boolean  @default(false)
  multiSelect Boolean  @default(false)
  minSelect   Int      @default(0)
  maxSelect   Int?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  options     ModifierOption[]
  products    ProductModifierGroup[]

  @@index([tenantId])
  @@map("modifier_groups")
}

/// A single choice within a modifier group (e.g. "Large +₱20")
model ModifierOption {
  id              String   @id @default(cuid())
  modifierGroupId String
  name            String
  priceAdjustment Decimal  @default(0) @db.Decimal(12, 2)
  isDefault       Boolean  @default(false)
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  group         ModifierGroup       @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemMods OrderItemModifier[]

  @@index([modifierGroupId])
  @@map("modifier_options")
}

/// Junction: which modifier groups apply to a product
model ProductModifierGroup {
  productId       String
  modifierGroupId String
  sortOrder       Int    @default(0)

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([productId, modifierGroupId])
  @@map("product_modifier_groups")
}

/// Snapshot of the modifier chosen at sale time — never re-queried from option table
model OrderItemModifier {
  id               String   @id @default(cuid())
  orderItemId      String
  modifierGroupId  String
  modifierOptionId String
  groupName        String
  optionName       String
  priceAdjustment  Decimal  @db.Decimal(12, 2)

  orderItem      OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption ModifierOption @relation(fields: [modifierOptionId], references: [id])

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

// ─── Units of Measure ─────────────────────────────────────────────────────────

/// Configurable UoM per tenant — used by Retail / Construction product types
model UnitOfMeasure {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  abbreviation     String
  baseUnit         String?
  conversionFactor Decimal? @db.Decimal(12, 6)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, abbreviation])
  @@index([tenantId])
  @@map("units_of_measure")
}

// ─── Settlement Tracking ──────────────────────────────────────────────────────

/// A batch of digital payments (GCash/Maya/QR Ph) that settle together to the bank.
/// GCash and Maya collect money from customers on the merchant's behalf, then transfer
/// a lump sum to the merchant's bank account 1–3 business days later.
/// One SettlementBatch = one bank credit entry.
model SettlementBatch {
  id                String           @id @default(cuid())
  tenantId          String
  branchId          String
  method            PaymentMethod    // GCASH_BUSINESS, MAYA_BUSINESS, QR_PH, etc.
  referenceNumber   String?          // Gateway's own batch/settlement reference
  expectedAmount    Decimal          @db.Decimal(12, 2) // Sum of transactions in batch
  actualAmount      Decimal?         @db.Decimal(12, 2) // Amount that actually arrived in bank
  variance          Decimal?         @db.Decimal(12, 2) // actualAmount - expectedAmount
  periodStart       DateTime         // Earliest transaction date in this batch
  periodEnd         DateTime         // Latest transaction date in this batch
  settledAt         DateTime?        // When bank credit was received
  bankReference     String?          // Bank transaction reference / OR number
  status            SettlementStatus @default(PENDING)
  notes             String?
  reconciledById    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items             SettlementItem[]

  @@index([tenantId, status])
  @@index([tenantId, method, periodStart])
  @@map("settlement_batches")
}

/// Links one OrderPayment to a SettlementBatch — the line-item level.
/// One GCash payment from a customer = one SettlementItem inside a batch.
model SettlementItem {
  id                String          @id @default(cuid())
  settlementBatchId String
  orderPaymentId    String          @unique  // one payment can only be in one batch
  amount            Decimal         @db.Decimal(12, 2)
  transactionRef    String?         // Gateway transaction reference for this specific payment
  createdAt         DateTime        @default(now())

  batch             SettlementBatch @relation(fields: [settlementBatchId], references: [id], onDelete: Cascade)
  orderPayment      OrderPayment    @relation(fields: [orderPaymentId], references: [id])

  @@index([settlementBatchId])
  @@map("settlement_items")
}

// ─── Accounting Periods ───────────────────────────────────────────────────────

/// A closed period prevents any new journal entries from being posted to it.
/// Think of it like a locked accounting book for a given month.
///
/// Immutability rules (mirrors SAP period management / OB52):
///   - Closing a period writes closedById + closedAt (permanent facts, never nulled).
///   - Reopening a period writes reopenedById + reopenedAt + reopenReason and increments
///     reopenCount. The close metadata is preserved so auditors can see the full history.
///   - Both actions are mirrored to the AuditLog for BIR/CAS compliance.
///   - No postings (journal entries or order sync) can land in a CLOSED period.
model AccountingPeriod {
  id             String                 @id @default(cuid())
  tenantId       String
  name           String                 // e.g. "April 2026"
  startDate      DateTime
  endDate        DateTime
  status         AccountingPeriodStatus @default(OPEN)
  /// User who last closed this period. Never nulled on reopen — preserved as a historical fact.
  closedById     String?
  closedAt       DateTime?
  /// User who last reopened this period (null if never reopened).
  reopenedById   String?
  reopenedAt     DateTime?
  /// Mandatory justification written by the Business Owner when reopening.
  reopenReason   String?
  /// How many times this period has been reopened. BIR auditors flag counts > 0 for review.
  reopenCount    Int                    @default(0)
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, startDate])
  @@index([tenantId, status])
  @@map("accounting_periods")
}

// ─── Z-Read Log (INSERT-only — BIR CAS daily tamper-proof totals) ──────────────
// One record per branch per calendar date. Never updated after creation.
// Mirrors the physical Z-Reading printout required by BIR CAS accreditation.
model ZReadLog {
  id              String    @id @default(cuid())
  tenantId        String
  branchId        String
  /// Calendar date of the sales day (local PH time, stored as midnight UTC+8)
  date            DateTime  @db.Date
  /// Total completed (non-voided) orders for the day
  totalOrders     Int
  /// Total voided orders for the day
  voidCount       Int
  /// Gross sales before any discounts (sum of order.subtotal)
  grossSales      Decimal   @db.Decimal(15, 4)
  /// Net sales after all discounts (sum of order.totalAmount for completed orders)
  netSales        Decimal   @db.Decimal(15, 4)
  /// Total VAT collected (0 for UNREGISTERED and NON_VAT tenants)
  vatAmount       Decimal   @db.Decimal(15, 4)
  /// Total discount amount applied
  discountAmount  Decimal   @db.Decimal(15, 4)
  /// Cash payments total
  cashAmount      Decimal   @db.Decimal(15, 4)
  /// Non-cash (card, e-wallet, etc.) payments total
  nonCashAmount   Decimal   @db.Decimal(15, 4)
  /// Who triggered this Z-Read (system cron = null, manual = userId)
  generatedById   String?
  /// Insert timestamp — immutable anchor for audit
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One Z-Read per branch per day — uniqueness enforced at DB level
  @@unique([branchId, date])
  @@index([tenantId, date])
  @@map("z_read_logs")
}

// ─── X-Read Log (shift-level tamper-proof totals) ────────────────────────────
// One record per shift. Never updated after creation.
model XReadLog {
  id              String    @id @default(cuid())
  tenantId        String
  branchId        String
  shiftId         String    @unique
  /// Shift open timestamp
  openedAt        DateTime
  /// Shift close timestamp
  closedAt        DateTime
  totalOrders     Int
  voidCount       Int
  grossSales      Decimal   @db.Decimal(15, 4)
  netSales        Decimal   @db.Decimal(15, 4)
  vatAmount       Decimal   @db.Decimal(15, 4)
  discountAmount  Decimal   @db.Decimal(15, 4)
  cashAmount      Decimal   @db.Decimal(15, 4)
  nonCashAmount   Decimal   @db.Decimal(15, 4)
  openingCash     Decimal   @db.Decimal(15, 4)
  closingCash     Decimal   @db.Decimal(15, 4)
  cashVariance    Decimal   @db.Decimal(15, 4)
  generatedById   String?
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, closedAt])
  @@map("x_read_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 4 AP STUBS — Accounts Payable & Withholding Tax
//
// These models are schema-ready but have no API controllers yet.
// They exist to:
//   1. Pass BIR CAS audit (WHT records must be in the database)
//   2. Enable future Phase 4 AP module without a breaking migration
//
// BIR references:
//   ATC (Alphanumeric Tax Code) — Form 1601-EQ classification
//   WHT (Withholding Tax) — creditable withholding on vendor payments
// ─────────────────────────────────────────────────────────────────────────────

/// Master list of vendors/suppliers.
/// Required for BIR Form 1601-EQ (withholding tax return) and input VAT claims.
model Vendor {
  id              String    @id @default(cuid())
  tenantId        String
  /// Legal business name as registered with BIR
  name            String
  /// Vendor's BIR TIN — required for valid input VAT claim (format: 000-000-000-000)
  tin             String?
  /// Vendor's BIR-registered address — required for input VAT documentation
  address         String?
  contactEmail    String?
  contactPhone    String?
  /// Default ATC (Alphanumeric Tax Code) for withholding on payments to this vendor.
  /// Examples: WI160 = rentals (5%), WI010 = professional fees (10/15%), WI040 = services (2%)
  defaultAtcCode  String?
  /// Default WHT rate for this vendor (as decimal, e.g. 0.05 = 5%)
  defaultWhtRate  Decimal?  @db.Decimal(5, 4)
  isActive        Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expenses        ExpenseEntry[]
  bills           APBill[]
  payments        APPayment[]

  @@index([tenantId, tin])
  @@index([tenantId, isActive])
  @@map("vendors")
}

/// Expense / vendor bill — records AP transactions with withholding tax.
/// Connects to the GL via AccountingEvent → JournalEntry.
/// BIR CAS requirement: every outgoing payment with WHT must be traceable.
model ExpenseEntry {
  id              String    @id @default(cuid())
  tenantId        String
  branchId        String?
  vendorId        String?
  /// Human-readable description of the expense (e.g., "Office rental Q1 2026")
  description     String
  /// Date the expense was incurred (document date)
  expenseDate     DateTime
  /// Gross amount before withholding (the invoice face value)
  grossAmount     Decimal   @db.Decimal(14, 2)
  /// BIR Alphanumeric Tax Code — classifies the nature of the payment for 1601-EQ.
  /// Must match the ATC on the BIR withholding tax certificate (2307).
  atcCode         String?
  /// WHT rate applied (e.g., 0.05 = 5%). Pulled from Vendor.defaultWhtRate or manually set.
  whtRate         Decimal?  @db.Decimal(5, 4)
  /// Computed withholding tax amount (grossAmount × whtRate).
  /// This is the amount remitted to BIR — held back from the vendor payment.
  whtAmount       Decimal   @db.Decimal(14, 2) @default(0)
  /// Net amount actually paid to the vendor (grossAmount − whtAmount).
  netAmount       Decimal   @db.Decimal(14, 2)
  /// Input VAT on this purchase (for VAT-registered tenants claiming input tax).
  inputVat        Decimal   @db.Decimal(14, 2) @default(0)
  /// Reference document number (vendor invoice #, receipt #, OR #)
  referenceNumber String?
  /// When the vendor bill is due — drives AP aging buckets (0-30, 31-60, 61-90, 90+)
  dueDate         DateTime?
  /// When payment was actually remitted to the vendor
  paidAt          DateTime?
  /// Amount paid to vendor (= netAmount for full payment; < netAmount for partial)
  paidAmount      Decimal?  @db.Decimal(14, 2)
  /// Bank reference, check number, or e-wallet transaction ID for the payment
  paymentRef      String?
  status          ExpenseStatus @default(DRAFT)
  notes           String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor          Vendor?   @relation(fields: [vendorId], references: [id])

  @@index([tenantId, expenseDate])
  @@index([tenantId, status])
  @@index([vendorId])
  @@map("expense_entries")
}

enum ExpenseStatus {
  DRAFT     // Entered but not yet posted to ledger
  POSTED    // Journal entry created; locked from editing
  VOIDED    // Cancelled; WHT refund/credit memo may be required
}

// ─── AR — Customer Master ─────────────────────────────────────────────────────

/// Customer / corporate account for B2B credit sales (AR sub-ledger).
/// Walk-in / retail customers are anonymous — no Customer record needed.
model Customer {
  id              String    @id @default(cuid())
  tenantId        String
  /// Legal business name as registered with BIR
  name            String
  /// BIR TIN — required for valid B2B invoice per RR No. 1-2026
  tin             String?
  /// BIR-registered address — required for invoices above ₱1,000
  address         String?
  contactEmail    String?
  contactPhone    String?
  /// Payment term in calendar days. 0 = cash; 30 = Net 30; 60 = Net 60.
  creditTermDays  Int       @default(0)
  /// Maximum outstanding AR balance allowed. NULL = no limit.
  creditLimit     Decimal?  @db.Decimal(14, 2)
  notes           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders          Order[]
  invoices        ARInvoice[]
  payments        ARPayment[]

  @@index([tenantId, isActive])
  @@index([tenantId, tin])
  @@map("customers")
}

// ─── AR (Accounts Receivable) ────────────────────────────────────────────────
// Customer invoices + payments + matching. Drives FBL5N-style "show me all
// open items for customer X" queries. POS Orders with invoiceType=CHARGE
// continue to exist independently — ARInvoice is the formal back-office
// invoice document with proper status tracking.

enum InvoiceStatus {
  DRAFT          // not yet posted; no GL impact
  OPEN           // posted, no payments
  PARTIALLY_PAID // some payment applied, balance > 0
  PAID           // fully paid, balance = 0
  CANCELLED      // never posted, retained for audit
  VOIDED         // posted then reversed; reversal JE created
}

/// Customer invoice — the "you owe us" document.
/// On POST, creates a JE: DR AR Receivables, CR Revenue/Output VAT.
/// Status transitions: DRAFT → OPEN → PARTIALLY_PAID → PAID
///                     OPEN → CANCELLED (if never posted) or VOIDED (post then reverse).
model ARInvoice {
  id              String          @id @default(cuid())
  tenantId        String
  branchId        String?

  /// User-visible invoice number, tenant-scoped sequence.
  invoiceNumber   String
  /// Customer's PO# or our external reference.
  reference       String?

  customerId      String

  /// Document Date — when the sale happened.
  invoiceDate     DateTime
  /// Posting Date — drives accounting period.
  postingDate     DateTime
  /// Computed at create: invoiceDate + termsDays (or override).
  dueDate         DateTime
  /// Net days. 0 = cash; 30 = Net 30; copied from customer at create unless overridden.
  termsDays       Int             @default(0)

  subtotal        Decimal         @db.Decimal(14, 2)
  vatAmount       Decimal         @db.Decimal(14, 2) @default(0)
  totalAmount     Decimal         @db.Decimal(14, 2)
  /// Sum of applied payments. Updated on every ARPaymentApplication change.
  paidAmount      Decimal         @db.Decimal(14, 2) @default(0)
  /// Computed: totalAmount - paidAmount. Stored for query speed in aging reports.
  balanceAmount   Decimal         @db.Decimal(14, 2)

  status          InvoiceStatus   @default(DRAFT)

  description     String?
  notes           String?
  createdById     String
  postedById      String?
  postedAt        DateTime?
  voidedById      String?
  voidedAt        DateTime?
  voidReason      String?

  /// JE created on POST. Null while DRAFT.
  journalEntryId  String?         @unique

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?         @relation(fields: [branchId], references: [id])
  customer        Customer        @relation(fields: [customerId], references: [id])
  journalEntry    JournalEntry?   @relation("ARInvoiceJE", fields: [journalEntryId], references: [id])
  lines           ARInvoiceLine[]
  applications    ARPaymentApplication[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, customerId, status])
  @@index([tenantId, status, dueDate])         // FBL5N-style: open items past due
  @@index([tenantId, postingDate])
  @@map("ar_invoices")
}

model ARInvoiceLine {
  id             String      @id @default(cuid())
  invoiceId      String
  /// GL account to credit on POST (Revenue, Service Income, etc.).
  accountId      String
  description    String?
  quantity       Decimal     @db.Decimal(14, 4) @default(1)
  unitPrice      Decimal     @db.Decimal(14, 2)
  /// Per-line VAT amount (for invoices with mixed VATable/non-VATable).
  taxAmount      Decimal     @db.Decimal(14, 2) @default(0)
  lineTotal      Decimal     @db.Decimal(14, 2)
  createdAt      DateTime    @default(now())

  invoice        ARInvoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  account        Account     @relation(fields: [accountId], references: [id])

  @@index([invoiceId])
  @@map("ar_invoice_lines")
}

/// Customer payment received. May apply to one or many invoices via ARPaymentApplication.
/// Unapplied portion = unallocated credit (customer paid more than billed; sits as credit).
model ARPayment {
  id              String          @id @default(cuid())
  tenantId        String
  branchId        String?

  paymentNumber   String          // tenant-scoped sequence
  customerId      String
  paymentDate     DateTime
  postingDate     DateTime

  method          PaymentMethod   // CASH | GCASH_BUSINESS | etc. (reuses POS enum)
  reference       String?         // OR#, check#, GCash ref
  totalAmount     Decimal         @db.Decimal(14, 2)
  appliedAmount   Decimal         @db.Decimal(14, 2) @default(0)
  /// totalAmount - appliedAmount. Sits as customer credit when > 0.
  unappliedAmount Decimal         @db.Decimal(14, 2)

  description     String?
  notes           String?
  createdById     String
  voidedById      String?
  voidedAt        DateTime?
  voidReason      String?

  journalEntryId  String?         @unique

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?         @relation(fields: [branchId], references: [id])
  customer        Customer        @relation(fields: [customerId], references: [id])
  journalEntry    JournalEntry?   @relation("ARPaymentJE", fields: [journalEntryId], references: [id])
  applications    ARPaymentApplication[]

  @@unique([tenantId, paymentNumber])
  @@index([tenantId, customerId])
  @@index([tenantId, postingDate])
  @@map("ar_payments")
}

/// Junction: one payment can apply to N invoices, one invoice can receive N payments.
/// On insert/update/delete, recompute the invoice's paidAmount + status.
model ARPaymentApplication {
  id            String     @id @default(cuid())
  paymentId     String
  invoiceId     String
  appliedAmount Decimal    @db.Decimal(14, 2)
  appliedAt     DateTime   @default(now())

  payment       ARPayment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice       ARInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
  @@map("ar_payment_applications")
}

// ─── AP (Accounts Payable) — mirrors AR for vendor bills ─────────────────────

enum BillStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  CANCELLED
  VOIDED
}

/// Vendor bill — the "we owe them" document.
/// On POST, creates a JE: DR Expense/Asset, CR AP Payables (+ optional WHT split).
model APBill {
  id              String          @id @default(cuid())
  tenantId        String
  branchId        String?

  /// Our internal bill number, tenant-scoped sequence.
  billNumber      String
  /// Vendor's invoice number printed on their document we received.
  vendorBillRef   String?
  /// Our PO# or external reference.
  reference       String?

  vendorId        String

  billDate        DateTime
  postingDate     DateTime
  dueDate         DateTime
  termsDays       Int             @default(0)

  subtotal        Decimal         @db.Decimal(14, 2)
  vatAmount       Decimal         @db.Decimal(14, 2) @default(0)
  /// Withholding tax withheld on payment (PH-specific). Reduces the cash outflow.
  whtAmount       Decimal         @db.Decimal(14, 2) @default(0)
  whtAtcCode      String?         // ATC: WI160 (rentals 5%), WI010 (prof fees 10/15%), WI040 (services 2%)
  totalAmount     Decimal         @db.Decimal(14, 2)
  paidAmount      Decimal         @db.Decimal(14, 2) @default(0)
  balanceAmount   Decimal         @db.Decimal(14, 2)

  status          BillStatus      @default(DRAFT)

  description     String?
  notes           String?
  createdById     String
  postedById      String?
  postedAt        DateTime?
  voidedById      String?
  voidedAt        DateTime?
  voidReason      String?

  journalEntryId  String?         @unique

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?         @relation(fields: [branchId], references: [id])
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  journalEntry    JournalEntry?   @relation("APBillJE", fields: [journalEntryId], references: [id])
  lines           APBillLine[]
  applications    APPaymentApplication[]

  @@unique([tenantId, billNumber])
  @@index([tenantId, vendorId, status])
  @@index([tenantId, status, dueDate])         // FBL1N-style: open items past due
  @@index([tenantId, postingDate])
  @@map("ap_bills")
}

model APBillLine {
  id             String     @id @default(cuid())
  billId         String
  /// GL account to debit on POST (expense or asset).
  accountId      String
  description    String?
  quantity       Decimal    @db.Decimal(14, 4) @default(1)
  unitPrice      Decimal    @db.Decimal(14, 2)
  taxAmount      Decimal    @db.Decimal(14, 2) @default(0)
  lineTotal      Decimal    @db.Decimal(14, 2)
  createdAt      DateTime   @default(now())

  bill           APBill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  account        Account    @relation(fields: [accountId], references: [id])

  @@index([billId])
  @@map("ap_bill_lines")
}

model APPayment {
  id              String          @id @default(cuid())
  tenantId        String
  branchId        String?

  paymentNumber   String
  vendorId        String
  paymentDate     DateTime
  postingDate     DateTime

  method          PaymentMethod
  reference       String?
  totalAmount     Decimal         @db.Decimal(14, 2)
  appliedAmount   Decimal         @db.Decimal(14, 2) @default(0)
  unappliedAmount Decimal         @db.Decimal(14, 2)

  description     String?
  notes           String?
  createdById     String
  voidedById      String?
  voidedAt        DateTime?
  voidReason      String?

  journalEntryId  String?         @unique

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?         @relation(fields: [branchId], references: [id])
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  journalEntry    JournalEntry?   @relation("APPaymentJE", fields: [journalEntryId], references: [id])
  applications    APPaymentApplication[]

  @@unique([tenantId, paymentNumber])
  @@index([tenantId, vendorId])
  @@index([tenantId, postingDate])
  @@map("ap_payments")
}

model APPaymentApplication {
  id            String     @id @default(cuid())
  paymentId     String
  billId        String
  appliedAmount Decimal    @db.Decimal(14, 2)
  appliedAt     DateTime   @default(now())

  payment       APPayment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bill          APBill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@unique([paymentId, billId])
  @@index([billId])
  @@map("ap_payment_applications")
}

// ─── Document Number Sequences (per-tenant, per-type, optional per-branch) ───

enum SequenceType {
  AR_INVOICE
  AR_PAYMENT
  AP_BILL
  AP_PAYMENT
}

enum SequenceResetPolicy {
  NEVER
  YEARLY
  MONTHLY
}

/// Per-tenant document number generator. Atomic counter increment, optional
/// monthly/yearly reset. Format string supports {YYYY} {YY} {MM} {####} tokens.
/// Default format if null: prefix + zero-padded counter (padding chars).
model DocumentNumberSequence {
  id           String              @id @default(cuid())
  tenantId     String
  type         SequenceType
  /// Null = tenant-wide. Non-null = per-branch numbering (some tenants want
  /// distinct invoice ranges per location for BIR compliance).
  branchId     String?
  prefix       String              @default("")
  /// Optional formatter, e.g. "INV-{YYYY}-{####}" → "INV-2026-0001"
  /// {YYYY} = 4-digit year, {YY} = 2-digit year, {MM} = 2-digit month,
  /// {####} = zero-padded counter (digits = padding).
  format       String?
  padding      Int                 @default(4)
  counter      Int                 @default(0)
  /// Last reset date for monthly/yearly sequences. Used by NumberingService
  /// to decide whether the next call should reset the counter.
  lastResetAt  DateTime?
  resetPolicy  SequenceResetPolicy @default(NEVER)

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, branchId])
  @@map("document_number_sequences")
}

// ─── Payroll — Time Entries ──────────────────────────────────────────────────

/// Single clock-in / clock-out punch for an employee.
/// One OPEN entry per user at a time (enforced via unique partial index).
model TimeEntry {
  id         String          @id @default(cuid())
  tenantId   String
  userId     String
  clockIn    DateTime
  clockOut   DateTime?
  /// Break duration in minutes (deducted from gross hours)
  breakMins  Int             @default(0)
  status     TimeEntryStatus @default(OPEN)
  notes      String?
  /// Computed gross hours = (clockOut - clockIn) minus breakMins; null while OPEN
  grossHours Decimal?        @db.Decimal(6, 2)
  /// Overtime hours beyond 8h/day (PH Labor Code Art. 87)
  otHours    Decimal?        @db.Decimal(6, 2)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, clockIn])
  @@index([tenantId, userId, clockIn])
  @@index([userId, status])
  @@map("time_entries")
}

/// A payroll processing batch covering a specific period for all employees.
model PayRun {
  id            String       @id @default(cuid())
  tenantId      String
  label         String
  periodStart   DateTime
  periodEnd     DateTime
  frequency     PayFrequency @default(SEMI_MONTHLY)
  status        PayRunStatus @default(DRAFT)
  totalGross    Decimal      @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal    @default(0) @db.Decimal(14, 2)
  totalNet      Decimal      @default(0) @db.Decimal(14, 2)
  employeeCount Int          @default(0)
  processedAt   DateTime?
  processedById String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslips      Payslip[]

  @@index([tenantId, status])
  @@index([tenantId, periodStart])
  @@map("pay_runs")
}

/// Individual payslip generated for one employee within a PayRun.
model Payslip {
  id                String   @id @default(cuid())
  tenantId          String
  payRunId          String
  userId            String
  employeeName      String
  position          String?
  department        String?
  basicPay          Decimal  @db.Decimal(14, 2)
  overtimePay       Decimal  @default(0) @db.Decimal(14, 2)
  allowances        Decimal  @default(0) @db.Decimal(14, 2)
  grossPay          Decimal  @db.Decimal(14, 2)
  sssContrib        Decimal  @default(0) @db.Decimal(14, 2)
  philhealthContrib Decimal  @default(0) @db.Decimal(14, 2)
  pagibigContrib    Decimal  @default(0) @db.Decimal(14, 2)
  withholdingTax    Decimal  @default(0) @db.Decimal(14, 2)
  otherDeductions   Decimal  @default(0) @db.Decimal(14, 2)
  totalDeductions   Decimal  @db.Decimal(14, 2)
  netPay            Decimal  @db.Decimal(14, 2)
  regularHours      Decimal  @db.Decimal(8, 2)
  overtimeHours     Decimal  @default(0) @db.Decimal(8, 2)
  createdAt         DateTime @default(now())
  payRun            PayRun   @relation(fields: [payRunId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id])
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([payRunId])
  @@index([tenantId, userId])
  @@index([tenantId, payRunId])
  @@map("payslips")
}

/// Time-tracking punch status
enum TimeEntryStatus {
  OPEN      // Clocked in; no clock-out yet
  CLOSED    // Clock-out recorded; ready for payroll processing
  APPROVED  // Approved by manager / payroll master
  REJECTED  // Disputed entry; will not be paid
}

enum PayFrequency {
  WEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum PayRunStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

// ─── Phase 7 — Document Attachments ──────────────────────────────────────────

/// Generic document/attachment — links a file to any entity.
/// Stored on disk (uploads/ folder); DB tracks metadata only.
model Document {
  id           String   @id @default(cuid())
  tenantId     String
  /// Discriminator: "Order" | "ExpenseEntry" | "JournalEntry" | "ExpenseClaim"
  entityType   String
  entityId     String
  /// Original filename as uploaded by the user
  filename     String
  /// MIME type (e.g. "application/pdf", "image/jpeg", "image/png")
  mimeType     String
  /// File size in bytes
  sizeBytes    Int
  /// Path relative to the uploads root (e.g. "tenants/abc/documents/xyz.pdf")
  storagePath  String
  /// Human label, e.g. "Official Receipt", "Delivery Receipt", "Invoice"
  label        String?
  uploadedById String?
  createdAt    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("documents")
}

// ─── Phase 8 — OR Sequential Numbering ───────────────────────────────────────

/// Tracks the next Official Receipt / Sales Invoice sequence number per tenant.
/// BIR requires sequential, unbroken OR/SI numbering (RR No. 18-2012).
model OrSequence {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  /// Prefix printed before the number (e.g. "OR", "SI", "AR")
  prefix     String   @default("OR")
  /// Last sequence number issued. Next = lastNumber + 1.
  lastNumber Int      @default(0)
  /// Zero-pad length for the numeric portion (8 → "OR-00000001")
  padLength  Int      @default(8)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("or_sequences")
}

// ─── Phase 10 — Travel & Expense Claims ──────────────────────────────────────

enum ExpenseClaimStatus {
  DRAFT       // Employee filling in; not yet submitted
  SUBMITTED   // Submitted for manager approval
  APPROVED    // Manager approved; ready for payment
  REJECTED    // Manager rejected with reason
  PAID        // Reimbursed to employee
}

/// An employee expense claim (meals, transport, accommodation, supplies, etc.)
model ExpenseClaim {
  id            String             @id @default(cuid())
  tenantId      String
  branchId      String?
  /// Auto-generated number, e.g. "EC-2026-00001"
  claimNumber   String
  submittedById String
  title         String
  description   String?
  totalAmount   Decimal            @db.Decimal(14, 2)
  status        ExpenseClaimStatus @default(DRAFT)
  submittedAt   DateTime?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  paidAt        DateTime?
  paymentRef    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items         ExpenseClaimItem[]

  @@unique([tenantId, claimNumber])
  @@index([tenantId, status])
  @@index([tenantId, submittedById])
  @@map("expense_claims")
}

/// One line item within an expense claim.
model ExpenseClaimItem {
  id          String       @id @default(cuid())
  claimId     String
  /// Category: "Meals", "Transport", "Accommodation", "Supplies", "Communication", "Other"
  category    String
  description String
  amount      Decimal      @db.Decimal(14, 2)
  receiptDate DateTime
  /// Receipt / OR number from the vendor
  receiptRef  String?
  createdAt   DateTime     @default(now())

  claim       ExpenseClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("expense_claim_items")
}

/// Auto-incrementing claim sequence counter per tenant.
model ExpenseClaimSequence {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("expense_claim_sequences")
}

/// In-app notifications for users.
/// kind drives icon + colour; link is an optional in-app deep link
/// ("/ledger/events" etc.) that the bell-dropdown navigates to.
enum NotificationKind {
  INFO
  WARNING
  ERROR
  SUCCESS
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  /// Null = tenant-wide broadcast (every user sees it)
  userId    String?
  kind      NotificationKind @default(INFO)
  title     String
  body      String?
  /// Optional in-app route to navigate to on click
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId],   references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

/// Bank reconciliation — match a bank statement to GL cash account entries.
enum BankReconciliationStatus {
  IN_PROGRESS
  COMPLETED
}

model BankReconciliation {
  id             String                       @id @default(cuid())
  tenantId       String
  /// GL cash account being reconciled (1010, 1020, etc.)
  accountId      String
  /// Statement period
  periodStart    DateTime
  periodEnd      DateTime
  /// Closing balance per the bank statement (what the bank says)
  bankBalance    Decimal                      @db.Decimal(14, 2)
  /// Closing balance per the GL as of periodEnd (what our books say)
  glBalance      Decimal                      @db.Decimal(14, 2)
  /// Sum of matched amounts; books are reconciled when this == bankBalance + adjustments
  matchedAmount  Decimal                      @default(0) @db.Decimal(14, 2)
  /// Free-text reconciling adjustments (outstanding checks, deposits in transit, fees)
  notes          String?
  status         BankReconciliationStatus     @default(IN_PROGRESS)
  preparedById   String
  completedAt    DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  tenant         Tenant                       @relation(fields: [tenantId],     references: [id], onDelete: Cascade)
  account        Account                      @relation(fields: [accountId],    references: [id])
  preparedBy     User                         @relation(fields: [preparedById], references: [id])
  items          BankReconciliationItem[]

  @@index([tenantId, accountId, periodEnd])
  @@map("bank_reconciliations")
}

/// One line on a bank reconciliation — either a statement row, a JE line, or both (matched).
model BankReconciliationItem {
  id                String              @id @default(cuid())
  reconciliationId  String
  /// "STATEMENT" = bank statement line (usually unmatched at first)
  /// "JE_LINE"   = our journal line for the period
  /// "MATCHED"   = statement matched to one or more JE lines
  itemType          String
  /// Bank statement details (when itemType STATEMENT or MATCHED)
  statementDate     DateTime?
  statementDesc     String?
  statementAmount   Decimal?            @db.Decimal(14, 2)
  /// JE-line reference (when itemType JE_LINE or MATCHED)
  journalLineId     String?
  isMatched         Boolean             @default(false)
  notes             String?
  createdAt         DateTime            @default(now())

  reconciliation BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@index([reconciliationId, isMatched])
  @@map("bank_reconciliation_items")
}
