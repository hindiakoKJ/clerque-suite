  /// Sprint 19 — tenant frozen (read-only kill switch)
  TENANT_FROZEN
  /// Sprint 19 — tenant unfrozen
  TENANT_UNFROZEN
}

/// Immutable audit trail of every action taken in the Clerque Console.
/// Written by AdminService; never deleted; read by /admin/console-log.
model ConsoleLog {
  id              String        @id @default(cuid())
  /// Super-admin email — denormalised for audit readability even if the
  /// super-admin record is later removed.
  superAdminEmail String
  /// Affected tenant (null for platform-level actions).
  tenantId        String?
  tenantSlug      String?
  /// Affected user (null for tenant-only actions).
  userId          String?
  userEmail       String?
  action          ConsoleAction
  /// Extra context: old/new values, reason, notes.
  detail          Json?
  createdAt       DateTime      @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@map("console_logs")
}

// ─── Branch ───────────────────────────────────────────────────────────────────

model Branch {
