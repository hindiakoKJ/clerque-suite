// ─────────────────────────────────────────────────────────────────────────────
// Sprint 15 — Platform-level configuration (singleton)
//
// HNS Corp PH's master data — TIN, address, VAT/BIR status, OR series start.
// One row per environment (id = "platform"). Subscription billing reads this
// to issue acknowledgement receipts (UNREGISTERED) or BIR-compliant Sales
// Invoices/ORs (NON_VAT / VAT) to tenants.
//
// NOTE: replaces the brief Sprint 14 SubscriptionInvoice approach. Per the
// dogfood architecture, HNS Corp PH operates its own Clerque tenant — the
// actual subscription billing happens via Orders + AR in HNS's tenant, with
// a mirrored APBill auto-created in each customer-tenant's books. This
// PlatformConfig is just HNS's master data + per-environment toggles
// (auto-issue cron on/off, due-days window).
// ─────────────────────────────────────────────────────────────────────────────

model PlatformConfig {
  /// Always "platform" — singleton row.
  id                    String    @id @default("platform")
  /// HNS Corp PH legal name printed on receipts.
  companyName           String    @default("HNS Corp PH")
  /// HNS Corp PH TIN (BIR). Null while pre-registration; set once registered.
  tin                   String?
  /// Registered office address.
  address               String?
  /// Contact phone for tenant inquiries on the receipt footer.
  contactPhone          String?
  /// Contact email for tenant inquiries.
  contactEmail          String?
  /// HNS Corp PH's tax status. Drives whether subscription bills carry VAT.
  /// Mirrors TaxStatus enum for the HNS tenant; kept here for fast read
  /// without joining the HNS tenant row.
  taxStatus             TaxStatus @default(UNREGISTERED)
  /// True once BIR has issued ATP for Official Receipts. Drives "AR vs OR"
  /// receipt template selection.
  isBirRegistered       Boolean   @default(false)
  /// Auto-issuance cron toggle. False = no monthly invoices auto-created.
  subscriptionAutoIssue Boolean   @default(true)
  /// Days from issuance until invoice flips to PAST_DUE.
  subscriptionDueDays   Int       @default(7)
  /// Sprint 16 — when true, auto-post the customer-side APBill (DR 6280 +
  /// optional Input VAT 1040 / CR 2010 AP) immediately after the bill is
  /// created. When false (default), the bill lands in DRAFT for tenant
  /// review before they post it themselves.
  subscriptionAutoPost  Boolean   @default(false)
  /// HNS tenant link — null until bootstrap-hns-corp runs the first time.
  /// Subscription billing creates Orders inside this tenant.
  hnsTenantId           String?
  /// Sprint 24 — Payment methods JSON. Array of method objects shown to
  /// customers on the payment-instructions page during signup + monthly
  /// renewal. Shape:
  /// [{ type: 'MAYA' | 'BDO' | 'MARIBANK' | 'GCASH', label: string,
  ///    accountDisplay: string, instructions: string (markdown) }]
  /// Owner edits this via /admin/payment-methods.
  paymentMethodsJson    Json      @default("[]")
  /// Sprint 24 — Sequential BIR Official Receipt number tracking. Holds the
  /// LAST issued OR number from the owner's paper BIR-accredited booklet.
  /// Used by /admin/payments-pending to auto-suggest the next OR number
  /// when the owner confirms a payment. Format: numeric string e.g. "000123".
  /// BIR requires gap-free sequencing — the UI enforces this at OR-entry time.
  lastOrNumber          String?
  /// Sprint 24 — OR numbering padding width (e.g., 6 means "000123"). From
  /// the booklet's printed format. Defaults to 6 — typical BIR booklet.
  orNumberPadding       Int       @default(6)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("platform_config")
}

// ─── Sprint 24 — Subscription payment collection ─────────────────────────────
//
// Pre-PayMongo flow: customers pay manually via owner's personal Maya /
// BDO / Maribank account (or GCash when added). Owner verifies the deposit
// in their banking app, then issues a paper BIR Official Receipt from the
// accredited booklet and records the OR# here.
//
// Used by:
// - /signup wizard: creates a PendingPayment row at tenant-create time,
//   redirects customer to /pay/<referenceCode> instructions page
// - /pay/<referenceCode>: customer submits proof (transaction ID + screenshot)
// - /admin/payments-pending: owner verifies + issues OR
// - Daily cron: creates renewal PendingPayment rows 5 days before due
// - Daily cron: expires AWAITING_PROOF rows after 30 days

enum PendingPaymentStatus {
  AWAITING_PROOF // Customer hasn't submitted proof yet
  PROOF_SUBMITTED // Customer uploaded receipt; owner needs to verify
  CONFIRMED // Owner confirmed payment; OR issued; tenant active
  REJECTED // Owner rejected (wrong amount, no matching deposit, etc.)
  EXPIRED // Customer never paid; auto-expired after 30 days
}

enum PendingPaymentReason {
  NEW_SIGNUP // First-month subscription, tenant in GRACE until confirmed
  MONTHLY_RENEWAL // Recurring renewal — tenant ACTIVE; goes GRACE if not paid by due date
  PLAN_UPGRADE // Customer upgraded mid-cycle (prorated charge)
}

model PendingPayment {
  id       String @id @default(cuid())
  tenantId String

  // Plan + billing details
  planCode       String // SOLO_LITE / SOLO_STANDARD / SOLO_PRO
  amountPhpCents Int // ₱199.00 = 19900
  periodStart    DateTime
  periodEnd      DateTime
  reason         PendingPaymentReason

  // Reference code shown to customer — owner uses this to match the deposit
  // in their banking app. Format: SIGNUP-XXXXX or RENEW-XXXXX (6 chars).
  referenceCode String @unique

  // Customer-side: proof submission
  status            PendingPaymentStatus @default(AWAITING_PROOF)
  submittedAt       DateTime?
  submittedProofUrl String? // R2 URL of receipt screenshot
  submittedRefId    String? // Transaction ID / Maya ref / bank InstaPay ref
  submittedNotes    String? // Free-form notes from customer
  submittedMethod   String? // 'MAYA' | 'BDO' | 'MARIBANK' | 'GCASH'

  // Owner-side: verification
  confirmedAt     DateTime?
  confirmedById   String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?

  // BIR OR — linked on confirmation
  officialReceiptId String? @unique

  // Lifecycle
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officialReceipt OfficialReceipt? @relation(fields: [officialReceiptId], references: [id])

  @@index([status, expiresAt])
  @@index([tenantId, status])
  @@map("pending_payments")
}

// BIR Official Receipt — manual issuance from owner's paper booklet.
// Owner enters OR number when confirming a PendingPayment; system stores
// it for audit + customer download. Optional scanned-copy upload preserves
// the legal proof.
model OfficialReceipt {
  id String @id @default(cuid())

  // BIR-required fields
  orNumber   String   @unique // Gap-free per BIR rule. From owner's paper booklet.
  issuedAt   DateTime
  issuedById String // User who recorded the issuance

  // Payer (customer) details
  payerTenantId String?
  payerName     String // Business legal name on the receipt
  payerTin      String? // Customer's BIR TIN if they have one
  payerAddress  String?

  // Amounts
  amountPhpCents    Int // Gross amount received
  taxStatus         String // 'NON_VAT' or 'VAT_12' — copied from PlatformConfig at issuance time
  vatAmountPhpCents Int    @default(0) // 0 if Non-VAT; computed if VAT-registered

  // Description on the OR
  description String // e.g., "Clerque Solo Standard subscription, Aug 2026"

  // Optional scan
  scannedCopyUrl String? // R2 URL of photo/scan of the paper OR

  createdAt DateTime @default(now())

  payerTenant    Tenant?         @relation(fields: [payerTenantId], references: [id])
  pendingPayment PendingPayment?

  @@index([orNumber])
  @@index([issuedAt])
  @@index([payerTenantId])
  @@map("official_receipts")
}

// ─── Sprint 25 — Solo tier delivery (batch inventory, PO, maker-checker, API) ─

enum PurchaseOrderStatus {
  DRAFT
  ORDERED // Sent to vendor
  PARTIAL // Some items received
  RECEIVED // All items received
  CANCELLED
}

/// Sprint 25 — Purchase order workflow (Solo Pro feature).
/// Owner drafts a PO → marks ordered → records receipts (which create lots).
model PurchaseOrder {
  id            String              @id @default(cuid())
  tenantId      String
  branchId      String?
  vendorId      String?
  /// Tenant-scoped human-readable number, e.g. PO-2026-000123.
  poNumber      String
  orderDate     DateTime
  expectedAt    DateTime?
  status        PurchaseOrderStatus @default(DRAFT)
  subtotalCents Int                 @default(0)
  taxCents      Int                 @default(0)
  totalCents    Int                 @default(0)
  notes         String?
  createdById   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch?             @relation(fields: [branchId], references: [id])
  vendor Vendor?             @relation(fields: [vendorId], references: [id])
  items  PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
  @@index([tenantId, orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  /// One of rawMaterialId or productId is set (XOR).
  rawMaterialId   String?
  productId       String?
  description     String
  qtyOrdered      Decimal @db.Decimal(12, 4)
  qtyReceived     Decimal @default(0) @db.Decimal(12, 4)
  unitCost        Decimal @db.Decimal(12, 4)
  lineTotalCents  Int

  purchaseOrder   PurchaseOrder    @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  rawMaterialLots RawMaterialLot[]
  inventoryLots   InventoryLot[]

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

/// Sprint 25 — Read-only API key for Solo Pro tier (PLAN_FEATURES.apiAccess).
/// Owner generates from /admin/api-keys; key prefix stored for display, rest
/// hashed. Used by accountants integrating with Xero/QB/etc.
model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  /// User-given label, e.g. "Maria's bookkeeper".
  label       String
  /// First 8 chars of the key, shown in the UI (e.g. "ck_live_abcd1234...").
  keyPrefix   String
  /// SHA-256 hash of the full key; full key shown to user once at creation.
  keyHash     String    @unique
  /// 'read' for Solo Pro. 'readwrite' for SUITE_T3/ENTERPRISE.
  accessLevel String
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("api_keys")
}

enum VoidApprovalStatus {
  PENDING // Cashier requested; awaiting Sales Lead / Owner
  APPROVED
  REJECTED
}

/// Sprint 25 — Maker-checker void/refund audit (Solo Pro: makerCheckerVoids).
/// When tenant.voidApprovalThresholdCents > 0 AND void amount >= threshold,
/// the cashier-initiated void creates a VoidApproval row. Only Sales Lead /
/// Owner can approve; void doesn't go through until approved.
model VoidApproval {
  id              String             @id @default(cuid())
  tenantId        String
  orderId         String
  orderItemId     String? // Null for whole-order void
  amountCents     Int
  reason          String
  initiatedById   String // Cashier
  initiatedAt     DateTime           @default(now())
  status          VoidApprovalStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, initiatedAt])
  @@index([orderId])
  @@map("void_approvals")
}

/// Sprint 25 — Device pairing for customer-display + KDS screens.
/// A cashier-side device generates a short-lived 4-digit code, the secondary
/// device (TV / second tablet / Chromecast'd phone) redeems the code, and we
/// hand back a long-lived device token. The token lets the secondary device
/// subscribe to the cashier's display stream without ever logging in.
///
/// One device token per (tenantId, role, label). Owners can revoke from
/// Settings → Displays.
enum DisplayDeviceRole {
  CUSTOMER_DISPLAY // Customer-facing screen (cart mirror, branded QR)
  KDS_KITCHEN // Kitchen display
  KDS_BAR // Bar display
  KDS_COLD_BAR
  KDS_HOT_BAR
  KDS_PASTRY_PASS
  KDS_GENERIC
}

model DisplayPairing {
  id          String            @id @default(cuid())
  tenantId    String
  /// 4-digit numeric code. Single-use, expires after 15 min.
  code        String
  /// Which cashier user generated the code — the redeemed token follows
  /// this user's display stream.
  createdById String
  /// Optional: pin to a specific KDS station. Only relevant when
  /// role is KDS_*.
  stationId   String?
  role        DisplayDeviceRole
  /// Friendly label shown in the cashier's Settings → Displays list
  /// once the device redeems the code.
  label       String?
  expiresAt   DateTime
  /// Set when a device successfully redeems the code. After redemption,
  /// the code is dead and the device uses `deviceToken` for every
  /// subsequent request.
  redeemedAt  DateTime?
  deviceToken String?           @unique
  /// Updated on each poll from the paired device — lets the owner see
  /// "last seen 3 min ago" in Settings → Displays.
  lastSeenAt  DateTime?
  /// Soft-revoke. The token stays in the DB for audit but stops working.
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, role, redeemedAt])
  @@index([deviceToken])
  @@map("display_pairings")
}

// ─── Pre-orders (Bakery custom cakes + advance reservations) ──────────────────

/// Lifecycle of a customer pre-order. Drives both the kitchen workflow and
/// the accounting flow — deposits are recognised as a liability until pickup.
///
///   DRAFT         — captured but customer hasn't paid yet (rare; usually
///                   we book the deposit straight away)
///   DEPOSIT_PAID  — deposit recorded as an Order with kind=DEPOSIT; balance
///                   still due on pickup
///   READY         — kitchen has finished production; cashier can settle
///   PICKED_UP     — customer received the goods; balance Order rung
///   CANCELLED     — refund deposit if any; do not reuse the receipt #
enum PreOrderStatus {
  DRAFT
  DEPOSIT_PAID
  READY
  PICKED_UP
  CANCELLED
}

/// A reservation for a future-dated sale. Built for bakery custom cakes but
/// reusable for any vertical that takes a deposit and settles later (e.g.
/// catering, made-to-order furniture, special orders).
model PreOrder {
  id                 String         @id @default(cuid())
  tenantId           String
  branchId           String
  customerId         String?
  /// Cashier or sales person who took the order. Stamps audit attribution.
  createdById        String
  /// Server-generated short code shown to the customer ("PO-000123"). The
  /// receipt prints this so a walk-in cashier can find the order on pickup.
  preOrderNumber     String
  status             PreOrderStatus @default(DRAFT)
  /// When the customer expects to pick up / take delivery. Counter dashboard
  /// surfaces "today's pickups"; production-plan job uses this for tomorrow's
  /// bake list.
  pickupDate         DateTime
  /// Optional time-of-day within the pickup date. NULL = anytime.
  pickupTime         String?        @db.VarChar(8) // "HH:MM" / "HH:MM:SS"
  /// Free-text inscription (cake message). Printed on the production slip.
  inscription        String?
  /// Anything else the kitchen needs (allergies, colour, theme).
  notes              String?
  /// ₱ cents — totals are snapshotted at order time so price changes after
  /// don't quietly affect the balance owed.
  subtotalCents      Int            @default(0)
  discountCents      Int            @default(0)
  totalCents         Int            @default(0)
  depositCents       Int            @default(0)
  /// Computed as totalCents − depositCents at write time. Kept here so the
  /// settle-balance flow can read it without recomputing the snapshot.
  balanceCents       Int            @default(0)
  /// Backlinks to the Order rows representing actual cash movement.
  /// depositOrderId is set when DEPOSIT_PAID; balanceOrderId when PICKED_UP.
  depositOrderId     String?        @unique
  balanceOrderId     String?        @unique
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch    @relation(fields: [branchId], references: [id])
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy    User      @relation(fields: [createdById], references: [id])
  depositOrder Order?    @relation("PreOrderDeposit", fields: [depositOrderId], references: [id])
  balanceOrder Order?    @relation("PreOrderBalance", fields: [balanceOrderId], references: [id])

  items PreOrderItem[]

  @@unique([tenantId, preOrderNumber])
  @@index([tenantId, branchId, pickupDate])
  @@index([tenantId, status, pickupDate])
  @@index([customerId])
  @@map("pre_orders")
}

/// Line item on a pre-order. Mirrors OrderItem shape so the settle-balance
/// flow can copy these straight onto the final Order with minimal mapping.
model PreOrderItem {
  id               String  @id @default(cuid())
  preOrderId       String
  productId        String
  productName      String /// Snapshot — survives product rename
  quantity         Decimal @db.Decimal(12, 3)
  unitPriceCents   Int
  /// Sum of modifier priceAdjustment × qty. Pre-computed for fast totals.
  modifierAddCents Int     @default(0)
  lineTotalCents   Int
  notes            String?

  preOrder  PreOrder               @relation(fields: [preOrderId], references: [id], onDelete: Cascade)
  product   Product                @relation(fields: [productId], references: [id])
  modifiers PreOrderItemModifier[]

  @@index([preOrderId])
  @@map("pre_order_items")
}

/// Snapshot of a modifier choice on a pre-order line. Same shape as
/// OrderItemModifier so copy-on-settle is a 1:1 map.
model PreOrderItemModifier {
  id               String  @id @default(cuid())
  preOrderItemId   String
  modifierGroupId  String
  modifierOptionId String
  groupName        String
  optionName       String
  priceAdjustment  Decimal @db.Decimal(12, 2)

  preOrderItem PreOrderItem @relation(fields: [preOrderItemId], references: [id], onDelete: Cascade)

  @@index([preOrderItemId])
  @@map("pre_order_item_modifiers")
}

// ─── Medical Equipment (DME) — Serial tracking + Rentals + Repairs ──────────

/// A specific physical unit of a serialized SKU. Wheelchairs, CPAP machines,
/// hospital beds — anything where the buyer / renter cares which exact one
/// they got, and the shop has to track it back through repairs + returns.
///
/// One Product (e.g. "Standard Folding Wheelchair") can have many
/// SerializedUnit rows; each unit has its own lifecycle:
///   IN_STOCK → SOLD | ON_RENT → (returned) → IN_STOCK
///                              → IN_REPAIR → IN_STOCK
///   RETIRED (lost / destroyed)
enum SerializedUnitStatus {
  IN_STOCK
  SOLD
  ON_RENT
  IN_REPAIR
  RETIRED
}

model SerializedUnit {
  id              String               @id @default(cuid())
  tenantId        String
  branchId        String
  productId       String
  serialNumber    String /// Manufacturer or vendor-stamped serial
  status          SerializedUnitStatus @default(IN_STOCK)
  /// Acquisition cost — used for COGS when sold (overrides Product.costPrice).
  acquiredAt      DateTime             @default(now())
  acquiredCost    Decimal?             @db.Decimal(14, 2)
  /// Free-text condition notes (scratches, missing battery, etc.)
  conditionNotes  String?
  /// Set when the unit is sold (links to the Order line that sold it).
  soldOrderId     String?
  /// Set when the unit is currently out on rental.
  currentRentalId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rentals RentalAgreement[]
  repairs RepairTicket[]

  @@unique([tenantId, serialNumber])
  @@index([tenantId, productId, status])
  @@index([branchId, status])
  @@map("serialized_units")
}

/// Rental / lease agreement. Used for DME wheelchair-for-30-days style.
///   OPEN     — unit checked out, return date in the future
///   RETURNED — unit returned (status flipped back to IN_STOCK)
///   OVERDUE  — return date passed, no return yet (cron flips daily)
///   LOST     — declared lost; deposit forfeited; unit RETIRED
enum RentalStatus {
  OPEN
  RETURNED
  OVERDUE
  LOST
}

model RentalAgreement {
  id               String       @id @default(cuid())
  tenantId         String
  branchId         String
  customerId       String /// Required — rentals always have a known renter
  serializedUnitId String
  status           RentalStatus @default(OPEN)
  rentalRate       Decimal      @db.Decimal(12, 2) /// per-day or per-unit-time rate
  rateUnit         String /// "day" | "week" | "month"
  /// ₱ deposit collected up front; refunded on return minus damage fees.
  depositCents     Int          @default(0)
  /// Set on rentals tied to an Order — the deposit Order receipt.
  depositOrderId   String?      @unique
  /// Set on settlement (return + damage fees) — the balance Order receipt.
  returnOrderId    String?      @unique
  startedAt        DateTime     @default(now())
  /// Promised return date. Cron flips OPEN → OVERDUE after this.
  dueAt            DateTime
  returnedAt       DateTime?
  /// Damage fee charged on return (deducted from depositCents).
  damageFeeCents   Int          @default(0)
  /// Refunded amount (depositCents - damageFeeCents), recorded for audit.
  refundCents      Int          @default(0)
  /// Free-text condition notes at intake + return.
  intakeNotes      String?
  returnNotes      String?
  createdById      String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch         @relation(fields: [branchId], references: [id])
  customer       Customer       @relation(fields: [customerId], references: [id])
  serializedUnit SerializedUnit @relation(fields: [serializedUnitId], references: [id])
  createdBy      User           @relation(fields: [createdById], references: [id])

  @@index([tenantId, branchId, status, dueAt])
  @@index([customerId])
  @@index([serializedUnitId])
  @@map("rental_agreements")
}

/// Repair ticket queue. DME shops accept units in for cleaning / repair /
/// part replacement; this row tracks the workflow.
enum RepairStatus {
  RECEIVED /// Just dropped off; awaiting diagnosis
  AWAITING_PARTS /// Diagnosed; ordering replacement parts
  IN_PROGRESS /// Technician working on it
  READY_FOR_PICKUP
  PICKED_UP
  CANCELLED
}

model RepairTicket {
  id               String       @id @default(cuid())
  tenantId         String
  branchId         String
  ticketNumber     String /// "RP-000123"
  customerId       String? /// Optional — walk-ins without an account
  serializedUnitId String? /// Optional — sometimes for non-serialized items
  /// Free-text product description when serializedUnitId is null.
  itemDescription  String
  reportedIssue    String /// What the customer said is wrong
  diagnosis        String? /// Technician's findings
  status           RepairStatus @default(RECEIVED)
  /// Quoted price (₱ cents) — confirmed with customer before work starts.
  quotedFeeCents   Int          @default(0)
  /// Final invoiced amount when picked up (links to Order).
  pickupOrderId    String?      @unique
  receivedAt       DateTime     @default(now())
  readyAt          DateTime?
  pickedUpAt       DateTime?
  createdById      String
  technicianId     String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  serializedUnit SerializedUnit? @relation(fields: [serializedUnitId], references: [id], onDelete: SetNull)
  createdBy      User            @relation("RepairCreatedBy", fields: [createdById], references: [id])
  technician     User?           @relation("RepairTechnician", fields: [technicianId], references: [id])

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, branchId, status])
  @@index([customerId])
  @@map("repair_tickets")
}

// ─── Gas Station (MSME independent) — Fuel pumps + dispenses + tank dips ─────

enum FuelGrade {
  UNLEADED
  REGULAR
  DIESEL
  PREMIUM
  KEROSENE
  OTHER
}

enum FuelDispenseStatus {
  OPEN /// Attendant has captured opening meter; pumping in progress
  COMPLETED /// Closing meter captured + Order rung
  VOIDED /// Aborted by cashier (no charge)
}

/// A single fuel dispenser. Independents typically have 2-4. Each pump is
/// dedicated to one fuel grade (no multi-product nozzle splitting at MSME
/// level — that's branded territory).
model FuelPump {
  id           String    @id @default(cuid())
  tenantId     String
  branchId     String
  label        String /// "Pump 1", "Pump 2 — Diesel side"
  fuelGrade    FuelGrade
  /// Product representing this fuel grade. Price-per-liter comes from
  /// Product.price; updating the price posts in real-time.
  productId    String
  /// Cumulative liters dispensed since pump install — used as default
  /// opening reading for the next dispense. Mechanical pumps typically
  /// have a physical totalizer; software-tracked here for digital pumps.
  currentMeter Decimal   @db.Decimal(14, 3)
  /// DOE-mandated price ceiling per liter (₱). DOE doesn't publish a real-
  /// time API today; the owner enters this manually whenever the agency
  /// issues a price freeze. Counter shows a warning when Product.price
  /// exceeds this value.
  doeCeilingPricePhp Decimal? @db.Decimal(8, 2)
  isActive     Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch         @relation(fields: [branchId], references: [id])
  product   Product        @relation(fields: [productId], references: [id])
  dispenses FuelDispense[]

  @@unique([tenantId, branchId, label])
  @@index([tenantId, branchId, isActive])
  @@map("fuel_pumps")
}

/// One fuel dispense — captures opening + closing meter readings, computes
/// liters, snapshots the price per liter, and links to the Order rung at
/// the till. Idempotent on (pumpId, openingMeter) so a double-tap doesn't
/// create two OPEN dispenses on the same pump.
model FuelDispense {
  id              String             @id @default(cuid())
  pumpId          String
  attendantId     String /// User who pumped (PIN-attested)
  openingMeter    Decimal            @db.Decimal(14, 3)
  closingMeter    Decimal?           @db.Decimal(14, 3) /// null until COMPLETED
  litersDispensed Decimal?           @db.Decimal(14, 3) /// computed
  pricePerLiter   Decimal            @db.Decimal(8, 2) /// snapshot
  totalCents      Int? /// liters * price * 100, snapshot
  orderId         String?            @unique /// links to the sales Order
  status          FuelDispenseStatus @default(OPEN)
  startedAt       DateTime           @default(now())
  endedAt         DateTime?
  voidReason      String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  pump      FuelPump @relation(fields: [pumpId], references: [id], onDelete: Cascade)
  attendant User     @relation(fields: [attendantId], references: [id])

  @@unique([pumpId, openingMeter])
  @@index([pumpId, status])
  @@index([attendantId, startedAt])
  @@map("fuel_dispenses")
}

/// Tank dipstick log. Owner records morning + evening physical tank levels.
/// Variance vs (meter-derived dispense + deliveries) is computed in reports.
model TankDip {
  id             String      @id @default(cuid())
  tenantId       String
  branchId       String
  fuelGrade      FuelGrade
  /// Reading time (morning or evening — see kind). Stored as full Date so
  /// we can sort and filter by day.
  recordedAt     DateTime
  kind           TankDipKind
  /// Liters in the tank at the reading.
  litersOnHand   Decimal     @db.Decimal(14, 3)
  /// Deliveries received between this and the previous dip, if any.
  /// Owner enters when a fuel truck arrives.
  deliveryLiters Decimal?    @db.Decimal(14, 3)
  notes          String?
  recordedById   String
  createdAt      DateTime    @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch @relation(fields: [branchId], references: [id])
  recordedBy User   @relation(fields: [recordedById], references: [id])

  @@index([tenantId, branchId, fuelGrade, recordedAt])
  @@map("tank_dips")
}

enum TankDipKind {
  MORNING
  EVENING
  DELIVERY /// Recorded at the moment a tanker drops off fuel
}

// ─── Wholesale Price Lists ────────────────────────────────────────────────────

/// A named price list — used to offer wholesale / corporate / event pricing
/// per customer or per customer-group. Resolves at cart time: if the active
/// customer has `priceListId` set, every line price is overridden via
/// `PriceListItem`. Products without an override fall back to default price.
///
/// Bakery example: "Wholesale (cafes)" list with discounted unit prices for
/// pandesal, ensaymada, monay that sell to nearby cafes by the dozen.
model PriceList {
  id        String   @id @default(cuid())
  tenantId  String
  name      String /// "Wholesale (cafes)", "Corporate Q4 Promo", etc.
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     PriceListItem[]
  customers Customer[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("price_lists")
}

/// Per-product price override on a PriceList. Missing rows = use default price.
model PriceListItem {
  id          String   @id @default(cuid())
  priceListId String
  productId   String
  /// ₱ pesos. Stored as Decimal for consistency with Product.price.
  unitPrice   Decimal  @db.Decimal(12, 2)
  /// Minimum order quantity to unlock this price (e.g. "dozen-or-more").
  /// NULL = no minimum.
  minQuantity Decimal? @db.Decimal(12, 3)

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@index([priceListId])
  @@index([productId])
  @@map("price_list_items")
}
