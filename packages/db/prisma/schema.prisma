  customerStamps             CustomerStamp[]
  kioskTerminals             KioskTerminal[]
  deliveryReceipts           DeliveryReceipt[]
  laundryAddOns              LaundryServiceAddOn[]
  laundryPromos              LaundryPromo[]
  stockTransfers             StockTransfer[]
  cycleCounts                CycleCount[]
  projects                   Project[]
  // Sprint 13 — six-engine vertical schemas (back-references)
  prescriptions              Prescription[]
  productLots                ProductLot[]
  controlledSubstanceLogs    ControlledSubstanceLog[]
  fleetAssets                FleetAsset[]
  pmSchedules                PMSchedule[]
  tireSerials                TireSerial[]
  tripTickets                TripTicket[]
  liquidationItems           LiquidationItem[]
  progressBillings           ProgressBilling[]
  retentionReleases          RetentionRelease[]
  jobOrders                  JobOrder[]
  idempotencyKeys            IdempotencyKey[]
  productPhotos              ProductPhoto[]
  /// Per-tenant tunable severity thresholds for the Ledger ops dashboard.
  /// JSON shape (keys all numbers, optional):
  ///   { eventLagWarnMs, eventLagBadMs, pendingEventsWarn, failedEventsWarn,
  ///     dsoWarn, dsoBad, dpoWarn, dpoBad, voidRateWarn, voidRateBad,
  ///     closeAgeWarn, closeAgeBad }
  /// Null/empty = use the system defaults defined in the dashboard page.
  metricsThresholds          Json?
  /// JE approval threshold — when total absolute debit on a manual JE
  /// exceeds this amount, the JE is held in PENDING_APPROVAL until an
  /// authorised user (Owner / Finance Lead) approves it. 0 = no approval
  /// (everything posts directly). Default ₱50,000.
  jeApprovalThreshold        Decimal                    @default(50000) @db.Decimal(14, 2)
  /// Coffee shop floor-layout tier (CS_1..CS_5) — only used when businessType
  /// is COFFEE_SHOP. Controls the canonical station/printer/display setup.
  /// Null until the owner picks a layout in the setup wizard.
  /// Sales-controlled — owners cannot self-upgrade (per architectural decision).
  coffeeShopTier             CoffeeShopTier?
  /// Sprint 6 — Manufacturing overhead rate applied to COGS at sale time.
  /// Per unit produced; only used when businessType = MANUFACTURING.
  /// Null = no overhead allocation (the F&B / retail default — they record
  /// utilities & rent as Operating Expenses, not COGS, per PFRS for SMEs).
  /// Set this when the tenant manufactures finished goods and needs full
  /// absorption costing (Direct Materials + Direct Labor + MOH = COGS).
  overheadRatePerUnit        Decimal?                   @db.Decimal(10, 4)
  /// Optional customer-facing display toggle — meaningful only for CS_1
  /// (where the canonical setup has no customer display). Other tiers have
  /// it included by definition; this flag is ignored for them.
  hasCustomerDisplay         Boolean                    @default(false)

  // Sprint 3 — Floor Layout relations
  stations  Station[]
  printers  Printer[]
  terminals Terminal[]

  @@map("tenants")
}

/// Coffee Shop Operational Layout tier — see packages/shared-types/src/layouts.ts
/// for the structural template per tier. Locked in Sprint 3.
enum CoffeeShopTier {
  CS_1
  CS_2
  CS_3
  CS_4
  CS_5
}

model SubscriptionLog {
  id          String            @id @default(cuid())
  tenantId    String
  action      String
  tierFrom    SubscriptionTier?
  tierTo      SubscriptionTier?
  expiresAt   DateTime?
  notes       String?
  performedBy String
  createdAt   DateTime          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscription_logs")
}

/// Immutable audit trail for any change to tax settings or price adjustments.
/// Records are INSERT-only; never updated or deleted — required for BIR compliance.
model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String
  action      AuditAction
  /// The table / domain entity that was changed (e.g. "Tenant", "Order", "Product")
  entityType  String
  /// Primary key of the changed entity
  entityId    String
  /// Previous state as JSON snapshot
  before      Json?
  /// New state as JSON snapshot
  after       Json?
  /// Human-readable description of the change
  description String?
  /// User who triggered the change (null = system action)
  performedBy String?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, action])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

/// Sprint 21 — Idempotency-Key replay protection for financial mutations.
/// Stores the request key + the response payload so a retried POST with
/// the same key returns the cached response instead of double-posting.
/// 24-hour TTL; cron purges expired rows.
model IdempotencyKey {
  id           String   @id @default(cuid())
  tenantId     String
  /// User-supplied key from the Idempotency-Key header. Tenant-scoped so
  /// two tenants can independently use the same key value (e.g., a uuid
  /// generated by their client).
  key          String
  /// Hash of the request body (sha256) — protects against accidentally
  /// reusing the same key for a DIFFERENT request, which would silently
  /// return wrong data.
  requestHash  String
  /// HTTP method + path, e.g. "POST /orders". Limits a key to one endpoint.
  endpoint     String
  /// HTTP status code of the cached response.
  statusCode   Int
  /// Full JSON-serialised response body (truncated at 64KB to keep DB
  /// pressure bounded; a too-large response is recomputed on retry).
  responseBody String   @db.Text
  performedBy  String?
  createdAt    DateTime @default(now())
  /// Soft expiry — 24h after createdAt. Cron purges expired rows nightly.
  expiresAt    DateTime
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, endpoint])
  @@index([tenantId, expiresAt])
  @@map("idempotency_keys")
}

// ─── Console Audit Log ────────────────────────────────────────────────────────

enum ConsoleAction {
  TENANT_CREATED
  USER_CREATED
  PASSWORD_RESET
  ACCOUNT_UNLOCKED
  FORCE_LOGOUT
  USER_DEACTIVATED
  USER_REACTIVATED
  TIER_CHANGED
  STATUS_CHANGED
  AI_OVERRIDE_SET
  PROFILE_UPDATED
  DEMO_RESET
  /// Sprint 19 — destructive op for ransomware response & audit
