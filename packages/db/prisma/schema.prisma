  /// Computed at post: countedQty - expectedQty (positive = found extra; negative = shrinkage).
  varianceQty   Decimal @default(0) @db.Decimal(12, 3)
  notes         String?

  count       CycleCount  @relation(fields: [countId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@index([countId])
  @@index([rawMaterialId])
  @@map("cycle_count_lines")
}

// ─── Construction: Project + MaterialIssuance (Sprint 6, 2026-05-08) ─────────
