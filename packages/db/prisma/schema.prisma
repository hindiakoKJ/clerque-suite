// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                       String          @id @default(cuid())
  tenantId                 String
  branchId                 String?
  email                    String
  passwordHash             String
  name                     String
  role                     UserRole
  employmentType           EmploymentType  @default(REGULAR)
  salaryType               SalaryType?
  salaryRate               Decimal?        @db.Decimal(12, 2)
  shiftStart               String?
  shiftEnd                 String?
  sssNumber                String?
  philhealthNumber         String?
  pagibigNumber            String?
  tin                      String?
  photo                    String?
  kioskPin                 String?
  /// Sprint 19 — when true, this user exists ONLY for kiosk clock-in/out.
  /// They cannot log into Sync (or any product) via password — /auth/login
  /// rejects with code KIOSK_ONLY_ACCOUNT. Lets owners onboard cooks /
  /// dishwashers / drivers without having to invent + manage credentials
  /// for staff who never use the apps. Their TimeEntry records flow into
  /// the same payroll runs as login-using employees.
  kioskOnly                Boolean         @default(false)
  /// Mobile / contact number for HR records
  phone                    String?
  /// Job title / position (e.g. "Barista", "Shift Supervisor")
  position                 String?
  isActive                 Boolean         @default(true)
  hiredAt                  DateTime?
  separatedAt              DateTime?
  /// Sprint 19 — attrition tracking. Set together with separatedAt at the
  /// moment a tenant offboards an employee. Drives the BIR Form 2316
  /// generation flow (separated employees need a year-to-date tax
  /// statement issued within 30 days of separation per BIR rules) and
  /// HR analytics (voluntary vs involuntary attrition rate).
  separationType           SeparationType?
  separationReason         String?
  enable2fa                Boolean         @default(false)
  twoFactorSecret          String?
  /// Sprint 17 — 8 single-use, hashed backup codes (bcrypt). Each consumed
  /// code is removed from the array; user can regenerate the set.
  twoFactorBackupCodes     String[]        @default([])
  /// Sprint 17 — when 2FA enroll begins, store the un-confirmed secret.
  /// Verified + activated by /auth/2fa/verify; cleared on cancel.
  twoFactorPendingSecret   String?
  /// Sprint 13 — Compliance-Engine. PRC license number for licensed
  /// pharmacists. Required for `pharmacist:dispense` permission and printed
  /// on Rx-required POS receipts. Null for non-pharmacists.
  prcLicense               String?
  prcLicenseExpiresAt      DateTime?
  /// Time-limited token for self-service password reset (expires in 1 hour)
  passwordResetToken       String?         @unique
  passwordResetTokenExpiry DateTime?
  /// Sprint 25 Phase 2A — Sales Lead delegation flag. When true, this user is
  /// authorized as a supervisor PIN holder for discount + void approvals at
  /// the till WITHOUT being elevated to BRANCH_MANAGER. Gated by
  /// PLAN_FEATURES[planCode].salesLeadDelegation (0 = disabled, N = at most N
  /// delegations per tenant, -1 = unlimited). Independent of UserRole.SALES_LEAD
  /// (the legacy role); a delegated user keeps their original role and just
  /// gains supervisor-PIN authority.
  isSalesLead              Boolean         @default(false)
  /// Bcrypt-hashed 4-6 digit PIN for supervisor void overrides at the till.
  /// Only meaningful for users with VOID_DIRECT_ROLES (SALES_LEAD,
  /// BRANCH_MANAGER, BUSINESS_OWNER). Cashiers can have one set but it
  /// won't be accepted by /auth/verify-supervisor-pin.
  supervisorPinHash        String?
  /// RBAC: persona template the user was created from (e.g. "CASHIER_COOK").
  /// Reference into packages/shared-types/src/personas.ts; null for legacy users.
  personaKey               String?
  /// RBAC: extra permissions granted on top of the role + persona defaults.
  /// Members are PermissionKey strings (see permissions.ts). JWT-issue time
  /// merges these into the user's effective permission set.
  customPermissions        String[]        @default([])
  /// RBAC: SOD warning overrides. JSON shape:
  ///   { ruleId: string; reason: string; overriddenAt: ISO; overriddenById: cuid }[]
  /// Recorded when the owner explicitly accepts a yellow SOD warning.
  sodOverrides             Json?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  tenant                   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                   Branch?              @relation(fields: [branchId], references: [id])
  sessions                 UserSession[]
  trustedDevices           TrustedDevice[]
  loginLogs                LoginLog[]
  appAccess                UserAppAccess[]
  ordersAsCreator          Order[]              @relation("CreatedByUser")
  ordersAsUpdatedBy        Order[]              @relation("UpdatedByUser")
  ordersAsVoidedBy         Order[]              @relation("VoidedByUser")
  discountsAuthorized      OrderDiscount[]      @relation("AuthorizedByUser")
  timeEntries              TimeEntry[]
  payslips                 Payslip[]
  notifications            Notification[]
  bankReconciliations      BankReconciliation[]
  orderItemRefunds         OrderItemRefund[]
  leaveRequests            LeaveRequest[]       @relation("UserLeaves")
  leaveApprovals           LeaveRequest[]       @relation("LeaveApprover")
  employeeRequests         EmployeeRequest[]    @relation("UserEmployeeRequests")
  employeeRequestApprovals EmployeeRequest[]    @relation("EmployeeRequestApprover")
  thirteenthMonths         ThirteenthMonth[]

  // Sprint 13 — vertical engine back-references
  fleetAssetsAsPrimaryDriver FleetAsset[]      @relation("FleetPrimaryDriver")
  tripsAsDriver              TripTicket[]      @relation("TripDriver")
  tripsAsHelper              TripTicket[]      @relation("TripHelper")
  tripsAsLiquidator          TripTicket[]      @relation("TripLiquidator")
  jobOrdersAsTechnician      JobOrder[]        @relation("JobOrderTechnician")
  jobOrderLinesAsTechnician  JobOrderLine[]    @relation("JobOrderLineTechnician")
  preOrdersCreated           PreOrder[]
  rentalsCreated             RentalAgreement[]
  repairsCreated             RepairTicket[]    @relation("RepairCreatedBy")
  repairsAssigned            RepairTicket[]    @relation("RepairTechnician")
  fuelDispenses              FuelDispense[]
  tankDipsRecorded           TankDip[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

/// Per-user, per-app access level.
/// Auto-seeded from DEFAULT_APP_ACCESS on user create; can be overridden by BUSINESS_OWNER.
model UserAppAccess {
  id      String      @id @default(cuid())
  userId  String
  appCode AppCode
  level   AccessLevel @default(NONE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appCode])
  @@map("user_app_access")
}

model UserSession {
  id                String        @id @default(cuid())
  userId            String
  refreshTokenHash  String        @unique
  deviceInfo        String?
  deviceFingerprint String?
  ipAddress         String?
  status            SessionStatus @default(ACTIVE)
  expiresAt         DateTime
  createdAt         DateTime      @default(now())
  lastUsedAt        DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // Sprint 13 audit hardening: hot-path on every refresh — find ACTIVE
  // sessions for this user. Without this index every refresh scans all
  // sessions ever created for the user.
  @@index([userId, status])
  @@map("user_sessions")
}

model TrustedDevice {
  id                String   @id @default(cuid())
  userId            String
  deviceFingerprint String
  deviceInfo        String?
  trustedAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@map("trusted_devices")
}

model LoginLog {
  id         String   @id @default(cuid())
  userId     String?
  tenantId   String?
  email      String
  success    Boolean
  reason     String?
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  // Sprint 13 audit hardening: lockout check counts recent failures per
  // user. Without this index every login does a non-indexed scan.
  @@index([userId, createdAt])
  @@map("login_logs")
}

// ─── Product Catalog ──────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  /// Sprint 3 — which station prepares this category's items.
  /// Null = goes to receipt printer only (no separate station ticket).
  stationId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products       Product[]
  station        Station?        @relation("CategoryStation", fields: [stationId], references: [id], onDelete: SetNull)
  modifierGroups ModifierGroup[]

  @@index([tenantId, sortOrder])
  @@index([stationId])
  @@map("categories")
}

model Product {
  id               String        @id @default(cuid())
  tenantId         String
  categoryId       String?
  name             String
  description      String?
  /// Internal Stock-Keeping Unit — unique per tenant when set
  sku              String?
  /// Barcode (EAN-13, UPC-A, QR, etc.) — for scanner integration and BIR inventory audit
  barcode          String?
  imageUrl         String?
  price            Decimal       @db.Decimal(12, 2)
  costPrice        Decimal?      @db.Decimal(12, 2)
  inventoryMode    InventoryMode @default(UNIT_BASED)
  /// Whether this item carries 12% VAT. Drives taxType on OrderItem at checkout.
  isVatable        Boolean       @default(true)
  isActive         Boolean       @default(true)
  // ── Sprint 13 — Compliance-Engine (Pharmacy) ──────────────────────────
  /// Generic name (per RA 6675 — Generics Act of 1988). Required on every
  /// dispensed-drug receipt. Null for non-pharmacy products.
  genericName      String?
  /// Brand name shown alongside generic on Rx-required products.
  brandName        String?
  /// Dosage form (tablet, capsule, syrup, suspension, cream, etc.).
  dosageForm       String?
  /// Strength (e.g. "500mg", "5mg/ml"). Free-text — formularies vary.
  strength         String?
  /// Sprint 19 — PH drug-classification taxonomy. Drives till workflow per
  /// product (OTC = tap-and-charge; RX_ONLY = pharmacist PIN-attest; DDB_S2 =
  /// PIN + Yellow Rx serial; etc). Single source of truth — the two booleans
  /// below are auto-derived from this in ProductsService for backward-compat
  /// with queries that filter on them.
  drugClass        DrugClass     @default(OTC)
  /// DERIVED from drugClass via ProductsService.deriveBooleans(). Kept as a
  /// real column so existing Prisma queries that filter on it (including
  /// the OrdersService Rx guard from commit 2d30c97) keep working without
  /// a coordinated rename across N callsites.
  isRxRequired     Boolean       @default(false)
  /// DERIVED from drugClass. RA 9165 dangerous drugs (any DDB schedule).
  /// ControlledSubstanceLog continues to auto-create on sale of these.
  isControlledDrug Boolean       @default(false)
  /// Unit of Measure for this product (PC, KG, BOX, LITER, etc.)
  unitOfMeasureId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category             Category?              @relation(fields: [categoryId], references: [id])
  unitOfMeasure        UnitOfMeasure?         @relation(fields: [unitOfMeasureId], references: [id])
  variants             ProductVariant[]
  inventory            InventoryItem[]
  inventoryLogs        InventoryLog[]
  bomItems             BomItem[]
  orderItems           OrderItem[]
  preOrderItems        PreOrderItem[]
  priceListItems       PriceListItem[]
  serializedUnits      SerializedUnit[]
  fuelPumps            FuelPump[]
  promotionItems       PromotionProduct[]
  modifierGroups       ProductModifierGroup[]
  laundryProductLines  LaundryProductLine[]
  // Sprint 13 — Compliance-Engine
  productLots          ProductLot[]
  deliveryReceiptItems DeliveryReceiptItem[]
  // Sprint 13 — Service-Engine
  jobOrderLines        JobOrderLine[]         @relation("JobOrderLineProduct")
  // Postgres BYTEA-backed product photos (DB storage driver).
  photos               ProductPhoto[]

  @@index([tenantId, sku])
  @@index([tenantId, barcode])
  @@map("products")
}

/// Postgres BYTEA-backed product photo storage. Used by the DB storage
/// driver when neither S3/R2 nor a writable local uploads dir is available
/// (e.g. Railway prod with ephemeral / partially read-only container fs).
/// The public URL exposed to clients is `/api/v1/products/photos/<id>`.
model ProductPhoto {
  id           String   @id @default(cuid())
  tenantId     String
  mimeType     String
  byteSize     Int
  data         Bytes
  /// Original filename for the Content-Disposition header. Optional.
  originalName String?
  createdById  String?
  createdAt    DateTime @default(now())
  /// Optional FK back to the product that uses this photo. Null when the
  /// photo was uploaded but not yet attached (e.g. cashier took a photo
  /// then cancelled the form). Cleanup cron later.
  productId    String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@map("product_photos")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  sku       String?
  price     Decimal? @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  variantBomItems VariantBomItem[]

  @@map("product_variants")
}

// ─── Raw Materials & BOM ──────────────────────────────────────────────────────

model RawMaterial {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  /// Unit of measure for this ingredient (g, ml, pc, kg, etc.)
  unit          String   @default("g")
  costPrice     Decimal? @db.Decimal(12, 4)
  /// Minimum stock level — system flags the ingredient as low when any branch
  /// falls below this quantity (same unit as the ingredient itself).
  lowStockAlert Decimal? @db.Decimal(12, 4)
  /// Sprint 25 — when true, this raw material uses lot tracking (FEFO/FIFO).
  /// When false, falls back to simple `RawMaterialInventory.quantity` count.
  /// Counts against PLAN_FEATURES.maxAdvancedInventoryItems for the tenant.
  lotsTracked   Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant                  Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bomItems                BomItem[]
  variantBomItems         VariantBomItem[]
  inventory               RawMaterialInventory[]
  lots                    RawMaterialLot[]
  transferLines           StockTransferLine[]
  cycleCountLines         CycleCountLine[]
  issuanceLines           MaterialIssuanceLine[]
  modifierIngredientLinks ModifierOptionIngredient[]

  @@index([tenantId, isActive])
  @@map("raw_materials")
}

/// Variant-level BOM — maps a specific product size/variant to ingredient quantities.
/// Example: ProductVariant "Large Iced Americano" → espresso beans 25g, water 180ml.
/// Overrides or supplements the product-level BomItem for that variant.
model VariantBomItem {
  id            String  @id @default(cuid())
  variantId     String
  rawMaterialId String
  /// How much of the raw material is consumed per unit of this variant
  quantity      Decimal @db.Decimal(12, 4)

  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial    @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)

  @@unique([variantId, rawMaterialId])
  @@map("variant_bom_items")
}

model BomItem {
  id            String  @id @default(cuid())
  productId     String
  rawMaterialId String
  quantity      Decimal @db.Decimal(12, 4)

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)

  @@unique([productId, rawMaterialId])
  @@map("bom_items")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryItem {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String
  productId     String
  quantity      Decimal  @db.Decimal(12, 4)
  /// Moving-Average Cost (WAC). Recomputed on every positive-qty receipt
  /// when a unitCost is supplied. Drives COGS posting at sale time, replacing
  /// the older "snapshot of Product.costPrice" model. Null until the first
  /// costed receipt — sales fall back to product.costPrice in that case.
  avgCost       Decimal? @db.Decimal(12, 4)
  lowStockAlert Int?
  /// Sprint 25 — when true, this finished-good item uses lot tracking
  /// (FEFO with expiration alerts). When false, simple WAC + count.
  /// Counts against PLAN_FEATURES.maxAdvancedInventoryItems for the tenant.
  lotsTracked   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  lots    InventoryLot[]

  @@unique([branchId, productId])
  @@map("inventory_items")
}

/// Sprint 25 — finished-goods inventory lot. Parallel to RawMaterialLot.
/// Enables FEFO consumption + expiry tracking for SKUs with `lotsTracked=true`.
model InventoryLot {
  id                  String    @id @default(cuid())
  tenantId            String
  inventoryItemId     String
  qtyReceived         Decimal   @db.Decimal(12, 4)
  qtyRemaining        Decimal   @db.Decimal(12, 4)
  unitCost            Decimal   @db.Decimal(12, 4)
  receivedAt          DateTime
  expirationDate      DateTime?
  referenceNumber     String?
  /// Optional link to PO line when received against a purchase order.
  purchaseOrderItemId String?
  createdAt           DateTime  @default(now())

  inventoryItem     InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])

  @@index([inventoryItemId, expirationDate, receivedAt])
  @@index([tenantId, expirationDate])
  @@map("inventory_lots")
}

model RawMaterialInventory {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String
  rawMaterialId String
  quantity      Decimal  @db.Decimal(12, 4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@unique([branchId, rawMaterialId])
  @@map("raw_material_inventory")
}

model InventoryLog {
  id             String           @id @default(cuid())
  tenantId       String
  branchId       String
  productId      String
  type           InventoryLogType
  quantity       Decimal          @db.Decimal(12, 4)
  quantityBefore Decimal          @db.Decimal(12, 4)
  quantityAfter  Decimal          @db.Decimal(12, 4)
  reason         String?
  note           String?
  referenceId    String?
  createdById    String?
  createdAt      DateTime         @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId])
  @@index([productId])
  @@map("inventory_logs")
}

// ─── Promotions & Discount Types ──────────────────────────────────────────────

model Promotion {
  id               String    @id @default(cuid())
  tenantId         String
  name             String
  discountPercent  Decimal?  @db.Decimal(5, 2)
  fixedPrice       Decimal?  @db.Decimal(12, 2)
  appliesToAll     Boolean   @default(false)
  isStackable      Boolean   @default(false)
  startDate        DateTime?
  endDate          DateTime?
  activeDays       Int[]
  activeHoursStart String?
  activeHoursEnd   String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products PromotionProduct[]

  @@index([tenantId, isActive])
  @@index([tenantId, isActive, startDate, endDate]) // promo rules engine: active + date-range filter
  @@map("promotions")
}

model PromotionProduct {
  promotionId String
  productId   String

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@map("promotion_products")
}

model DiscountTypeConfig {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  defaultPercent      Decimal? @db.Decimal(5, 2)
  defaultFixed        Decimal? @db.Decimal(12, 2)
  requiresManagerAuth Boolean  @default(false)
  appliesAtItemLevel  Boolean  @default(true)
  appliesAtOrderLevel Boolean  @default(true)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("discount_type_configs")
}

// ─── Payment Channel Config ───────────────────────────────────────────────────

model PaymentChannelConfig {
  id         String        @id @default(cuid())
  tenantId   String
  method     PaymentMethod
  isEnabled  Boolean       @default(true)
  isBusiness Boolean       @default(false)
  mdrRate    Decimal?      @db.Decimal(5, 4)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, method])
  @@map("payment_channel_configs")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id               String      @id @default(cuid())
  tenantId         String
  branchId         String
  shiftId          String?
  orderNumber      String
  status           OrderStatus @default(OPEN)
  subtotal         Decimal     @db.Decimal(12, 2)
  discountAmount   Decimal     @default(0) @db.Decimal(12, 2)
  vatAmount        Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal     @db.Decimal(12, 2)
  isPwdScDiscount  Boolean     @default(false)
  pwdScIdRef       String?
  pwdScIdOwnerName String?
  notes            String?
  clientUuid       String?     @unique

  // ── BIR CAS Audit: Invoice Classification ─────────────────────────────────
  /// How payment is settled at POS.
  /// CASH_SALE = paid immediately; CHARGE = on-account (B2B / corporate).
  invoiceType InvoiceType @default(CASH_SALE)
  /// Dominant tax classification for the order.
  /// Individual line items may override this with their own taxType.
  taxType     TaxType     @default(VAT_12)

  // ── BIR CAS Audit: B2B Customer Fields (AR) ───────────────────────────────
  // Required per RR No. 1-2026 for invoices issued to registered businesses.
  // Walk-in / anonymous retail sales leave all three null.
  /// FK to the Customer master (AR sub-ledger). Null for walk-in / anonymous sales.
  customerId      String?
  /// Business name of the corporate buyer (for B2B invoices)
  customerName    String?
  /// BIR TIN of the corporate buyer — required for valid input VAT claim (format: 000-000-000)
  customerTin     String?
  /// Registered address of the corporate buyer — required for invoices > ₱1,000
  customerAddress String?
  /// Due date for credit (CHARGE) sales — set to createdAt + Customer.creditTermDays.
  /// Null for CASH_SALE. Drives AR aging buckets.
  dueDate         DateTime?

  // ── Audit Trail ────────────────────────────────────────────────────────────
  createdById       String?
  /// Last user to modify this record (role change, void, correction)
  updatedById       String?
  voidedById        String? // The supervisor who authorized the void (SALES_LEAD / OWNER)
  voidInitiatedById String? // The cashier who requested the void (null if supervisor voided directly)
  voidedAt          DateTime?
  voidReason        String?
  /// When payment was received and the order entered the production queue.
  /// For pre-Sprint-7 orders, this is backfilled to equal completedAt.
  paidAt            DateTime?
  /// When the LAST prep item on the order was marked READY by KDS — the
  /// moment the customer's order is physically ready for handoff.
  /// For orders with no prep items (retail / no station routing), this
  /// equals paidAt. Lead time KPI = readyAt - paidAt.
  readyAt           DateTime?
  completedAt       DateTime?
  /// Soft-delete timestamp — set on void/correction; NULL means active.
  /// BIR requirement: invoice numbers must never have gaps; hard delete is forbidden.
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch             @relation(fields: [branchId], references: [id])
  shift             Shift?             @relation(fields: [shiftId], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  createdBy         User?              @relation("CreatedByUser", fields: [createdById], references: [id])
  updatedBy         User?              @relation("UpdatedByUser", fields: [updatedById], references: [id])
  voidedBy          User?              @relation("VoidedByUser", fields: [voidedById], references: [id])
  items             OrderItem[]
  payments          OrderPayment[]
  discounts         OrderDiscount[]
  accountingEvents  AccountingEvent[]
  laundryOrder      LaundryOrder?
  // Sprint 13 — vertical engine back-references
  tripTicket        TripTicket?        @relation("TripOrder")
  progressBillings  ProgressBilling[]  @relation("ProgressBillingOrder")
  retentionReleases RetentionRelease[] @relation("RetentionReleaseOrder")
  jobOrder          JobOrder?          @relation("JobOrderInvoice")
  /// Back-pointers when this Order represents a pre-order deposit or balance.
  preOrderAsDeposit PreOrder?          @relation("PreOrderDeposit")
  preOrderAsBalance PreOrder?          @relation("PreOrderBalance")

  @@unique([tenantId, orderNumber])
  @@index([tenantId, createdAt])
  @@index([branchId, status])
  @@index([tenantId, deletedAt]) // soft-delete filter: WHERE deleted_at IS NULL
  @@index([branchId, deletedAt]) // branch-scoped active-order queries
  @@index([tenantId, customerId]) // AR: customer ledger queries
  @@index([tenantId, dueDate]) // AR aging: due-date range scans
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String
  variantId      String?
  productName    String
  unitPrice      Decimal  @db.Decimal(12, 2)
  quantity       Decimal  @db.Decimal(12, 4)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  vatAmount      Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal  @db.Decimal(12, 2)
  costPrice      Decimal? @db.Decimal(12, 2)
  isVatable      Boolean  @default(true)
  /// BIR per-line tax classification. Overrides the order-level taxType for this line.
  /// VAT_12 = standard 12%; VAT_EXEMPT = exempt by law; ZERO_RATED = 0% (exports/PEZA).
  taxType        TaxType  @default(VAT_12)
  notes          String?
  /// Running total of refunded quantity. 0 = no refund; equal to quantity = fully refunded.
  /// Source of truth: increment via OrderItemRefund event creation.
  refundedQty    Decimal  @default(0) @db.Decimal(12, 4)

  /// Sprint 5 — KDS state machine for kitchen/bar stations.
  /// PENDING (default) → READY (bumped by chef/barista) → SERVED (delivered).
  /// Only meaningful when the parent product's category routes to a station.
  prepStatus PrepStatus @default(PENDING)
  /// When the station bumped this item to READY (audit + lead-time analytics).
  readyAt    DateTime?
  /// When the runner/cashier marked it as delivered.
  servedAt   DateTime?

  // ── Sprint 13 — Compliance-Engine (Pharmacy) ──────────────────────────
  /// Link to a Prescription when the dispensed item required one. Pharmacy
  /// POS attaches this at till; backend rejects sale of `isRxRequired`
  /// products without a valid prescriptionId.
  prescriptionId String?
  /// Specific lot dispensed (for FDA recall trail + expiry enforcement).
  /// Null for non-pharmacy items.
  lotId          String?
  /// PRC license number of the pharmacist who approved the dispense.
  /// Required for `isRxRequired` items; printed on the OR.
  dispensedByPrc String?
  /// Sprint 19 — Yellow Rx serial number (DDB Form 1, pre-numbered accountable
  /// form). Required for DDB Schedule II sales (RA 9165 §61). The actual
  /// patient/doctor details remain in the paper Yellow Rx held by the
  /// pharmacy; this column is the link from the sale back to that paper.
  /// Format: alphanumeric + hyphens, 4-32 chars (no strict regex — actual
  /// DDB serial formats vary by issuing region).
  yellowRxSerial String?
  /// Sprint 19 — User.id of the pharmacist who attested at the till.
  /// Set together with dispensedByPrc by the OrdersService PIN-attest flow.
  /// Lets us join back to User for the dispensing pharmacist's name on the OR.
  dispensedById  String?

  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product             @relation(fields: [productId], references: [id])
  variant      ProductVariant?     @relation(fields: [variantId], references: [id])
  modifiers    OrderItemModifier[]
  refunds      OrderItemRefund[]
  prescription Prescription?       @relation(fields: [prescriptionId], references: [id])
  lot          ProductLot?         @relation(fields: [lotId], references: [id])

  @@index([orderId])
  @@index([prescriptionId])
  @@index([lotId])
  @@map("order_items")
}

enum PrepStatus {
  PENDING
  READY
  SERVED
}

/// Audit trail for partial item refunds. Each row is one refund event
/// against a single order line. Inventory is restocked optionally.
model OrderItemRefund {
  id           String        @id @default(cuid())
  orderItemId  String
  /// Quantity refunded in this event (positive)
  quantity     Decimal       @db.Decimal(12, 4)
  /// Cash refund amount = pro-rated lineTotal portion (incl. VAT)
  refundAmount Decimal       @db.Decimal(12, 2)
  reason       String
  /// How was the customer refunded — same enum as payment methods
  refundMethod PaymentMethod
  /// Did the operator put the items back on the shelf? If yes, inventory
  /// was incremented and a proportional COGS reversal was posted.
  restocked    Boolean       @default(true)
  refundedById String
  createdAt    DateTime      @default(now())

  orderItem  OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  refundedBy User      @relation(fields: [refundedById], references: [id])

  @@index([orderItemId, createdAt])
  @@map("order_item_refunds")
}

model OrderPayment {
  id        String        @id @default(cuid())
  orderId   String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  createdAt DateTime      @default(now())

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  settlementItem SettlementItem?

  @@index([orderId]) // settlement unmatched-payment lookup
  @@map("order_payments")
}

model OrderDiscount {
  id               String       @id @default(cuid())
  orderId          String
  discountType     DiscountType
  discountConfigId String?
  appliedBy        String?
  authorizedById   String?
  discountPercent  Decimal?     @db.Decimal(5, 2)
  discountFixed    Decimal?     @db.Decimal(12, 2)
  discountAmount   Decimal      @db.Decimal(12, 2)
  reason           String?
  /// PWD/SC ID — only set when discountType is PWD or SENIOR_CITIZEN.
  /// Multiple OrderDiscount rows on the same order = multiple PWDs/SCs sharing the meal,
  /// each with their own ID & cardholder name (BIR audit requires this trail).
  pwdScIdRef       String?
  pwdScIdOwnerName String?
  createdAt        DateTime     @default(now())

  order        Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorizedBy User? @relation("AuthorizedByUser", fields: [authorizedById], references: [id])

  @@index([orderId]) // order detail fetch includes discounts
  @@map("order_discounts")
}

// ─── Shift / Cash Management ──────────────────────────────────────────────────

model Shift {
  id                  String    @id @default(cuid())
  tenantId            String
  branchId            String
  /// Sprint 3 — terminal this shift opened on (POS-01, POS-02, etc.).
  /// Null for legacy shifts opened before multi-terminal support.
  terminalId          String?
  cashierId           String
  openingCash         Decimal   @db.Decimal(12, 2)
  closingCashDeclared Decimal?  @db.Decimal(12, 2)
  closingCashExpected Decimal?  @db.Decimal(12, 2)
  variance            Decimal?  @db.Decimal(12, 2)
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  notes               String?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch         @relation(fields: [branchId], references: [id])
  terminal Terminal?      @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  orders   Order[]
  cashOuts ShiftCashOut[]

  @@index([tenantId, branchId])
  @@index([branchId, closedAt]) // getActive(): WHERE branchId = X AND closedAt IS NULL
  @@index([terminalId, closedAt]) // per-terminal Z-Read queries
  @@map("shifts")
}

/// AI usage telemetry — one row per LLM call. Drives per-tenant cost
/// tracking, monthly budget caps, and an audit trail of AI-assisted
/// actions (receipt OCR, JE drafter, time-anomaly resolver, etc.).
///
/// Cost is recorded at write-time based on the provider's published pricing;
/// we do NOT recompute or normalise across providers. If pricing changes,
/// historical rows keep their original cost.
model AiUsage {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  /// Stable action key, e.g. 'receipt_ocr' | 'je_drafter' | 'time_anomaly'.
  /// New actions can be added without a migration.
  action       String
  provider     String   @default("anthropic")
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Decimal  @default(0) @db.Decimal(12, 6)
  success      Boolean  @default(true)
  errorMessage String?
  durationMs   Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action, createdAt])
  @@map("ai_usage")
}

/// Cash leaving the till during a shift.
/// PAID_OUT  = real expense paid from cash drawer (parking tip, ice run,
///             COD delivery payment). Reduces expected cash AND posts a
///             journal entry (DR Expense / CR Cash on Hand).
/// CASH_DROP = mid-shift safekeeping — cashier hands cash to manager who
///             puts it in the safe. Reduces expected cash; offset to
///             "Cash on Safe" — no expense.
///
/// Both subtract from the close-shift expected-cash math, so variance
/// reconciles cleanly when legitimate cash leaves the till mid-shift.
enum CashOutType {
  PAID_OUT
  CASH_DROP
}

model ShiftCashOut {
  id              String      @id @default(cuid())
  tenantId        String
  branchId        String
  shiftId         String
  type            CashOutType
  amount          Decimal     @db.Decimal(12, 2)
  reason          String // free-text, ≥10 chars validated at DTO
  category        String? // 'supplies' | 'delivery' | 'fuel' | 'change_fund' | 'other' | etc.
  receiptPhotoUrl String? // optional snap of the receipt; OCR-fillable
  /// User who recorded the cash-out (typically the cashier on shift)
  createdById     String
  /// Optional manager who approved an above-threshold paid-out (PIN co-auth)
  approvedById    String?
  /// AI-assisted flag — set when receipt OCR pre-filled the form
  aiAssisted      Boolean     @default(false)
  createdAt       DateTime    @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([tenantId, shiftId])
  @@index([branchId, createdAt])
  @@map("shift_cash_outs")
}

// ─── Accounting Events ────────────────────────────────────────────────────────

model AccountingEvent {
  id         String                @id @default(cuid())
  tenantId   String
  orderId    String?
  type       AccountingEventType
  status     AccountingEventStatus @default(PENDING)
  payload    Json
  retryCount Int                   @default(0)
  lastError  String?
  syncedAt   DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order        Order?        @relation(fields: [orderId], references: [id])
  journalEntry JournalEntry?

  @@index([tenantId, status])
  @@index([tenantId, status, createdAt]) // CRON processor: PENDING events ordered by age
  @@map("accounting_events")
}

// ─── Chart of Accounts ────────────────────────────────────────────────────────

model Account {
  id             String         @id @default(cuid())
  tenantId       String
  code           String
  name           String
  type           AccountType
  normalBalance  NormalBalance
  postingControl PostingControl @default(OPEN)
  isSystem       Boolean        @default(false)
  isActive       Boolean        @default(true)
  parentId       String?
  description    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant                        Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent                        Account?                       @relation("AccountHierarchy", fields: [parentId], references: [id])
  children                      Account[]                      @relation("AccountHierarchy")
  journalLines                  JournalLine[]
  arInvoiceLines                ARInvoiceLine[]
  apBillLines                   APBillLine[]
  bankReconciliations           BankReconciliation[]
  // Sprint 22 — AR/AP parity
  creditMemoLines               CreditMemoLine[]
  vendorCreditNoteLines         VendorCreditNoteLine[]
  recurringInvoiceTemplateLines RecurringInvoiceTemplateLine[]
  recurringBillTemplateLines    RecurringBillTemplateLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@map("accounts")
}

// ─── Journal Entries ──────────────────────────────────────────────────────────

model JournalEntry {
  id                String             @id @default(cuid())
  tenantId          String
  accountingEventId String?            @unique
  entryNumber       String
  /// Document Date — date the economic event occurred (source doc date)
  date              DateTime
  /// Posting Date — determines which accounting period the entry lands in.
  /// User-editable; must fall within an open period before posting.
  /// Defaults to the document date when not explicitly set.
  postingDate       DateTime?
  description       String
  /// Optional external reference: invoice #, OR #, voucher #, etc.
  reference         String?
  status            JournalEntryStatus @default(POSTED)
  source            JournalSource      @default(MANUAL)
  createdBy         String?
  postedBy          String? // userId who approved DRAFT → POSTED
  postedAt          DateTime?
  /// Approval workflow — set when the entry's gross amount exceeded the
  /// tenant's jeApprovalThreshold and was held for sign-off. Approver
  /// must be Owner / Finance Lead / Super Admin (different from poster
  /// where possible, for SOD).
  approvedById      String?
  approvedAt        DateTime?
  /// Optional rejection reason (set when an approver rejects a pending JE)
  rejectionReason   String?
  /// Points to the JE this entry is reversing (set on the reversal JE)
  reversalOfId      String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountingEvent  AccountingEvent?  @relation(fields: [accountingEventId], references: [id])
  lines            JournalLine[]
  /// The original entry that this JE reverses
  reversalOf       JournalEntry?     @relation("JEReversals", fields: [reversalOfId], references: [id])
  /// The reversal entry created for this JE (if any)
  reversedBy       JournalEntry?     @relation("JEReversals")
  /// AR/AP back-references — at most one is non-null per JE (a JE is created
  /// by exactly one document type: invoice post, bill post, or payment).
  arInvoice        ARInvoice?        @relation("ARInvoiceJE")
  arPayment        ARPayment?        @relation("ARPaymentJE")
  apBill           APBill?           @relation("APBillJE")
  apPayment        APPayment?        @relation("APPaymentJE")
  // Sprint 22 — AR/AP parity. Each is also at-most-one per JE.
  creditMemo       CreditMemo?       @relation("CreditMemoJE")
  vendorCreditNote VendorCreditNote? @relation("VendorCreditNoteJE")
  customerAdvance  CustomerAdvance?  @relation("CustomerAdvanceJE")
  vendorAdvance    VendorAdvance?    @relation("VendorAdvanceJE")

  @@index([tenantId, postingDate])
  @@index([tenantId, date])
  @@index([tenantId, status])
  /// SecAudit 2026-05 A1 (Critical) — gapless JE numbering per BIR. Comment
  /// in journal.service.ts:41 has long claimed this constraint exists; it
  /// only existed as @@index before — NumberingService races could silently
  /// double-issue. Now enforced at the DB level.
  @@unique([tenantId, entryNumber])
  @@map("journal_entries")
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal  @default(0) @db.Decimal(14, 2)
  credit         Decimal  @default(0) @db.Decimal(14, 2)
  /// Transaction currency (future FX support). Always "PHP" until multi-currency is enabled.
  currency       String   @default("PHP")
  /// Exchange rate to PHP functional currency. Always 1 until FX engine is built.
  exchangeRate   Decimal  @default(1) @db.Decimal(12, 6)
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

// ─── Modifier Groups (F&B add-ons) ───────────────────────────────────────────

/// A named group of choices attached to a product (e.g. "Size", "Add-ons")
model ModifierGroup {
  id          String   @id @default(cuid())
  tenantId    String
  /// Optional category binding — when set, this modifier group auto-applies
  /// to every product in the category, without needing per-product attachment.
  /// Per-product ProductModifierGroup links still work for one-off overrides.
  categoryId  String?
  name        String
  required    Boolean  @default(false)
  multiSelect Boolean  @default(false)
  minSelect   Int      @default(0)
  maxSelect   Int?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  options  ModifierOption[]
  products ProductModifierGroup[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("modifier_groups")
}

/// A single choice within a modifier group (e.g. "Large +₱20")
///
/// Sprint-modifier-recipes: options now carry recipe-aware fields so the
/// inventory consumption path on orders can deduct extra ingredients (an
/// "+1 espresso shot" add-on) and scale the base BOM up or down (a "Grande"
/// size at 1.25× the Tall recipe).
model ModifierOption {
  id               String   @id @default(cuid())
  modifierGroupId  String
  name             String
  priceAdjustment  Decimal  @default(0) @db.Decimal(12, 2)
  /// Multiplier applied to the product's base BOM when this option is
  /// selected. 1.0 = no change (default). 1.25 = consume 25% more of every
  /// base ingredient (used for size upgrades). Only one size-type option
  /// per order item is honoured — if a cashier somehow selects two, the
  /// service uses the highest multiplier.
  recipeMultiplier Decimal  @default(1.0) @db.Decimal(8, 4)
  isDefault        Boolean  @default(false)
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  group         ModifierGroup              @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemMods OrderItemModifier[]
  ingredients   ModifierOptionIngredient[]

  @@index([modifierGroupId])
  @@map("modifier_options")
}

/// Junction: ingredients that get ADDED to a sale when this option is
/// selected. The decrement runs against RawMaterialInventory just like a
/// product BomItem does, so COGS posting + lot drain + WAC math all flow
/// through the existing pipeline. Quantity is scaled by the order item's
/// quantity (1 latte × 2 cups × 5g coffee = 10g consumed).
///
/// Unit is a denormalized snapshot so the consumption code doesn't need to
/// join through RawMaterial for unit math. The web admin enforces that
/// option.unit matches RawMaterial.unit at edit time.
model ModifierOptionIngredient {
  id               String  @id @default(cuid())
  modifierOptionId String
  rawMaterialId    String
  quantity         Decimal @db.Decimal(14, 4)
  unit             String

  option      ModifierOption @relation(fields: [modifierOptionId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial    @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)

  @@unique([modifierOptionId, rawMaterialId])
  @@index([modifierOptionId])
  @@index([rawMaterialId])
  @@map("modifier_option_ingredients")
}

/// Junction: which modifier groups apply to a product
model ProductModifierGroup {
  productId       String
  modifierGroupId String
  sortOrder       Int    @default(0)

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([productId, modifierGroupId])
  @@map("product_modifier_groups")
}

/// Snapshot of the modifier chosen at sale time — never re-queried from option table
model OrderItemModifier {
  id               String  @id @default(cuid())
  orderItemId      String
  modifierGroupId  String
  modifierOptionId String
  groupName        String
  optionName       String
  priceAdjustment  Decimal @db.Decimal(12, 2)

  orderItem      OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption ModifierOption @relation(fields: [modifierOptionId], references: [id])

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

// ─── Units of Measure ─────────────────────────────────────────────────────────

/// Configurable UoM per tenant — used by Retail / Construction product types
model UnitOfMeasure {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  abbreviation     String
  baseUnit         String?
  conversionFactor Decimal? @db.Decimal(12, 6)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, abbreviation])
  @@index([tenantId])
  @@map("units_of_measure")
}

// ─── Settlement Tracking ──────────────────────────────────────────────────────

/// A batch of digital payments (GCash/Maya/QR Ph) that settle together to the bank.
/// GCash and Maya collect money from customers on the merchant's behalf, then transfer
/// a lump sum to the merchant's bank account 1–3 business days later.
/// One SettlementBatch = one bank credit entry.
model SettlementBatch {
  id              String           @id @default(cuid())
  tenantId        String
  branchId        String
  method          PaymentMethod // GCASH_BUSINESS, MAYA_BUSINESS, QR_PH, etc.
  referenceNumber String? // Gateway's own batch/settlement reference
  expectedAmount  Decimal          @db.Decimal(12, 2) // Sum of transactions in batch
  actualAmount    Decimal?         @db.Decimal(12, 2) // Amount that actually arrived in bank
  variance        Decimal?         @db.Decimal(12, 2) // actualAmount - expectedAmount
  periodStart     DateTime // Earliest transaction date in this batch
  periodEnd       DateTime // Latest transaction date in this batch
  settledAt       DateTime? // When bank credit was received
  bankReference   String? // Bank transaction reference / OR number
  status          SettlementStatus @default(PENDING)
  notes           String?
  reconciledById  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  SettlementItem[]

  @@index([tenantId, status])
  @@index([tenantId, method, periodStart])
  @@map("settlement_batches")
}

/// Links one OrderPayment to a SettlementBatch — the line-item level.
/// One GCash payment from a customer = one SettlementItem inside a batch.
model SettlementItem {
  id                String   @id @default(cuid())
  settlementBatchId String
  orderPaymentId    String   @unique // one payment can only be in one batch
  amount            Decimal  @db.Decimal(12, 2)
  transactionRef    String? // Gateway transaction reference for this specific payment
  createdAt         DateTime @default(now())

  batch        SettlementBatch @relation(fields: [settlementBatchId], references: [id], onDelete: Cascade)
  orderPayment OrderPayment    @relation(fields: [orderPaymentId], references: [id])

  @@index([settlementBatchId])
  @@map("settlement_items")
}

// ─── Accounting Periods ───────────────────────────────────────────────────────

/// A closed period prevents any new journal entries from being posted to it.
/// Think of it like a locked accounting book for a given month.
///
/// Immutability rules (mirrors SAP period management / OB52):
///   - Closing a period writes closedById + closedAt (permanent facts, never nulled).
///   - Reopening a period writes reopenedById + reopenedAt + reopenReason and increments
///     reopenCount. The close metadata is preserved so auditors can see the full history.
///   - Both actions are mirrored to the AuditLog for BIR/CAS compliance.
///   - No postings (journal entries or order sync) can land in a CLOSED period.
model AccountingPeriod {
  id           String                 @id @default(cuid())
  tenantId     String
  name         String // e.g. "April 2026"
  startDate    DateTime
  endDate      DateTime
  status       AccountingPeriodStatus @default(OPEN)
  /// User who last closed this period. Never nulled on reopen — preserved as a historical fact.
  closedById   String?
  closedAt     DateTime?
  /// User who last reopened this period (null if never reopened).
  reopenedById String?
  reopenedAt   DateTime?
  /// Mandatory justification written by the Business Owner when reopening.
  reopenReason String?
  /// How many times this period has been reopened. BIR auditors flag counts > 0 for review.
  reopenCount  Int                    @default(0)
  notes        String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, startDate])
  @@index([tenantId, status])
  @@map("accounting_periods")
}

// ─── Z-Read Log (INSERT-only — BIR CAS daily tamper-proof totals) ──────────────
// One record per branch per calendar date. Never updated after creation.
// Mirrors the physical Z-Reading printout required by BIR CAS accreditation.
model ZReadLog {
  id             String   @id @default(cuid())
  tenantId       String
  branchId       String
  /// Calendar date of the sales day (local PH time, stored as midnight UTC+8)
  date           DateTime @db.Date
  /// Total completed (non-voided) orders for the day
  totalOrders    Int
  /// Total voided orders for the day
  voidCount      Int
  /// Gross sales before any discounts (sum of order.subtotal)
  grossSales     Decimal  @db.Decimal(15, 4)
  /// Net sales after all discounts (sum of order.totalAmount for completed orders)
  netSales       Decimal  @db.Decimal(15, 4)
  /// Total VAT collected (0 for UNREGISTERED and NON_VAT tenants)
  vatAmount      Decimal  @db.Decimal(15, 4)
  /// Total discount amount applied
  discountAmount Decimal  @db.Decimal(15, 4)
  /// Cash payments total
  cashAmount     Decimal  @db.Decimal(15, 4)
  /// Non-cash (card, e-wallet, etc.) payments total
  nonCashAmount  Decimal  @db.Decimal(15, 4)
  /// Who triggered this Z-Read (system cron = null, manual = userId)
  generatedById  String?
  /// Insert timestamp — immutable anchor for audit
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// One Z-Read per branch per day — uniqueness enforced at DB level
  @@unique([branchId, date])
  @@index([tenantId, date])
  @@map("z_read_logs")
}

// ─── X-Read Log (shift-level tamper-proof totals) ────────────────────────────
// One record per shift. Never updated after creation.
model XReadLog {
  id             String   @id @default(cuid())
  tenantId       String
  branchId       String
  shiftId        String   @unique
  /// Shift open timestamp
  openedAt       DateTime
  /// Shift close timestamp
  closedAt       DateTime
  totalOrders    Int
  voidCount      Int
  grossSales     Decimal  @db.Decimal(15, 4)
  netSales       Decimal  @db.Decimal(15, 4)
  vatAmount      Decimal  @db.Decimal(15, 4)
  discountAmount Decimal  @db.Decimal(15, 4)
  cashAmount     Decimal  @db.Decimal(15, 4)
  nonCashAmount  Decimal  @db.Decimal(15, 4)
  openingCash    Decimal  @db.Decimal(15, 4)
  closingCash    Decimal  @db.Decimal(15, 4)
  cashVariance   Decimal  @db.Decimal(15, 4)
  generatedById  String?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, closedAt])
  @@map("x_read_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 4 AP STUBS — Accounts Payable & Withholding Tax
//
// These models are schema-ready but have no API controllers yet.
// They exist to:
//   1. Pass BIR CAS audit (WHT records must be in the database)
//   2. Enable future Phase 4 AP module without a breaking migration
//
// BIR references:
//   ATC (Alphanumeric Tax Code) — Form 1601-EQ classification
//   WHT (Withholding Tax) — creditable withholding on vendor payments
// ─────────────────────────────────────────────────────────────────────────────

/// Master list of vendors/suppliers.
/// Required for BIR Form 1601-EQ (withholding tax return) and input VAT claims.
model Vendor {
  id             String   @id @default(cuid())
  tenantId       String
  /// Legal business name as registered with BIR
  name           String
  /// Vendor's BIR TIN — required for valid input VAT claim (format: 000-000-000-000)
  tin            String?
  /// Vendor's BIR-registered address — required for input VAT documentation
  address        String?
  contactEmail   String?
  contactPhone   String?
  /// Default ATC (Alphanumeric Tax Code) for withholding on payments to this vendor.
  /// Examples: WI160 = rentals (5%), WI010 = professional fees (10/15%), WI040 = services (2%)
  defaultAtcCode String?
  /// Default WHT rate for this vendor (as decimal, e.g. 0.05 = 5%)
  defaultWhtRate Decimal? @db.Decimal(5, 4)
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expenses         ExpenseEntry[]
  bills            APBill[]
  payments         APPayment[]
  deliveryReceipts DeliveryReceipt[]

  // Sprint 22 — AP standalone-accounting parity
  creditNotes    VendorCreditNote[]
  vendorAdvances VendorAdvance[]
  recurringBills RecurringBillTemplate[]
  // Sprint 25 — Solo Pro purchase orders
  purchaseOrders PurchaseOrder[]

  @@index([tenantId, tin])
  @@index([tenantId, isActive])
  @@map("vendors")
}

/// Expense / vendor bill — records AP transactions with withholding tax.
/// Connects to the GL via AccountingEvent → JournalEntry.
/// BIR CAS requirement: every outgoing payment with WHT must be traceable.
model ExpenseEntry {
  id              String        @id @default(cuid())
  tenantId        String
  branchId        String?
  vendorId        String?
  /// Human-readable description of the expense (e.g., "Office rental Q1 2026")
  description     String
  /// Date the expense was incurred (document date)
  expenseDate     DateTime
  /// Gross amount before withholding (the invoice face value)
  grossAmount     Decimal       @db.Decimal(14, 2)
  /// BIR Alphanumeric Tax Code — classifies the nature of the payment for 1601-EQ.
  /// Must match the ATC on the BIR withholding tax certificate (2307).
  atcCode         String?
  /// WHT rate applied (e.g., 0.05 = 5%). Pulled from Vendor.defaultWhtRate or manually set.
  whtRate         Decimal?      @db.Decimal(5, 4)
  /// Computed withholding tax amount (grossAmount × whtRate).
  /// This is the amount remitted to BIR — held back from the vendor payment.
  whtAmount       Decimal       @default(0) @db.Decimal(14, 2)
  /// Net amount actually paid to the vendor (grossAmount − whtAmount).
  netAmount       Decimal       @db.Decimal(14, 2)
  /// Input VAT on this purchase (for VAT-registered tenants claiming input tax).
  inputVat        Decimal       @default(0) @db.Decimal(14, 2)
  /// Reference document number (vendor invoice #, receipt #, OR #)
  referenceNumber String?
  /// When the vendor bill is due — drives AP aging buckets (0-30, 31-60, 61-90, 90+)
  dueDate         DateTime?
  /// When payment was actually remitted to the vendor
  paidAt          DateTime?
  /// Amount paid to vendor (= netAmount for full payment; < netAmount for partial)
  paidAmount      Decimal?      @db.Decimal(14, 2)
  /// Bank reference, check number, or e-wallet transaction ID for the payment
  paymentRef      String?
  status          ExpenseStatus @default(DRAFT)
  notes           String?
  createdById     String?
  updatedById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@index([tenantId, expenseDate])
  @@index([tenantId, status])
  @@index([vendorId])
  @@map("expense_entries")
}

enum ExpenseStatus {
  DRAFT // Entered but not yet posted to ledger
  POSTED // Journal entry created; locked from editing
  VOIDED // Cancelled; WHT refund/credit memo may be required
}

// ─── AR — Customer Master ─────────────────────────────────────────────────────

/// Customer / corporate account for B2B credit sales (AR sub-ledger).
/// Walk-in / retail customers are anonymous — no Customer record needed.
model Customer {
  id             String   @id @default(cuid())
  tenantId       String
  /// Legal business name as registered with BIR
  name           String
  /// BIR TIN — required for valid B2B invoice per RR No. 1-2026
  tin            String?
  /// BIR-registered address — required for invoices above ₱1,000
  address        String?
  /// Default pickup/delivery address used by laundry intake. Falls back to
  /// `address` when null — separated so a B2B customer's BIR-registered HQ
  /// address can differ from where they want their dry-cleaning delivered.
  defaultAddress String?
  contactEmail   String?
  contactPhone   String?
  /// Payment term in calendar days. 0 = cash; 30 = Net 30; 60 = Net 60.
  creditTermDays Int      @default(0)
  /// Maximum outstanding AR balance allowed. NULL = no limit.
  creditLimit    Decimal? @db.Decimal(14, 2)
  /// Lifetime claim count — auto-incremented on every CLAIMED LaundryOrder.
  /// Drives the loyalty punch-card UI ("you're 7 of 10 visits in"). Reset to 0
  /// after a free-Nth promo redemption.
  loyaltyVisits  Int      @default(0)
  /// Optional wholesale price list. When set, Counter cart pulls per-product
  /// overrides from PriceListItem instead of the default Product.price.
  priceListId    String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  priceList        PriceList?        @relation(fields: [priceListId], references: [id], onDelete: SetNull)
  orders           Order[]
  invoices         ARInvoice[]
  payments         ARPayment[]
  quotes           Quote[]
  laundryOrders    LaundryOrder[]
  projects         Project[]
  // Sprint 13
  prescriptions    Prescription[]
  trips            TripTicket[]      @relation("TripCustomer")
  jobOrders        JobOrder[]        @relation("JobOrderCustomer")
  preOrders        PreOrder[]
  rentalAgreements RentalAgreement[]
  repairTickets    RepairTicket[]

  // Sprint 19 — Loyalty stamp cards (digital + printable)
  stampCards CustomerStampCard[]

  // Sprint 25 Phase 2C — Loyalty Pro stamp tracking (Pro-tier).
  loyaltyProStamps CustomerStamp[]

  // Sprint 22 — AR standalone-accounting parity
  creditMemos       CreditMemo[]
  customerAdvances  CustomerAdvance[]
  recurringInvoices RecurringInvoiceTemplate[]

  @@index([tenantId, isActive])
  @@index([tenantId, tin])
  @@map("customers")
}

// ─── Loyalty Stamp Cards (Sprint 19) ─────────────────────────────────────────
//
// "Buy 9 coffees, get the 10th free" — the classic SMB coffee-shop
// loyalty mechanic. Tenant defines templates; customers earn stamps
// automatically on qualifying sales; redemption is a cashier-side action
// at the till. Each customer has a per-template card with a permanent
// public token so they can pull up their stamp count from any phone
// (digital wallet replacement) and the tenant can print a thermal-sized
// physical card with the same QR code.

enum StampAccrualBasis {
  /// One stamp per qualifying order (regardless of quantity / amount).
  /// Default — matches the typical "buy 1 drink = 1 punch" model.
  PER_ORDER
  /// One stamp per ₱X spent on the order (set via accrualThreshold).
  /// Bigger orders earn more stamps.
  PER_AMOUNT
}

model StampCardTemplate {
  id               String            @id @default(cuid())
  tenantId         String
  /// Display name on the card (e.g. "Coffee Lovers Card").
  name             String
  /// Description of the reward — printed on the back of the card and
  /// shown digitally. Free-form. (e.g. "Free drink up to ₱150")
  rewardLabel      String
  /// How many stamps to earn the reward.
  requiredStamps   Int
  /// How stamps are earned. PER_ORDER is the safe default.
  accrualBasis     StampAccrualBasis @default(PER_ORDER)
  /// Only meaningful when accrualBasis = PER_AMOUNT. Stamp = floor(orderTotal / threshold).
  accrualThreshold Decimal?          @db.Decimal(10, 2)
  /// Optional: minimum order subtotal to earn ANY stamp (cuts low-value gaming).
  /// Null = no minimum. Applied AFTER discounts.
  minOrderTotal    Decimal?          @db.Decimal(10, 2)
  /// Days until a customer's accrued stamps expire if no new earn activity.
  /// Null = stamps never expire. Common values: 90 / 180 / 365.
  expiryDays       Int?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cards  CustomerStampCard[]

  @@index([tenantId, isActive])
  @@map("stamp_card_templates")
}

model CustomerStampCard {
  id              String    @id @default(cuid())
  tenantId        String
  customerId      String
  templateId      String
  /// Current stamp count toward the next reward. Resets to 0 on redemption.
  stamps          Int       @default(0)
  /// Lifetime stamps earned (never resets — analytics).
  lifetimeStamps  Int       @default(0)
  /// Number of times this card has been redeemed.
  redemptionCount Int       @default(0)
  /// Unguessable URL slug for the public /stamps/<token> page.
  /// Format: <8-hex>-<8-hex>; safe to print on physical cards / QR codes.
  publicToken     String    @unique
  /// Last earn event — drives the expiry warning ("stamps expire in 14 days").
  lastEarnedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template StampCardTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  events   StampCardEvent[]

  @@unique([customerId, templateId])
  @@index([tenantId, customerId])
  @@map("customer_stamp_cards")
}

enum StampEventKind {
  EARN // +N stamps from a sale
  REDEEM // reward claimed; stamps reset to 0
  EXPIRE // cron-triggered when expiryDays elapsed
  ADJUST // manual adjustment by owner (audit purposes)
}

model StampCardEvent {
  id          String         @id @default(cuid())
  cardId      String
  kind        StampEventKind
  /// Signed delta. EARN positive, REDEEM negative, ADJUST either.
  delta       Int
  /// Stamps after this event landed (snapshot for audit).
  stampsAfter Int
  /// Optional FK to the Order that triggered the EARN — null for ADJUST/EXPIRE.
  orderId     String?
  /// Free-form note, e.g. "Manual: card lost; restored from old paper card".
  note        String?
  performedBy String?
  createdAt   DateTime       @default(now())

  card CustomerStampCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
  @@map("stamp_card_events")
}

// ─── Loyalty Pro — Digital Stamp Programs (Sprint 25 Phase 2C) ───────────────
// Pro-tier (loyaltyPro feature flag). Simpler, QR-code-driven stamp scheme
// that runs alongside the existing Sprint 19 stamp cards. Cashier scans the
// customer's QR at the till and grants N stamps; redemption zeros earned
// stamps and surfaces the configured reward product.
model StampProgram {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  stampsRequired  Int
  rewardProductId String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stamps CustomerStamp[]

  @@index([tenantId, isActive])
  @@map("stamp_programs")
}

model CustomerStamp {
  id           String    @id @default(cuid())
  tenantId     String
  customerId   String
  programId    String
  stampsEarned Int       @default(0)
  lastEarnedAt DateTime?
  redeemedAt   DateTime?

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  program  StampProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([customerId, programId])
  @@index([tenantId, customerId])
  @@map("customer_stamps")
}

// ─── Sync Kiosk Terminals (Sprint 19) ────────────────────────────────────────
// Shared on-site clock-in/out device. Owner enrolls a tablet once; staff
// punch their kiosk PIN to clock in or out. The kiosk authenticates with a
// long-lived apiKey scoped to a (tenant, optional branch); per-staff
// authentication is the User.kioskPin lookup performed server-side. Only
// punches; no read access to any other tenant data.

model KioskTerminal {
  id             String    @id @default(cuid())
  tenantId       String
  /// Optional branch scope. When set, only users assigned to that branch
  /// (or no branch) can punch from this kiosk. Null = any branch.
  branchId       String?
  name           String
  /// Owner-issued long-lived bearer key. Embedded in the kiosk URL once
  /// at enrollment; rotate by revoking + re-issuing.
  apiKey         String    @unique
  isActive       Boolean   @default(true)
  /// Telemetry — last successful or failed punch attempt from this kiosk.
  lastUsedAt     DateTime?
  /// Sliding-window failure counter for PIN brute-force throttling.
  failedAttempts Int       @default(0)
  /// When failedAttempts hit the limit, this is set; punches return 429
  /// until now() > lockedUntil.
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId, isActive])
  @@map("kiosk_terminals")
}

// ─── Sprint 19 — Supplier delivery receiving ─────────────────────────────────
// Pharmacies receive stock from distributors (Mercury, Watsons-DSI, Zuellig,
// Pharma) and need to log it with lot + expiry → inventory atomically. The
// optional apBillId link lets the owner manually create the AP bill from the
// existing /ledger/ap/bills page and tie it back. Future sprint: auto-post
// the bill from the receipt.

model DeliveryReceipt {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String
  vendorId     String
  /// Distributor's DR / invoice number printed on the paper receipt
  drNumber     String
  receivedAt   DateTime @default(now())
  /// User.id of the staff member who received + logged the delivery
  receivedById String
  notes        String?
  /// Optional link to the AP bill posted for this delivery (created later
  /// from /ledger/ap/bills; null until the owner posts the bill).
  apBillId     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch                @relation(fields: [branchId], references: [id])
  vendor Vendor                @relation(fields: [vendorId], references: [id])
  items  DeliveryReceiptItem[]

  @@unique([tenantId, vendorId, drNumber])
  @@index([tenantId, branchId, receivedAt])
  @@map("delivery_receipts")
}

model DeliveryReceiptItem {
  id           String   @id @default(cuid())
  receiptId    String
  productId    String
  /// Lot/batch number from the distributor's slip
  lotNumber    String
  expiresAt    DateTime
  quantity     Decimal  @db.Decimal(12, 3)
  costPrice    Decimal  @db.Decimal(12, 2)
  /// FK to the ProductLot row created when this receipt item posted
  productLotId String?  @unique
  createdAt    DateTime @default(now())

  receipt    DeliveryReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id])
  productLot ProductLot?     @relation(fields: [productLotId], references: [id])

  @@index([receiptId])
  @@map("delivery_receipt_items")
}

// ─── AR (Accounts Receivable) ────────────────────────────────────────────────
// Customer invoices + payments + matching. Drives FBL5N-style "show me all
// open items for customer X" queries. POS Orders with invoiceType=CHARGE
// continue to exist independently — ARInvoice is the formal back-office
// invoice document with proper status tracking.

enum InvoiceStatus {
  DRAFT // not yet posted; no GL impact
  OPEN // posted, no payments
  PARTIALLY_PAID // some payment applied, balance > 0
  PAID // fully paid, balance = 0
  CANCELLED // never posted, retained for audit
  VOIDED // posted then reversed; reversal JE created
}

/// Customer invoice — the "you owe us" document.
/// On POST, creates a JE: DR AR Receivables, CR Revenue/Output VAT.
/// Status transitions: DRAFT → OPEN → PARTIALLY_PAID → PAID
///                     OPEN → CANCELLED (if never posted) or VOIDED (post then reverse).
model ARInvoice {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  /// User-visible invoice number, tenant-scoped sequence.
  invoiceNumber String
  /// Customer's PO# or our external reference.
  reference     String?

  customerId String

  /// Document Date — when the sale happened.
  invoiceDate DateTime
  /// Posting Date — drives accounting period.
  postingDate DateTime
  /// Computed at create: invoiceDate + termsDays (or override).
  dueDate     DateTime
  /// Net days. 0 = cash; 30 = Net 30; copied from customer at create unless overridden.
  termsDays   Int      @default(0)

  subtotal      Decimal @db.Decimal(14, 2)
  vatAmount     Decimal @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal @db.Decimal(14, 2)
  /// Sum of applied payments. Updated on every ARPaymentApplication change.
  paidAmount    Decimal @default(0) @db.Decimal(14, 2)
  /// Computed: totalAmount - paidAmount. Stored for query speed in aging reports.
  balanceAmount Decimal @db.Decimal(14, 2)

  status InvoiceStatus @default(DRAFT)

  description String?
  notes       String?
  createdById String
  postedById  String?
  postedAt    DateTime?
  voidedById  String?
  voidedAt    DateTime?
  voidReason  String?

  /// JE created on POST. Null while DRAFT.
  journalEntryId String? @unique

  /// Sprint 22 — set when this invoice was materialized by the recurring
  /// template @Cron runner. Null for manually-created invoices.
  recurringTemplateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?                      @relation(fields: [branchId], references: [id])
  customer            Customer                     @relation(fields: [customerId], references: [id])
  journalEntry        JournalEntry?                @relation("ARInvoiceJE", fields: [journalEntryId], references: [id])
  lines               ARInvoiceLine[]
  applications        ARPaymentApplication[]
  convertedFromQuote  Quote?                       @relation("QuoteConversion")
  recurringTemplate   RecurringInvoiceTemplate?    @relation("ARInvoiceFromRecurringTemplate", fields: [recurringTemplateId], references: [id])
  creditApplications  CreditMemoApplication[]      @relation("ARInvoiceCreditApplications")
  advanceApplications CustomerAdvanceApplication[] @relation("ARInvoiceAdvanceApplications")

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, customerId, status])
  @@index([tenantId, status, dueDate]) // FBL5N-style: open items past due
  @@index([tenantId, postingDate])
  @@index([tenantId, recurringTemplateId])
  @@map("ar_invoices")
}

model ARInvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  /// GL account to credit on POST (Revenue, Service Income, etc.).
  accountId   String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(14, 4)
  unitPrice   Decimal  @db.Decimal(14, 2)
  /// Per-line VAT amount (for invoices with mixed VATable/non-VATable).
  taxAmount   Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  invoice ARInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  account Account   @relation(fields: [accountId], references: [id])

  @@index([invoiceId])
  @@map("ar_invoice_lines")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

/// Sales Quote (a.k.a. Proforma / Estimate). Pre-revenue: no GL impact.
/// Converts to an ARInvoice on acceptance, which is when the JE posts.
model Quote {
  id                   String      @id @default(cuid())
  tenantId             String
  branchId             String?
  /// Tenant-scoped sequence. Format: Q-YYYY-####
  quoteNumber          String
  customerId           String
  quoteDate            DateTime
  /// When the quote auto-expires if not accepted.
  validUntil           DateTime
  /// Free-text terms (payment terms, scope of work). Owner-set per quote.
  terms                String?
  notes                String?
  /// Set when status becomes CONVERTED; FK to the ARInvoice it became.
  convertedToInvoiceId String?     @unique
  status               QuoteStatus @default(DRAFT)
  subtotal             Decimal     @db.Decimal(14, 2)
  vatAmount            Decimal     @default(0) @db.Decimal(14, 2)
  totalAmount          Decimal     @db.Decimal(14, 2)
  createdById          String
  acceptedAt           DateTime?
  sentAt               DateTime?
  convertedAt          DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  tenant               Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch?     @relation(fields: [branchId], references: [id])
  customer             Customer    @relation(fields: [customerId], references: [id])
  convertedInvoice     ARInvoice?  @relation("QuoteConversion", fields: [convertedToInvoiceId], references: [id])
  lines                QuoteLine[]

  @@unique([tenantId, quoteNumber])
  @@index([tenantId, customerId, status])
  @@index([tenantId, status, validUntil])
  @@map("quotes")
}

model QuoteLine {
  id          String   @id @default(cuid())
  quoteId     String
  description String
  quantity    Decimal  @default(1) @db.Decimal(14, 4)
  unitPrice   Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_lines")
}

/// Customer payment received. May apply to one or many invoices via ARPaymentApplication.
/// Unapplied portion = unallocated credit (customer paid more than billed; sits as credit).
model ARPayment {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  paymentNumber String // tenant-scoped sequence
  customerId    String
  paymentDate   DateTime
  postingDate   DateTime

  method          PaymentMethod // CASH | GCASH_BUSINESS | etc. (reuses POS enum)
  reference       String? // OR#, check#, GCash ref
  totalAmount     Decimal       @db.Decimal(14, 2)
  appliedAmount   Decimal       @default(0) @db.Decimal(14, 2)
  /// totalAmount - appliedAmount. Sits as customer credit when > 0.
  unappliedAmount Decimal       @db.Decimal(14, 2)

  description String?
  notes       String?
  createdById String
  voidedById  String?
  voidedAt    DateTime?
  voidReason  String?

  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?                @relation(fields: [branchId], references: [id])
  customer     Customer               @relation(fields: [customerId], references: [id])
  journalEntry JournalEntry?          @relation("ARPaymentJE", fields: [journalEntryId], references: [id])
  applications ARPaymentApplication[]

  @@unique([tenantId, paymentNumber])
  @@index([tenantId, customerId])
  @@index([tenantId, postingDate])
  @@map("ar_payments")
}

/// Junction: one payment can apply to N invoices, one invoice can receive N payments.
/// On insert/update/delete, recompute the invoice's paidAmount + status.
model ARPaymentApplication {
  id            String   @id @default(cuid())
  paymentId     String
  invoiceId     String
  appliedAmount Decimal  @db.Decimal(14, 2)
  appliedAt     DateTime @default(now())

  payment ARPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice ARInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
  @@map("ar_payment_applications")
}

// ─── AP (Accounts Payable) — mirrors AR for vendor bills ─────────────────────

enum BillStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  CANCELLED
  VOIDED
}

/// Vendor bill — the "we owe them" document.
/// On POST, creates a JE: DR Expense/Asset, CR AP Payables (+ optional WHT split).
model APBill {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  /// Our internal bill number, tenant-scoped sequence.
  billNumber    String
  /// Vendor's invoice number printed on their document we received.
  vendorBillRef String?
  /// Our PO# or external reference.
  reference     String?

  vendorId String

  billDate    DateTime
  postingDate DateTime
  dueDate     DateTime
  termsDays   Int      @default(0)

  subtotal      Decimal @db.Decimal(14, 2)
  vatAmount     Decimal @default(0) @db.Decimal(14, 2)
  /// Withholding tax withheld on payment (PH-specific). Reduces the cash outflow.
  whtAmount     Decimal @default(0) @db.Decimal(14, 2)
  whtAtcCode    String? // ATC: WI160 (rentals 5%), WI010 (prof fees 10/15%), WI040 (services 2%)
  totalAmount   Decimal @db.Decimal(14, 2)
  paidAmount    Decimal @default(0) @db.Decimal(14, 2)
  balanceAmount Decimal @db.Decimal(14, 2)

  status BillStatus @default(DRAFT)

  description String?
  notes       String?
  createdById String
  postedById  String?
  postedAt    DateTime?
  voidedById  String?
  voidedAt    DateTime?
  voidReason  String?

  journalEntryId String? @unique

  /// Sprint 22 — set when materialized by the recurring bill template runner.
  recurringTemplateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?                       @relation(fields: [branchId], references: [id])
  vendor              Vendor                        @relation(fields: [vendorId], references: [id])
  journalEntry        JournalEntry?                 @relation("APBillJE", fields: [journalEntryId], references: [id])
  lines               APBillLine[]
  applications        APPaymentApplication[]
  recurringTemplate   RecurringBillTemplate?        @relation("APBillFromRecurringTemplate", fields: [recurringTemplateId], references: [id])
  creditApplications  VendorCreditNoteApplication[] @relation("APBillCreditApplications")
  advanceApplications VendorAdvanceApplication[]    @relation("APBillAdvanceApplications")

  @@unique([tenantId, billNumber])
  @@index([tenantId, vendorId, status])
  @@index([tenantId, status, dueDate]) // FBL1N-style: open items past due
  @@index([tenantId, postingDate])
  @@index([tenantId, recurringTemplateId])
  @@map("ap_bills")
}

model APBillLine {
  id          String   @id @default(cuid())
  billId      String
  /// GL account to debit on POST (expense or asset).
  accountId   String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(14, 4)
  unitPrice   Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  bill    APBill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([billId])
  @@map("ap_bill_lines")
}

model APPayment {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  paymentNumber String
  vendorId      String
  paymentDate   DateTime
  postingDate   DateTime

  method          PaymentMethod
  reference       String?
  totalAmount     Decimal       @db.Decimal(14, 2)
  appliedAmount   Decimal       @default(0) @db.Decimal(14, 2)
  unappliedAmount Decimal       @db.Decimal(14, 2)

  description String?
  notes       String?
  createdById String
  voidedById  String?
  voidedAt    DateTime?
  voidReason  String?

  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?                @relation(fields: [branchId], references: [id])
  vendor       Vendor                 @relation(fields: [vendorId], references: [id])
  journalEntry JournalEntry?          @relation("APPaymentJE", fields: [journalEntryId], references: [id])
  applications APPaymentApplication[]

  @@unique([tenantId, paymentNumber])
  @@index([tenantId, vendorId])
  @@index([tenantId, postingDate])
  @@map("ap_payments")
}

model APPaymentApplication {
  id            String   @id @default(cuid())
  paymentId     String
  billId        String
  appliedAmount Decimal  @db.Decimal(14, 2)
  appliedAt     DateTime @default(now())

  payment APPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bill    APBill    @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@unique([paymentId, billId])
  @@index([billId])
  @@map("ap_payment_applications")
}

// ─── Sprint 22 — AR/AP standalone-accounting parity ─────────────────────────
//
// Six new models bring Clerque AR/AP to Xero/QuickBooks feature parity:
//   1. CreditMemo            — AR credit issued against an invoice (refund / write-off / adjustment)
//   2. VendorCreditNote      — AP credit received from vendor (returns, vendor refund)
//   3. CustomerAdvance       — customer down payment / deposit before invoice
//   4. VendorAdvance         — vendor prepayment / deposit before bill
//   5. RecurringInvoiceTemplate — subscription billing (Xero killer feature)
//   6. RecurringBillTemplate    — recurring payables (rent, utilities)
//
// Design notes:
// - Credit Memos / Credit Notes POST their own JE rather than reversing the
//   original's JE. This preserves the original invoice's audit trail and
//   matches Xero/QB behaviour (the original stays OPEN/PAID, the credit
//   reduces customer/vendor balance separately).
// - Advances are unallocated cash on the customer/vendor account, applied
//   against future invoices/bills via the same Application-row pattern AR
//   and AP already use for payments.
// - Recurring templates are NOT documents themselves — they spawn child
//   invoices/bills on a @Cron schedule. The child is a normal ARInvoice /
//   APBill with `recurringTemplateId` set, so all existing reporting,
//   posting, and aging code works unchanged.

enum CreditMemoStatus {
  DRAFT
  POSTED // GL impact recorded; appears on customer statement
  APPLIED // Fully applied to one or more invoices (or refunded in cash)
  VOIDED
}

enum CreditMemoReason {
  RETURN // Customer returned goods
  PRICE_ADJUSTMENT // Negotiated discount after invoice
  BILLING_ERROR // We over-billed
  GOODWILL // Customer-service gesture
  BAD_DEBT_WRITE_OFF // Uncollectable; written off
  OTHER
}

/// AR Credit Memo. Reduces a customer's outstanding balance without
/// reversing the original invoice. Posts its own JE on POST:
///   DR Revenue (or Sales Returns)   CR Accounts Receivable
/// Applied against open invoices via CreditMemoApplication. Unapplied
/// portion sits as customer credit (mirror of unappliedAmount on ARPayment).
model CreditMemo {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  memoNumber String // Tenant-scoped sequence (CM-YYYY-####)
  customerId String

  memoDate    DateTime
  postingDate DateTime

  reason      CreditMemoReason @default(OTHER)
  reasonNotes String?

  /// Optional FK to the invoice this credit relates to (informational only —
  /// the actual application is via CreditMemoApplication rows so a single
  /// credit can apply across multiple invoices).
  relatedInvoiceId String?

  subtotal        Decimal @db.Decimal(14, 2)
  vatAmount       Decimal @default(0) @db.Decimal(14, 2)
  totalAmount     Decimal @db.Decimal(14, 2)
  /// Sum of CreditMemoApplication.appliedAmount.
  appliedAmount   Decimal @default(0) @db.Decimal(14, 2)
  /// totalAmount - appliedAmount.
  unappliedAmount Decimal @db.Decimal(14, 2)

  status CreditMemoStatus @default(DRAFT)

  description String?
  notes       String?
  createdById String
  postedById  String?
  postedAt    DateTime?
  voidedById  String?
  voidedAt    DateTime?
  voidReason  String?

  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?                 @relation(fields: [branchId], references: [id])
  customer     Customer                @relation(fields: [customerId], references: [id])
  journalEntry JournalEntry?           @relation("CreditMemoJE", fields: [journalEntryId], references: [id])
  lines        CreditMemoLine[]
  applications CreditMemoApplication[]

  @@unique([tenantId, memoNumber])
  @@index([tenantId, customerId, status])
  @@index([tenantId, postingDate])
  @@map("credit_memos")
}

model CreditMemoLine {
  id          String   @id @default(cuid())
  memoId      String
  /// GL account to DEBIT on POST (Sales Returns / Revenue contra).
  accountId   String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(14, 4)
  unitPrice   Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  memo    CreditMemo @relation(fields: [memoId], references: [id], onDelete: Cascade)
  account Account    @relation(fields: [accountId], references: [id])

  @@index([memoId])
  @@map("credit_memo_lines")
}

/// Junction: applies a CreditMemo against an ARInvoice. A single memo can
/// span multiple invoices (e.g., a goodwill credit applied across several
/// open invoices). Mirrors ARPaymentApplication.
model CreditMemoApplication {
  id            String   @id @default(cuid())
  memoId        String
  invoiceId     String
  appliedAmount Decimal  @db.Decimal(14, 2)
  appliedAt     DateTime @default(now())
  appliedById   String

  memo    CreditMemo @relation(fields: [memoId], references: [id], onDelete: Cascade)
  invoice ARInvoice  @relation("ARInvoiceCreditApplications", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([memoId, invoiceId])
  @@index([invoiceId])
  @@map("credit_memo_applications")
}

enum VendorCreditNoteStatus {
  DRAFT
  POSTED
  APPLIED
  VOIDED
}

enum VendorCreditNoteReason {
  RETURN
  PRICE_ADJUSTMENT
  BILLING_ERROR
  REBATE
  OTHER
}

/// AP Vendor Credit Note. Vendor credits us (we returned goods, vendor
/// over-billed, rebate). Posts:
///   DR Accounts Payable    CR Expense / Inventory
/// Applied against open bills via VendorCreditNoteApplication.
model VendorCreditNote {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  noteNumber    String // Tenant-scoped (VCN-YYYY-####)
  /// Vendor's credit-note reference printed on their document.
  vendorNoteRef String?
  vendorId      String

  noteDate    DateTime
  postingDate DateTime

  reason      VendorCreditNoteReason @default(OTHER)
  reasonNotes String?

  relatedBillId String?

  subtotal        Decimal @db.Decimal(14, 2)
  vatAmount       Decimal @default(0) @db.Decimal(14, 2)
  totalAmount     Decimal @db.Decimal(14, 2)
  appliedAmount   Decimal @default(0) @db.Decimal(14, 2)
  unappliedAmount Decimal @db.Decimal(14, 2)

  status VendorCreditNoteStatus @default(DRAFT)

  description String?
  notes       String?
  createdById String
  postedById  String?
  postedAt    DateTime?
  voidedById  String?
  voidedAt    DateTime?
  voidReason  String?

  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?                       @relation(fields: [branchId], references: [id])
  vendor       Vendor                        @relation(fields: [vendorId], references: [id])
  journalEntry JournalEntry?                 @relation("VendorCreditNoteJE", fields: [journalEntryId], references: [id])
  lines        VendorCreditNoteLine[]
  applications VendorCreditNoteApplication[]

  @@unique([tenantId, noteNumber])
  @@index([tenantId, vendorId, status])
  @@index([tenantId, postingDate])
  @@map("vendor_credit_notes")
}

model VendorCreditNoteLine {
  id          String   @id @default(cuid())
  noteId      String
  /// GL account to CREDIT on POST (Expense reversal / Inventory contra).
  accountId   String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(14, 4)
  unitPrice   Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  note    VendorCreditNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  account Account          @relation(fields: [accountId], references: [id])

  @@index([noteId])
  @@map("vendor_credit_note_lines")
}

model VendorCreditNoteApplication {
  id            String   @id @default(cuid())
  noteId        String
  billId        String
  appliedAmount Decimal  @db.Decimal(14, 2)
  appliedAt     DateTime @default(now())
  appliedById   String

  note VendorCreditNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  bill APBill           @relation("APBillCreditApplications", fields: [billId], references: [id], onDelete: Cascade)

  @@unique([noteId, billId])
  @@index([billId])
  @@map("vendor_credit_note_applications")
}

enum AdvanceStatus {
  DRAFT
  POSTED // Cash received/sent; sits as liability/asset
  APPLIED // Fully applied to invoices/bills
  REFUNDED // Returned to customer/vendor
  VOIDED
}

/// Customer down payment / deposit received before invoicing.
/// Posts on receive:  DR Cash  CR Customer Deposits Liability (Acct 2031 / 1063 contra)
/// Posts on apply:    DR Customer Deposits Liability   CR AR (invoice balance)
model CustomerAdvance {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  advanceNumber String // Tenant-scoped (CA-YYYY-####)
  customerId    String

  advanceDate DateTime
  postingDate DateTime

  method          PaymentMethod
  reference       String?
  totalAmount     Decimal       @db.Decimal(14, 2)
  appliedAmount   Decimal       @default(0) @db.Decimal(14, 2)
  unappliedAmount Decimal       @db.Decimal(14, 2)

  status      AdvanceStatus @default(DRAFT)
  description String?
  notes       String?
  createdById String
  postedById  String?
  postedAt    DateTime?
  voidedById  String?
  voidedAt    DateTime?
  voidReason  String?

  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?                      @relation(fields: [branchId], references: [id])
  customer     Customer                     @relation(fields: [customerId], references: [id])
  journalEntry JournalEntry?                @relation("CustomerAdvanceJE", fields: [journalEntryId], references: [id])
  applications CustomerAdvanceApplication[]

  @@unique([tenantId, advanceNumber])
  @@index([tenantId, customerId, status])
  @@index([tenantId, postingDate])
  @@map("customer_advances")
}

model CustomerAdvanceApplication {
  id            String   @id @default(cuid())
  advanceId     String
  invoiceId     String
  appliedAmount Decimal  @db.Decimal(14, 2)
  appliedAt     DateTime @default(now())
  appliedById   String

  advance CustomerAdvance @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  invoice ARInvoice       @relation("ARInvoiceAdvanceApplications", fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([advanceId, invoiceId])
  @@index([invoiceId])
  @@map("customer_advance_applications")
}

/// Vendor prepayment / deposit we paid before receiving the bill.
/// Posts on send:   DR Vendor Prepayments (Acct 1063)   CR Cash
/// Posts on apply:  DR Accounts Payable   CR Vendor Prepayments
model VendorAdvance {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  advanceNumber String // Tenant-scoped (VA-YYYY-####)
  vendorId      String

  advanceDate DateTime
  postingDate DateTime

  method          PaymentMethod
  reference       String?
  totalAmount     Decimal       @db.Decimal(14, 2)
  appliedAmount   Decimal       @default(0) @db.Decimal(14, 2)
  unappliedAmount Decimal       @db.Decimal(14, 2)

  status      AdvanceStatus @default(DRAFT)
  description String?
  notes       String?
  createdById String
  postedById  String?
  postedAt    DateTime?
  voidedById  String?
  voidedAt    DateTime?
  voidReason  String?

  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?                    @relation(fields: [branchId], references: [id])
  vendor       Vendor                     @relation(fields: [vendorId], references: [id])
  journalEntry JournalEntry?              @relation("VendorAdvanceJE", fields: [journalEntryId], references: [id])
  applications VendorAdvanceApplication[]

  @@unique([tenantId, advanceNumber])
  @@index([tenantId, vendorId, status])
  @@index([tenantId, postingDate])
  @@map("vendor_advances")
}

model VendorAdvanceApplication {
  id            String   @id @default(cuid())
  advanceId     String
  billId        String
  appliedAmount Decimal  @db.Decimal(14, 2)
  appliedAt     DateTime @default(now())
  appliedById   String

  advance VendorAdvance @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  bill    APBill        @relation("APBillAdvanceApplications", fields: [billId], references: [id], onDelete: Cascade)

  @@unique([advanceId, billId])
  @@index([billId])
  @@map("vendor_advance_applications")
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

enum RecurringTemplateStatus {
  ACTIVE
  PAUSED
  COMPLETED // End date reached
  CANCELLED
}

/// Recurring AR Invoice template. The template itself never posts —
/// the @Cron materializer creates ARInvoice rows on the schedule and
/// links them back via ARInvoice.recurringTemplateId. Customer / lines /
/// terms are copied verbatim into each child invoice.
model RecurringInvoiceTemplate {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  templateNumber String // Tenant-scoped (RI-YYYY-####)
  /// Human label shown in lists ("Monthly retainer — ACME Corp").
  name           String

  customerId String

  frequency   RecurrenceFrequency
  /// Day-of-month for MONTHLY / QUARTERLY / etc., or day-of-week for WEEKLY (0=Sun).
  dayOfPeriod Int
  /// First invoice date.
  startDate   DateTime
  /// Optional end date. If null, runs forever (until paused/cancelled).
  endDate     DateTime?
  /// Net terms copied into each child invoice.
  termsDays   Int                 @default(0)

  /// When the next child invoice should be materialized. Cron advances this
  /// after each successful materialization.
  nextRunAt DateTime
  /// When the last child invoice was materialized (audit).
  lastRunAt DateTime?
  /// Count of children materialized to date (audit).
  runCount  Int       @default(0)

  /// Template totals (denormalized from lines; recomputed on update).
  subtotal    Decimal @db.Decimal(14, 2)
  vatAmount   Decimal @default(0) @db.Decimal(14, 2)
  totalAmount Decimal @db.Decimal(14, 2)

  status      RecurringTemplateStatus @default(ACTIVE)
  description String?
  notes       String?
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?                        @relation(fields: [branchId], references: [id])
  customer Customer                       @relation(fields: [customerId], references: [id])
  lines    RecurringInvoiceTemplateLine[]
  children ARInvoice[]                    @relation("ARInvoiceFromRecurringTemplate")

  @@unique([tenantId, templateNumber])
  @@index([tenantId, customerId, status])
  @@index([tenantId, status, nextRunAt]) // cron-scan-friendly
  @@map("recurring_invoice_templates")
}

model RecurringInvoiceTemplateLine {
  id          String  @id @default(cuid())
  templateId  String
  accountId   String
  description String?
  quantity    Decimal @default(1) @db.Decimal(14, 4)
  unitPrice   Decimal @db.Decimal(14, 2)
  taxAmount   Decimal @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal @db.Decimal(14, 2)

  template RecurringInvoiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account  Account                  @relation(fields: [accountId], references: [id])

  @@index([templateId])
  @@map("recurring_invoice_template_lines")
}

/// Recurring AP Bill template. Mirror of RecurringInvoiceTemplate for payables.
model RecurringBillTemplate {
  id       String  @id @default(cuid())
  tenantId String
  branchId String?

  templateNumber String
  name           String

  vendorId String

  frequency   RecurrenceFrequency
  dayOfPeriod Int
  startDate   DateTime
  endDate     DateTime?
  termsDays   Int                 @default(0)

  nextRunAt DateTime
  lastRunAt DateTime?
  runCount  Int       @default(0)

  subtotal    Decimal @db.Decimal(14, 2)
  vatAmount   Decimal @default(0) @db.Decimal(14, 2)
  /// Default WHT for the recurring bill (rent typically WI160 = 5%).
  whtAmount   Decimal @default(0) @db.Decimal(14, 2)
  whtAtcCode  String?
  totalAmount Decimal @db.Decimal(14, 2)

  status      RecurringTemplateStatus @default(ACTIVE)
  description String?
  notes       String?
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?                     @relation(fields: [branchId], references: [id])
  vendor   Vendor                      @relation(fields: [vendorId], references: [id])
  lines    RecurringBillTemplateLine[]
  children APBill[]                    @relation("APBillFromRecurringTemplate")

  @@unique([tenantId, templateNumber])
  @@index([tenantId, vendorId, status])
  @@index([tenantId, status, nextRunAt])
  @@map("recurring_bill_templates")
}

model RecurringBillTemplateLine {
  id          String  @id @default(cuid())
  templateId  String
  accountId   String
  description String?
  quantity    Decimal @default(1) @db.Decimal(14, 4)
  unitPrice   Decimal @db.Decimal(14, 2)
  taxAmount   Decimal @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal @db.Decimal(14, 2)

  template RecurringBillTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account  Account               @relation(fields: [accountId], references: [id])

  @@index([templateId])
  @@map("recurring_bill_template_lines")
}

// ─── Document Number Sequences (per-tenant, per-type, optional per-branch) ───

enum SequenceType {
  AR_INVOICE
  AR_PAYMENT
  AP_BILL
  AP_PAYMENT
  // Sprint 16 — race-safe sequencing for every per-tenant document type.
  // Replaces the legacy MAX+1 / count()+1 generators across modules.
  POS_ORDER // Order.orderNumber (ORD-{YYYY}-{####})
  JOURNAL_ENTRY // JournalEntry.entryNumber (JE-{YYYYMMDD}-{####})
  LAUNDRY_CLAIM // LaundryOrder.claimNumber (CLA-{YYYY}-{######})
  TRIP_TICKET // TripTicket.tripNumber (TRIP-{YYYY}-{######})
  JOB_ORDER // JobOrder.jobNumber (JO-{YYYY}-{######})
  PROGRESS_BILLING // ProgressBilling.billingNumber (PB-{YYYY}-{######})
  MATERIAL_ISSUANCE // MaterialIssuance.issuanceNumber (ISS-{YYYY}-{######})
  PROJECT_CODE // Project.projectCode (PRJ-{YYYY}-{######})
  QUOTE // Quote.quoteNumber (Q-{YYYY}-{####})
  // Sprint 22 — AR/AP standalone-accounting parity (Xero/QB feature set).
  AR_CREDIT_MEMO // CreditMemo.memoNumber (CM-{YYYY}-{####})
  AP_CREDIT_NOTE // VendorCreditNote.noteNumber (VCN-{YYYY}-{####})
  CUSTOMER_ADVANCE // CustomerAdvance.advanceNumber (CA-{YYYY}-{####})
  VENDOR_ADVANCE // VendorAdvance.advanceNumber (VA-{YYYY}-{####})
  RECURRING_INVOICE // RecurringInvoiceTemplate.templateNumber (RI-{YYYY}-{####})
  RECURRING_BILL // RecurringBillTemplate.templateNumber (RB-{YYYY}-{####})
}

enum SequenceResetPolicy {
  NEVER
  YEARLY
  MONTHLY
}

/// Per-tenant document number generator. Atomic counter increment, optional
/// monthly/yearly reset. Format string supports {YYYY} {YY} {MM} {####} tokens.
/// Default format if null: prefix + zero-padded counter (padding chars).
model DocumentNumberSequence {
  id          String              @id @default(cuid())
  tenantId    String
  type        SequenceType
  /// Null = tenant-wide. Non-null = per-branch numbering (some tenants want
  /// distinct invoice ranges per location for BIR compliance).
  branchId    String?
  prefix      String              @default("")
  /// Optional formatter, e.g. "INV-{YYYY}-{####}" → "INV-2026-0001"
  /// {YYYY} = 4-digit year, {YY} = 2-digit year, {MM} = 2-digit month,
  /// {####} = zero-padded counter (digits = padding).
  format      String?
  padding     Int                 @default(4)
  counter     Int                 @default(0)
  /// Last reset date for monthly/yearly sequences. Used by NumberingService
  /// to decide whether the next call should reset the counter.
  lastResetAt DateTime?
  resetPolicy SequenceResetPolicy @default(NEVER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, branchId])
  @@map("document_number_sequences")
}

// ─── Payroll — Time Entries ──────────────────────────────────────────────────

/// Single clock-in / clock-out punch for an employee.
/// One OPEN entry per user at a time (enforced via unique partial index).
model TimeEntry {
  id         String          @id @default(cuid())
  tenantId   String
  userId     String
  clockIn    DateTime
  clockOut   DateTime?
  /// Break duration in minutes (deducted from gross hours)
  breakMins  Int             @default(0)
  status     TimeEntryStatus @default(OPEN)
  notes      String?
  /// Computed gross hours = (clockOut - clockIn) minus breakMins; null while OPEN
  grossHours Decimal?        @db.Decimal(6, 2)
  /// Overtime hours beyond 8h/day (PH Labor Code Art. 87)
  otHours    Decimal?        @db.Decimal(6, 2)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, clockIn])
  @@index([tenantId, userId, clockIn])
  @@index([userId, status])
  @@map("time_entries")
}

/// A payroll processing batch covering a specific period for all employees.
model PayRun {
  id              String       @id @default(cuid())
  tenantId        String
  label           String
  periodStart     DateTime
  periodEnd       DateTime
  frequency       PayFrequency @default(SEMI_MONTHLY)
  status          PayRunStatus @default(DRAFT)
  totalGross      Decimal      @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal      @default(0) @db.Decimal(14, 2)
  totalNet        Decimal      @default(0) @db.Decimal(14, 2)
  employeeCount   Int          @default(0)
  processedAt     DateTime?
  processedById   String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslips        Payslip[]

  @@index([tenantId, status])
  @@index([tenantId, periodStart])
  @@map("pay_runs")
}

/// Individual payslip generated for one employee within a PayRun.
model Payslip {
  id                String   @id @default(cuid())
  tenantId          String
  payRunId          String
  userId            String
  employeeName      String
  position          String?
  department        String?
  basicPay          Decimal  @db.Decimal(14, 2)
  overtimePay       Decimal  @default(0) @db.Decimal(14, 2)
  allowances        Decimal  @default(0) @db.Decimal(14, 2)
  grossPay          Decimal  @db.Decimal(14, 2)
  sssContrib        Decimal  @default(0) @db.Decimal(14, 2)
  philhealthContrib Decimal  @default(0) @db.Decimal(14, 2)
  pagibigContrib    Decimal  @default(0) @db.Decimal(14, 2)
  withholdingTax    Decimal  @default(0) @db.Decimal(14, 2)
  otherDeductions   Decimal  @default(0) @db.Decimal(14, 2)
  totalDeductions   Decimal  @db.Decimal(14, 2)
  netPay            Decimal  @db.Decimal(14, 2)
  regularHours      Decimal  @db.Decimal(8, 2)
  overtimeHours     Decimal  @default(0) @db.Decimal(8, 2)
  createdAt         DateTime @default(now())
  payRun            PayRun   @relation(fields: [payRunId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id])
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([payRunId])
  @@index([tenantId, userId])
  @@index([tenantId, payRunId])
  @@map("payslips")
}

/// Time-tracking punch status
enum TimeEntryStatus {
  OPEN // Clocked in; no clock-out yet
  CLOSED // Clock-out recorded; ready for payroll processing
  APPROVED // Approved by manager / payroll master
  REJECTED // Disputed entry; will not be paid
}

enum PayFrequency {
  WEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum PayRunStatus {
  DRAFT
  COMPLETED
  /// Sprint 19 — once a run is LOCKED, payslips become immutable and the
  /// salary GL has been posted. No re-process, no edit. Use this to seal a
  /// pay run after the bookkeeper has reviewed and approved the numbers.
  LOCKED
  CANCELLED
}

// ─── Phase 7 — Document Attachments ──────────────────────────────────────────

/// Generic document/attachment — links a file to any entity.
/// Stored on disk (uploads/ folder); DB tracks metadata only.
model Document {
  id           String   @id @default(cuid())
  tenantId     String
  /// Discriminator: "Order" | "ExpenseEntry" | "JournalEntry" | "ExpenseClaim" | "APBill" | "ARInvoice" | "BankReconciliation"
  entityType   String
  entityId     String
  /// Original filename as uploaded by the user
  filename     String
  /// MIME type (e.g. "application/pdf", "image/jpeg", "image/png")
  mimeType     String
  /// File size in bytes
  sizeBytes    Int
  /// Path relative to the uploads root (e.g. "tenants/abc/documents/xyz.pdf")
  storagePath  String
  /// Human label, e.g. "Official Receipt", "Delivery Receipt", "Invoice"
  label        String?
  uploadedById String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("documents")
}

// ─── Phase 8 — OR Sequential Numbering ───────────────────────────────────────

/// Tracks the next Official Receipt / Sales Invoice sequence number per tenant.
/// BIR requires sequential, unbroken OR/SI numbering (RR No. 18-2012).
model OrSequence {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  /// Prefix printed before the number (e.g. "OR", "SI", "AR")
  prefix     String   @default("OR")
  /// Last sequence number issued. Next = lastNumber + 1.
  lastNumber Int      @default(0)
  /// Zero-pad length for the numeric portion (8 → "OR-00000001")
  padLength  Int      @default(8)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("or_sequences")
}

// ─── Phase 10 — Travel & Expense Claims ──────────────────────────────────────

enum ExpenseClaimStatus {
  DRAFT // Employee filling in; not yet submitted
  SUBMITTED // Submitted for manager approval
  APPROVED // Manager approved; ready for payment
  REJECTED // Manager rejected with reason
  PAID // Reimbursed to employee
}

/// An employee expense claim (meals, transport, accommodation, supplies, etc.)
model ExpenseClaim {
  id            String             @id @default(cuid())
  tenantId      String
  branchId      String?
  /// Auto-generated number, e.g. "EC-2026-00001"
  claimNumber   String
  submittedById String
  title         String
  description   String?
  totalAmount   Decimal            @db.Decimal(14, 2)
  status        ExpenseClaimStatus @default(DRAFT)
  submittedAt   DateTime?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  paidAt        DateTime?
  paymentRef    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  ExpenseClaimItem[]

  @@unique([tenantId, claimNumber])
  @@index([tenantId, status])
  @@index([tenantId, submittedById])
  @@map("expense_claims")
}

/// One line item within an expense claim.
model ExpenseClaimItem {
  id          String   @id @default(cuid())
  claimId     String
  /// Category: "Meals", "Transport", "Accommodation", "Supplies", "Communication", "Other"
  category    String
  description String
  amount      Decimal  @db.Decimal(14, 2)
  receiptDate DateTime
  /// Receipt / OR number from the vendor
  receiptRef  String?
  createdAt   DateTime @default(now())

  claim ExpenseClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("expense_claim_items")
}

/// Auto-incrementing claim sequence counter per tenant.
model ExpenseClaimSequence {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("expense_claim_sequences")
}

/// In-app notifications for users.
/// kind drives icon + colour; link is an optional in-app deep link
/// ("/ledger/events" etc.) that the bell-dropdown navigates to.
enum NotificationKind {
  INFO
  WARNING
  ERROR
  SUCCESS
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  /// Null = tenant-wide broadcast (every user sees it)
  userId    String?
  kind      NotificationKind @default(INFO)
  title     String
  body      String?
  /// Optional in-app route to navigate to on click
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

/// Bank reconciliation — match a bank statement to GL cash account entries.
enum BankReconciliationStatus {
  IN_PROGRESS
  COMPLETED
}

model BankReconciliation {
  id            String                   @id @default(cuid())
  tenantId      String
  /// GL cash account being reconciled (1010, 1020, etc.)
  accountId     String
  /// Statement period
  periodStart   DateTime
  periodEnd     DateTime
  /// Closing balance per the bank statement (what the bank says)
  bankBalance   Decimal                  @db.Decimal(14, 2)
  /// Closing balance per the GL as of periodEnd (what our books say)
  glBalance     Decimal                  @db.Decimal(14, 2)
  /// Sum of matched amounts; books are reconciled when this == bankBalance + adjustments
  matchedAmount Decimal                  @default(0) @db.Decimal(14, 2)
  /// Free-text reconciling adjustments (outstanding checks, deposits in transit, fees)
  notes         String?
  status        BankReconciliationStatus @default(IN_PROGRESS)
  preparedById  String
  completedAt   DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  tenant     Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account    Account                  @relation(fields: [accountId], references: [id])
  preparedBy User                     @relation(fields: [preparedById], references: [id])
  items      BankReconciliationItem[]

  @@index([tenantId, accountId, periodEnd])
  @@map("bank_reconciliations")
}

/// One line on a bank reconciliation — either a statement row, a JE line, or both (matched).
model BankReconciliationItem {
  id               String    @id @default(cuid())
  reconciliationId String
  /// "STATEMENT" = bank statement line (usually unmatched at first)
  /// "JE_LINE"   = our journal line for the period
  /// "MATCHED"   = statement matched to one or more JE lines
  itemType         String
  /// Bank statement details (when itemType STATEMENT or MATCHED)
  statementDate    DateTime?
  statementDesc    String?
  statementAmount  Decimal?  @db.Decimal(14, 2)
  /// JE-line reference (when itemType JE_LINE or MATCHED)
  journalLineId    String?
  isMatched        Boolean   @default(false)
  notes            String?
  createdAt        DateTime  @default(now())

  reconciliation BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@index([reconciliationId, isMatched])
  @@map("bank_reconciliation_items")
}

/// Recurring/template Journal Entries — for monthly accruals, depreciation,
/// utility-allocation patterns. Each template stores a JE skeleton (lines as
/// JSON) and an optional cron-style schedule.
///
/// Two modes:
///   - One-shot: schedule null, user instantiates manually via "Generate now"
///   - Recurring: schedule + nextRunAt set; scheduler creates the JE on each tick
enum JournalTemplateFrequency {
  MANUAL // never auto-runs; user clicks "Generate now"
  DAILY
  WEEKLY
  MONTHLY // most common — accruals, depreciation
  QUARTERLY
  YEARLY
}

model JournalTemplate {
  id          String                   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  /// Lines as JSON: [{accountId, debit?, credit?, description?}, ...]
  /// Must balance (Σ debit = Σ credit) at instantiation time.
  lines       Json
  frequency   JournalTemplateFrequency @default(MANUAL)
  /// Next scheduled run (auto-set on save when frequency != MANUAL)
  nextRunAt   DateTime?
  lastRunAt   DateTime?
  isActive    Boolean                  @default(true)
  createdById String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, nextRunAt])
  @@map("journal_templates")
}

// ─── Sprint 3: Floor Layouts (Stations, Printers, Terminals) ─────────────────

/**
 * A station is a logical prep area where ordered items are routed for
 * preparation. Auto-provisioned from the tenant's `coffeeShopTier` template.
 * Locked structure: owner can rename (`name`), enable/disable KDS, and assign
 * categories/printers — but cannot add or remove stations beyond the template.
 */
model Station {
  id         String      @id @default(cuid())
  tenantId   String
  branchId   String?
  /// Station archetype (COUNTER / BAR / KITCHEN / HOT_BAR / COLD_BAR / PASTRY_PASS)
  /// — see packages/shared-types/src/layouts.ts
  kind       StationKind
  /// User-facing name. Defaults to the kind's defaultName but renameable.
  name       String
  /// Display order in setup screens / KDS lists.
  sortOrder  Int         @default(0)
  /// Whether this station has a Kitchen Display Screen (KDS).
  hasKds     Boolean     @default(false)
  /// Whether this station drives its own printer (separate from receipt printer).
  hasPrinter Boolean     @default(false)
  /// Optional printer assignment. When null, items still print to the receipt
  /// printer only (no separate ticket). Tier upgrades may auto-attach a printer.
  printerId  String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  printer    Printer?   @relation(fields: [printerId], references: [id], onDelete: SetNull)
  /// Categories that route to this station (drinks → BAR, food → KITCHEN, etc.)
  categories Category[] @relation("CategoryStation")

  @@index([tenantId, branchId])
  @@index([printerId])
  @@map("stations")
}

enum StationKind {
  COUNTER
  BAR
  KITCHEN
  HOT_BAR
  COLD_BAR
  PASTRY_PASS
}

/**
 * A printer registered to the tenant. Multiple stations + the receipt path
 * can share a single Printer record. Bluetooth printers are addressed via the
 * RawBT bridge URL scheme (rawbt://) on Android tablets; network printers via
 * direct TCP connection.
 */
model Printer {
  id             String           @id @default(cuid())
  tenantId       String
  branchId       String?
  /// User-facing label (e.g., "Receipt Printer", "Bar Printer").
  name           String
  /// Manufacturer + model (e.g., "Epson TM-T20", "Xprinter XP-58"). Free text.
  model          String?
  /// Connection method.
  interface      PrinterInterface @default(BLUETOOTH_RAWBT)
  /// For NETWORK: IPv4/host. For BLUETOOTH_RAWBT: paired device name or MAC.
  address        String?
  /// Paper width in mm. 58 (small thermal) or 80 (full thermal). Defaults to 80.
  paperWidthMm   Int              @default(80)
  /// Role hints — drives which jobs route here automatically.
  printsReceipts Boolean          @default(true)
  printsOrders   Boolean          @default(false) // station tickets — set true for kitchen/bar
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stations Station[]

  @@index([tenantId, branchId])
  @@map("printers")
}

enum PrinterInterface {
  /// Network printer — TCP/IP at the supplied address (most reliable).
  NETWORK
  /// Bluetooth via RawBT Android bridge — uses rawbt:// URL scheme.
  /// Requires RawBT app installed on the printing tablet.
  BLUETOOTH_RAWBT
  /// USB-attached via the OS print dialog (browser-mediated, less reliable).
  USB
  /// Native Bluetooth — only available in the Capacitor Android wrap.
  BLUETOOTH_NATIVE
}

/**
 * A cashier terminal (POS-01, POS-02, drive-thru, kiosk).
 * Multi-terminal tiers (CS_4, CS_5) auto-provision multiple Terminal rows.
 * Used for per-terminal Z-Reads and shift identification.
 */
model Terminal {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  /// User-facing label (POS-01, POS-02, Drive-Thru, Kiosk-A, etc.)
  name      String
  /// Internal code — short string for receipts ("POS01"). Auto-generated
  /// from name on create; editable.
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts Shift[]

  @@unique([tenantId, code])
  @@index([tenantId, branchId])
  @@map("terminals")
}

// ─── Sprint 4A: FIFO Lot Tracking ───────────────────────────────────────────

/**
 * A discrete supplier-delivery lot of a raw material.
 * Created on every successful `receiveRawMaterial` call regardless of the
 * tenant's valuation method (WAC or FIFO) — this keeps the data model
 * future-proof and lets a tenant inspect "how much of this delivery is left".
 * For tenants on FIFO, the orders.service consumes lots in receivedAt order
 * (oldest-first) and sums their costs for COGS. For WAC tenants, lots are
 * audit-only — the running average cost on RawMaterial.costPrice still
 * drives COGS.
 * qtyRemaining is decremented atomically as orders consume the lot; when
 * it hits zero the lot stays in the table (audit trail) but is skipped
 * during FIFO traversal.
 */
model RawMaterialLot {
  id                  String    @id @default(cuid())
  tenantId            String
  branchId            String
  rawMaterialId       String
  /// Original delivery quantity in the ingredient's unit (g, ml, pc, ...)
  qtyReceived         Decimal   @db.Decimal(12, 4)
  /// Remaining quantity — drained by FEFO/FIFO consumption.
  qtyRemaining        Decimal   @db.Decimal(12, 4)
  /// Unit cost AT THE TIME of this delivery — frozen per lot.
  unitCost            Decimal   @db.Decimal(12, 4)
  /// Business-date of receipt (cashier-provided; respects period lock).
  receivedAt          DateTime
  /// Sprint 25 — expiration date for perishables. When set, consumption
  /// follows FEFO (oldest expiry first); when null, FIFO (oldest receivedAt
  /// first). Drives 7/3/0-day expiry alerts.
  expirationDate      DateTime?
  /// Supplier reference (PO/DR/invoice no.) — purely audit metadata.
  referenceNumber     String?
  /// CASH / CREDIT / OWNER_FUNDED — mirrored from the receipt for reporting.
  paymentMethod       String?
  /// Sprint 25 — link to PurchaseOrder when received against one.
  purchaseOrderItemId String?
  createdAt           DateTime  @default(now())

  rawMaterial       RawMaterial        @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])

  // FEFO consumption sort: expirationDate ASC NULLS LAST, then receivedAt ASC
  @@index([rawMaterialId, branchId, expirationDate, receivedAt])
  @@index([rawMaterialId, branchId, receivedAt])
  @@index([tenantId, expirationDate])
  @@map("raw_material_lots")
}

// ─── Laundry vertical (BusinessType.LAUNDRY) ─────────────────────────────────
// First-class workflow for laundromat / wash-dry-fold / dry-clean tenants.
// Decoupled from Order so the workflow status (RECEIVED → READY) can advance
// independently of payment. On claim, a POS Order is created so the existing
// OR / receipt / BIR compliance flow handles the financial side.

enum LaundryServiceType {
  WASH_FOLD
  WASH_ONLY
  DRY_ONLY
  DRY_CLEAN
  IRON_ONLY
  FULL_SERVICE
}

enum LaundryPricingMode {
  PER_KG
  PER_LOAD
  PER_PIECE
  PER_GARMENT
}

enum LaundryOrderStatus {
  RECEIVED
  WASHING
  DRYING
  FOLDING
  READY_FOR_PICKUP
  CLAIMED
  CANCELLED
}

/// Sprint 11 — delivery workflow for laundry tickets. Only set when
/// LaundryOrder.isDelivery = true; null for walk-in / pickup orders.
enum LaundryDeliveryStatus {
  PENDING_PICKUP /// rider not yet dispatched
  OUT_FOR_PICKUP /// rider en route to customer
  AT_LAUNDROMAT /// laundry received from customer (back-end of pickup leg)
  OUT_FOR_DELIVERY /// rider returning the cleaned load to customer
  DELIVERED /// customer received the cleaned load — usually claimed in same beat
}

enum LaundryPaymentStatus {
  UNPAID
  PAID
}

model LaundryOrder {
  id              String                 @id @default(cuid())
  tenantId        String
  branchId        String
  customerId      String? // optional walk-in
  claimNumber     String // CLA-2026-000001 (unique per tenant per year)
  status          LaundryOrderStatus     @default(RECEIVED)
  /// Sprint 19 — Payment is independent of activity status. Customers
  /// can pay at intake (self-service / walk-in pay-upfront), at claim
  /// time (legacy full-service), or anywhere in between. paidAt + the
  /// existing orderId field get stamped the moment payment lands.
  /// Claim then only records pickup if already PAID — no double-billing.
  paymentStatus   LaundryPaymentStatus   @default(UNPAID)
  paidAt          DateTime?
  /// Legacy single-shape header fields. Sprint 7 (2026-05-08) introduced
  /// LaundryOrderLine for multi-line tickets. New tickets create lines and
  /// leave these null; old tickets still read from these. Both flows compute
  /// the same totalAmount.
  serviceType     LaundryServiceType?
  pricingMode     LaundryPricingMode?
  weightKg        Decimal?               @db.Decimal(10, 3)
  loadCount       Int?
  pieceCount      Int?
  unitPrice       Decimal?               @db.Decimal(12, 2)
  totalAmount     Decimal                @db.Decimal(12, 2)
  receivedAt      DateTime               @default(now())
  promisedAt      DateTime?
  readyAt         DateTime?
  claimedAt       DateTime?
  notes           String?
  intakeBy        String // userId (creator)
  releasedBy      String?
  orderId         String?                @unique // POS Order created on claim
  /// Sprint 11 — pickup/delivery support. When isDelivery=true, the order
  /// is delivered to deliveryAddress (auto-filled from Customer.defaultAddress
  /// if present); deliveryFee is added to totalAmount; deliveryStatus tracks
  /// the rider workflow. Non-delivery walk-in tickets keep these null/false.
  isDelivery      Boolean                @default(false)
  deliveryAddress String?
  deliveryFee     Decimal?               @db.Decimal(10, 2)
  deliveryStatus  LaundryDeliveryStatus?
  /// Sprint 11 — short shareable token (e.g. CLA-2026-000001-A1B2) used as
  /// the URL slug for the public claim-stub page. Customer can show their
  /// phone instead of the paper ticket. Token is intentionally unguessable
  /// — random 4-char suffix means an attacker can't iterate sequential
  /// claim numbers to peek at other customers' orders.
  publicStubToken String?                @unique
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch                    @relation(fields: [branchId], references: [id])
  customer          Customer?                 @relation(fields: [customerId], references: [id])
  order             Order?                    @relation(fields: [orderId], references: [id])
  items             LaundryItem[]
  lines             LaundryOrderLine[]
  productLines      LaundryProductLine[]
  promoApplications LaundryPromoApplication[]

  @@unique([tenantId, claimNumber])
  @@index([tenantId, status])
  @@index([tenantId, branchId, receivedAt])
  @@map("laundry_orders")
}

model LaundryItem {
  id          String  @id @default(cuid())
  orderId     String
  garmentType String // "shirt", "jeans", "blanket"
  quantity    Int     @default(1)
  condition   String? // intake checklist — "stained", "torn collar"
  tagNumber   String? // optional physical tag pinned to garment

  laundryOrder LaundryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("laundry_items")
}

// ─── Laundry v2 — Machines, multi-line tickets, promos (2026-05-08) ─────────
//
// PH neighborhood laundromats price PER SET (one machine load), with
// SELF_SERVICE vs FULL_SERVICE pricing. A single ticket usually has multiple
// service lines (3 wash + 2 dry + combo) PLUS retail items (detergent, bags).
// Shops have a fixed fleet of washers + dryers; cashier needs a panel to see
// which machines are free.

enum LaundryServiceCode {
  WASH
  DRY
  WASH_DRY_COMBO
  DRY_CLEAN
  IRON
  FOLD
  EXTRA_RINSE
  FABRIC_SOFTENER
}

enum LaundryServiceMode {
  SELF_SERVICE // customer operates the machine — cheaper
  FULL_SERVICE // shop staff handles the load
}

enum LaundryMachineKind {
  WASHER
  DRYER
  COMBO // single unit that does both
}

enum LaundryMachineStatus {
  IDLE
  RUNNING
  OUT_OF_ORDER
}

enum LaundryMachineLineStatus {
  NOT_STARTED
  RUNNING
  DONE
}

enum LaundryPromoKind {
  PACKAGE_DEAL // "5 wash sets for ₱250"
  PERCENT_OFF
  FLAT_OFF
  FREE_NTH // every Nth set free
}

model LaundryMachine {
  id         String               @id @default(cuid())
  tenantId   String
  branchId   String
  code       String // "W1" | "D1" — printed on machine
  kind       LaundryMachineKind
  capacityKg Decimal              @db.Decimal(6, 2)
  status     LaundryMachineStatus @default(IDLE)
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch             @relation(fields: [branchId], references: [id])
  /// Lines where this machine is the washer (or sole machine for non-combo).
  lines      LaundryOrderLine[] @relation("LineWasherMachine")
  /// Sprint 19 — Lines where this machine is the dryer half of a combo.
  dryerLines LaundryOrderLine[] @relation("LineDryerMachine")

  @@unique([tenantId, branchId, code])
  @@index([tenantId, branchId, status])
  @@map("laundry_machines")
}

/// Sprint 19 — Wash/dry cycle packages. A laundromat operator defines
/// the buttons that exist on their physical machines (e.g. "Regular Wash
/// — 30 min", "Premium Wash — 60 min", "Heavy Duty Dry — 45 min") so the
/// cashier can pick one at cycle-start and the queue page shows a live
/// countdown. With `autoComplete=true`, the @Cron worker auto-flips the
/// line to DONE + the machine back to IDLE when `cycleEndsAt` passes —
/// no manual click. Otherwise the operator still confirms but at least
/// has the timer in front of them.
model LaundryWashCycle {
  id              String             @id @default(cuid())
  tenantId        String
  /// Display label, e.g. "Regular Wash" / "Premium Wash" / "Heavy Duty Dry".
  name            String
  /// Which machine kind this cycle runs on. WASHER / DRYER / COMBO.
  kind            LaundryMachineKind
  /// Wall-clock duration of the cycle in minutes.
  durationMinutes Int
  /// When true, the @Cron worker promotes the line to DONE automatically
  /// at end of cycle; the operator does NOT need to click "Done".
  autoComplete    Boolean            @default(false)
  /// Optional surcharge: cycles like "Premium Wash" can carry a fee
  /// applied on top of the line's base unitPrice. Null = no surcharge.
  surcharge       Decimal?           @db.Decimal(10, 2)
  isActive        Boolean            @default(true)
  /// Sort order in the cycle picker. Lower = shown first.
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  LaundryOrderLine[]

  @@index([tenantId, kind, isActive])
  @@map("laundry_wash_cycles")
}

/// Tenant pricing matrix: service × mode → ₱ per set/piece.
model LaundryServicePrice {
  id          String             @id @default(cuid())
  tenantId    String
  serviceCode LaundryServiceCode
  mode        LaundryServiceMode
  unitPrice   Decimal            @db.Decimal(10, 2)
  isActive    Boolean            @default(true)
  updatedAt   DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, serviceCode, mode])
  @@index([tenantId, isActive])
  @@map("laundry_service_prices")
}

/// One service line within a LaundryOrder. Multi-line replaces the
/// single-shape header fields; old fields stay for backward compat.
model LaundryOrderLine {
  id             String                   @id @default(cuid())
  orderId        String
  serviceCode    LaundryServiceCode
  mode           LaundryServiceMode
  sets           Int                      @default(1)
  unitPrice      Decimal                  @db.Decimal(10, 2)
  lineTotal      Decimal                  @db.Decimal(12, 2)
  weightKg       Decimal?                 @db.Decimal(6, 2)
  notes          String?
  machineId      String?
  /// Sprint 19 — Wash+Dry combo support. When serviceCode is WASH_DRY_COMBO,
  /// `machineId` is the WASHER (or COMBO) used for the wash phase, and
  /// `dryerMachineId` is the DRYER (or COMBO) used for the dry phase. Most
  /// Filipino laundromats have separate washers + dryers, not all-in-one
  /// COMBO machines, so a combo package needs to be able to pick a washer
  /// + dryer pair instead of being forced onto a non-existent COMBO unit.
  /// For non-combo lines this field is always null.
  dryerMachineId String?
  machineStatus  LaundryMachineLineStatus @default(NOT_STARTED)
  startedAt      DateTime?
  finishedAt     DateTime?

  // Sprint 19 — Cycle tracking. When a cycle is picked at start time,
  // cycleEndsAt is computed = startedAt + cycle.durationMinutes. The
  // queue page shows a live countdown from this. If
  // cycleAutoComplete=true, a @Cron worker promotes the line to DONE +
  // releases the machine when cycleEndsAt passes. Otherwise the
  // countdown is informational only and the operator clicks Done.
  cycleId           String?
  cycleEndsAt       DateTime?
  cycleAutoComplete Boolean   @default(false)

  order        LaundryOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  machine      LaundryMachine?         @relation("LineWasherMachine", fields: [machineId], references: [id])
  dryerMachine LaundryMachine?         @relation("LineDryerMachine", fields: [dryerMachineId], references: [id])
  cycle        LaundryWashCycle?       @relation(fields: [cycleId], references: [id])
  addOns       LaundryOrderLineAddOn[]

  @@index([orderId])
  @@index([machineId])
  @@index([dryerMachineId])
  @@index([cycleEndsAt, machineStatus, cycleAutoComplete]) // cron scan target
  @@map("laundry_order_lines")
}

/// Retail items in a laundry ticket — detergents, bags, hangers. Links to
/// the existing Product catalog so retail SKUs work the same as in regular POS.
model LaundryProductLine {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(12, 2)
  notes     String?

  order   LaundryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("laundry_product_lines")
}

model LaundryPromo {
  id         String           @id @default(cuid())
  tenantId   String
  code       String // "WASH5FOR250"
  name       String // "5 wash sets for ₱250"
  kind       LaundryPromoKind
  /// JSON conditions; shape varies by kind. See LaundryPromoEvaluator.
  conditions Json
  priority   Int              @default(100)
  isActive   Boolean          @default(true)
  validFrom  DateTime?
  validTo    DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("laundry_promos")
}

model LaundryPromoApplication {
  id             String   @id @default(cuid())
  orderId        String
  promoCode      String
  promoName      String
  discountAmount Decimal  @db.Decimal(12, 2)
  appliedAt      DateTime @default(now())

  order LaundryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("laundry_promo_applications")
}

/// Tenant-defined service add-on / modifier (Sprint 8, 2026-05-08).
/// Lets the owner price arbitrary variants on top of the standard service codes:
///   - "BYO detergent" (SURCHARGE, amount=-15)
///   - "Without folding" (SURCHARGE, amount=-20)
///   - "Extra rinse" (SURCHARGE, amount=+10)
///   - "Express 1-hr" (SURCHARGE, amount=+50)
enum LaundryAddOnKind {
  SURCHARGE
  FLAT_FEE
}

model LaundryServiceAddOn {
  id        String           @id @default(cuid())
  tenantId  String
  code      String
  name      String
  kind      LaundryAddOnKind @default(SURCHARGE)
  amount    Decimal          @db.Decimal(10, 2)
  priority  Int              @default(100)
  defaultOn Boolean          @default(false)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  LaundryOrderLineAddOn[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("laundry_service_addons")
}

model LaundryOrderLineAddOn {
  id            String           @id @default(cuid())
  lineId        String
  addOnId       String
  kind          LaundryAddOnKind
  code          String
  name          String
  amountPerUnit Decimal          @db.Decimal(10, 2)
  totalAmount   Decimal          @db.Decimal(12, 2)
  appliedAt     DateTime         @default(now())

  line  LaundryOrderLine    @relation(fields: [lineId], references: [id], onDelete: Cascade)
  addOn LaundryServiceAddOn @relation(fields: [addOnId], references: [id])

  @@index([lineId])
  @@index([addOnId])
  @@map("laundry_order_line_addons")
}

// ─── Payroll: Leave management + 13th-month (Sprint 3, 2026-05-08) ────────────

enum LeaveType {
  VACATION
  SICK
  EMERGENCY
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id              String      @id @default(cuid())
  tenantId        String
  userId          String
  type            LeaveType
  status          LeaveStatus @default(PENDING)
  startDate       DateTime
  endDate         DateTime
  daysCount       Decimal     @db.Decimal(4, 2)
  reason          String
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user     User  @relation("UserLeaves", fields: [userId], references: [id])
  approver User? @relation("LeaveApprover", fields: [approvedBy], references: [id])

  @@index([tenantId, status])
  @@index([userId, startDate])
  @@map("leave_requests")
}

/// Sprint 19 — pre-destructive snapshot taken before any console-initiated
/// data wipe (resetDemoData / clearAllTenantData). Even though those ops
/// now refuse to run on live (non-demo) tenants, the snapshot is the
/// belt-and-suspenders: a downloadable JSON dump of every row about to be
/// deleted, so a misclassified demo flag or a future code path that
/// bypasses the guard can still be recovered from.
///
/// payload shape (JSONB):
///   {
///     orders: [...], orderItems: [...], orderPayments: [...],
///     accountingEvents: [...], journalEntries: [...], journalLines: [...],
///     products: [...], categories: [...], bomItems: [...],
///     rawMaterials: [...], rawMaterialInventory: [...],
///     inventoryItems: [...], inventoryLogs: [...],
///     customers: [...]   (when applicable)
///   }
///
/// Auto-purged after 30 days via @Cron — these are recovery tools, not
/// audit logs.
model TenantDataSnapshot {
  id           String   @id @default(cuid())
  tenantId     String
  /// Why this snapshot was taken: PRE_RESET_DEMO | PRE_CLEAR_ALL | MANUAL.
  reason       String
  /// SUPER_ADMIN user id who triggered the destructive op (or null for cron).
  takenById    String?
  takenByEmail String?
  /// Total rows captured across all tables in payload (for the UI summary).
  rowCount     Int      @default(0)
  /// Compressed-ish JSON blob — each top-level key is a Prisma model name.
  payload      Json     @default("{}")
  /// Soft cutoff for cron purge. Default 30 days from creation.
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("tenant_data_snapshots")
}

/// Sync-Requests (Sprint 18) — generic employee self-service workflows.
///
/// One polymorphic table covers the 4 short-form workflows that share an
/// approval pattern but differ in specifics:
///   COA      — Certificate of Attendance (missed-clock log)
///   SCHEDULE — Schedule Adjustment (temporary shift change)
///   OB       — Official Business (off-site work)
///   OT       — Overtime (post-shift extra hours)
///   UT       — Undertime (early-out / short shift)
///
/// LeaveRequest stays separate — it has fundamentally different semantics
/// (multi-day, leave-credit math, BIR DTR impact, leave-type ledger). These
/// 5 are all "single-day deviation from a normal shift" and share the same
/// approve/reject flow and the same UI shell.
///
/// `payload` is a Json blob; the shape varies by `kind` and is validated in
/// the service layer (we want to evolve fields without migrating the table).
enum EmployeeRequestKind {
  COA // Certificate of Attendance (missed clock-in/out)
  SCHEDULE // Schedule Adjustment (temporary)
  OB // Official Business (off-site)
  OT // Overtime
  UT // Undertime
}

enum EmployeeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model EmployeeRequest {
  id              String                @id @default(cuid())
  tenantId        String
  userId          String
  kind            EmployeeRequestKind
  status          EmployeeRequestStatus @default(PENDING)
  /// The day the request applies to (the work day in question).
  forDate         DateTime              @db.Date
  /// Free-form reason / justification (mandatory for all kinds).
  reason          String
  /// Kind-specific payload — see service for shape per kind.
  ///   COA      : { clockIn?: ISO, clockOut?: ISO }
  ///   SCHEDULE : { newStart: HH:MM, newEnd: HH:MM }
  ///   OB       : { startTime: ISO, endTime: ISO, location: string }
  ///   OT       : { startTime: ISO, endTime: ISO, hoursClaimed: number }
  ///   UT       : { earlyOutAt: ISO, hoursMissed: number }
  payload         Json                  @default("{}")
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user     User  @relation("UserEmployeeRequests", fields: [userId], references: [id])
  approver User? @relation("EmployeeRequestApprover", fields: [approvedBy], references: [id])

  @@index([tenantId, status, kind])
  @@index([userId, forDate])
  @@map("employee_requests")
}

/// 13th-month-pay tracker — one row per employee per year.
/// Computed as basicSalaryYTD / 12. Idempotent on (tenantId, userId, year).
model ThirteenthMonth {
  id               String    @id @default(cuid())
  tenantId         String
  userId           String
  year             Int
  basicSalaryYTD   Decimal   @db.Decimal(12, 2)
  amount           Decimal   @db.Decimal(12, 2)
  paidAt           DateTime?
  paidViaPayslipId String?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId, year])
  @@map("thirteenth_month")
}

// ─── Warehousing: Stock transfers + cycle counts (Sprint 6, 2026-05-08) ──────
//
// StockTransfer moves raw materials between branches. The receiving branch's
// RawMaterialInventory increases when the transfer is RECEIVED; the sending
// branch's decreases at SENT time. Lots are NOT moved — the receiving branch
// gets a fresh lot at the originating lot's WAC. Audit trail preserved via
// inline lines + status timeline.

enum StockTransferStatus {
  DRAFT // created but not yet sent
  IN_TRANSIT // sent from origin; awaiting receipt
  RECEIVED // booked at destination
  CANCELLED
}

model StockTransfer {
  id             String              @id @default(cuid())
  tenantId       String
  transferNumber String // ST-{YYYY}-{6-digit-seq}
  fromBranchId   String
  toBranchId     String
  status         StockTransferStatus @default(DRAFT)
  notes          String?
  createdById    String
  sentAt         DateTime?
  receivedAt     DateTime?
  receivedById   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromBranch Branch              @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  toBranch   Branch              @relation("TransferToBranch", fields: [toBranchId], references: [id])
  lines      StockTransferLine[]

  @@unique([tenantId, transferNumber])
  @@index([tenantId, status])
  @@index([tenantId, fromBranchId, createdAt])
  @@index([tenantId, toBranchId, createdAt])
  @@map("stock_transfers")
}

model StockTransferLine {
  id            String  @id @default(cuid())
  transferId    String
  rawMaterialId String
  quantity      Decimal @db.Decimal(12, 3)
  unitCost      Decimal @db.Decimal(12, 4) // copied from origin WAC at send time
  notes         String?

  transfer    StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial   @relation(fields: [rawMaterialId], references: [id])

  @@index([transferId])
  @@index([rawMaterialId])
  @@map("stock_transfer_lines")
}

// CycleCount — physical-count session per branch. Captures expected vs actual
// quantity per ingredient/product; on POST creates an InventoryLog adjustment
// for any discrepancies. Provides audit trail for "I counted X, system said Y."

enum CycleCountStatus {
  OPEN
  POSTED
  CANCELLED
}

model CycleCount {
  id          String           @id @default(cuid())
  tenantId    String
  branchId    String
  countNumber String // CC-{YYYY}-{6-digit-seq}
  status      CycleCountStatus @default(OPEN)
  notes       String?
  startedById String
  postedById  String?
  postedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch           @relation(fields: [branchId], references: [id])
  lines  CycleCountLine[]

  @@unique([tenantId, countNumber])
  @@index([tenantId, branchId, status])
  @@map("cycle_counts")
}

model CycleCountLine {
  id            String  @id @default(cuid())
  countId       String
  rawMaterialId String
  expectedQty   Decimal @db.Decimal(12, 3) // snapshot from RawMaterialInventory at start
